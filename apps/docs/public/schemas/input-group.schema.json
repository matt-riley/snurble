{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "size": {
      "description": "Control size.",
      "enum": ["sm", "md", "lg"],
      "default": "md"
    },
    "invalid": {
      "description": "Show invalid styling.",
      "type": "boolean",
      "default": "false"
    },
    "disabled": {
      "description": "Show disabled styling.",
      "type": "boolean",
      "default": "false"
    },
    "class": {
      "description": "Additional CSS classes.",
      "type": "string"
    }
  },
  "title": "InputGroup Props",
  "type": "object"
}
