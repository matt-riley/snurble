---
import {
  Accordion,
  Alert,
  Badge,
  BentoGrid,
  BentoItem,
  Breadcrumbs,
  Button,
  Callout,
  Checkbox,
  CodeSnippet,
  DataTable,
  DecoratedHeading,
  DescriptionList,
  Dialog,
  Drawer,
  DropdownMenu,
  EmptyState,
  ExperienceCard,
  ExperienceList,
  Field,
  FilterBar,
  FormError,
  FormHint,
  Hero,
  IconButton,
  Input,
  LinkButton,
  MetaList,
  PageShell,
  Pagination,
  Panel,
  Popover,
  ProfileHero,
  ProjectCard,
  ProjectGrid,
  RadioGroup,
  Section,
  Select,
  Skeleton,
  SkillIcon,
  SkillIconList,
  SocialLinks,
  SortIndicator,
  Sparkle,
  SegmentedControl,
  Stack,
  StatCard,
  Switch,
  TableOfContents,
  Tabs,
  Textarea,
  ThemeToggle,
  Toast,
  Tooltip,
} from "@matt-riley/ui-astro";

import { componentDocs } from "../../component-docs/registry";
import type { ComponentDocEntry } from "../../component-docs/registry";

interface Props {
  entry: ComponentDocEntry;
}

const { entry } = Astro.props;

const breadcrumbItems = [
  { href: "/", label: "Docs" },
  { href: "/components", label: "Components" },
  { label: entry.name },
];

const tabs = [
  { id: "overview", label: "Overview" },
  { id: "usage", label: "Usage" },
  { id: "notes", label: "Notes" },
];

const accordionItems = [
  { expanded: true, id: "contract", title: "What it does" },
  { id: "ownership", title: "What stays consumer-owned" },
];

const radioOptions = [
  { id: "radio-docs", label: "Docs", value: "docs" },
  { id: "radio-components", label: "Components", value: "components" },
];

const selectOptions = [
  { label: "Foundation", value: "foundation" },
  { label: "Forms", value: "forms" },
  { label: "Overlays", value: "overlays" },
];

const menuItems = [
  { label: "Duplicate", value: "duplicate" },
  { label: "Archive", value: "archive" },
  { label: "Delete", value: "delete", variant: "danger" as const },
];

const tocItems = [
  { id: "overview", label: "Overview", level: 1 },
  { id: "demo", label: "Curated demo", level: 1 },
  { id: "reference", label: "Reference", level: 1 },
];

const socialLinks = [
  { href: "https://github.com/matt-riley", icon: "github", label: "GitHub profile" },
  { href: "https://linkedin.com/in/matthewjriley", icon: "linkedin", label: "LinkedIn profile" },
];

const badgeVariants = [
  { label: "Default", variant: "default" },
  { label: "Success", variant: "success" },
  { label: "Warning", variant: "warning" },
  { label: "Danger", variant: "danger" },
  { label: "Info", variant: "info" },
] as const;

const alertVariants = [
  { description: "Tokens ship separately.", title: "Heads up", variant: "info" },
  { description: "Release tag moved to latest.", title: "Published", variant: "success" },
  { description: "Missing package token in local shell.", title: "Check config", variant: "warning" },
  { description: "Production build needs attention before retry.", title: "Deploy failed", variant: "danger" },
] as const;

const popoverPositions = [
  { label: "Top", value: "top" },
  { label: "Bottom", value: "bottom" },
  { label: "Left", value: "left" },
  { label: "Right", value: "right" },
] as const;

const codeSnippetDemo = `const publishTag = "next";

console.log(\`Publishing Snurble with the \${publishTag} dist-tag\`);`;
---

<Stack space={4}>
  {entry.name === "Layout" && (
    <Panel variant="bordered">
      <Stack space={3}>
        <p class="text-sm text-[var(--snurble-text-muted)]">
          This page is already rendered inside <code>Layout</code> via <code>BaseLayout</code>.
          The live shell around this content is the demonstration.
        </p>
      </Stack>
    </Panel>
  )}

  {entry.name === "PageShell" && (
    <PageShell class="flex flex-col gap-4 rounded-lg border border-[var(--snurble-border)] p-4">
      <Panel variant="bordered">PageShell controls readable page width and section rhythm.</Panel>
      <Panel variant="bordered">Use it as the main wrapper for a full page.</Panel>
    </PageShell>
  )}

  {entry.name === "Hero" && <Hero title="Component docs" lede="Hero introduces a page with high-signal context." />}

  {entry.name === "Section" && (
    <Section title="Overview" headingId="section-demo-heading">
      <Panel variant="bordered">Section wraps titled content blocks with a stable heading contract.</Panel>
    </Section>
  )}

  {entry.name === "Panel" && <Panel variant="glass">Panels provide shared flat, bordered, elevated, or glass surfaces.</Panel>}

  {entry.name === "DataTable" && (
    <div>
      <h3 id="data-table-demo-heading" class="mb-3 text-lg font-semibold">Release matrix</h3>
      <DataTable labelledBy="data-table-demo-heading" striped>
        <tr slot="head">
          <th>Surface</th>
          <th>Status</th>
        </tr>
        <tr>
          <td data-label="Surface">Docs app</td>
          <td data-label="Status">Ready</td>
        </tr>
        <tr>
          <td data-label="Surface">UI package</td>
          <td data-label="Status">Stable</td>
        </tr>
      </DataTable>
    </div>
  )}

  {entry.name === "MetaList" && (
    <MetaList>
      <dt>Status</dt>
      <dd>Stable</dd>
      <dt>Registry</dt>
      <dd>GitHub Packages</dd>
    </MetaList>
  )}

  {entry.name === "CodeSnippet" && (
    <CodeSnippet
      variant="block"
      code={codeSnippetDemo}
      language="ts"
      label="Highlighted TypeScript example"
    />
  )}

  {entry.name === "Stack" && (
    <Stack space={3}>
      <Panel variant="bordered">First item</Panel>
      <Panel variant="bordered">Second item</Panel>
      <Panel variant="bordered">Third item</Panel>
    </Stack>
  )}

  {entry.name === "BentoGrid" && (
    <BentoGrid columns={1} columnsMd={2} columnsLg={3} gap={4}>
      <BentoItem colSpan={1} colSpanLg={2}>
        <Panel variant="glass">Featured panel with extra breathing room.</Panel>
      </BentoItem>
      <BentoItem>
        <Panel variant="bordered">Compact supporting card.</Panel>
      </BentoItem>
      <BentoItem>
        <Panel variant="elevated">Another surface in the grid.</Panel>
      </BentoItem>
    </BentoGrid>
  )}

  {entry.name === "BentoItem" && (
    <BentoGrid columns={2} columnsLg={3} gap={4}>
      <BentoItem colSpan={2} rowSpan={1} colSpanLg={2}>
        <Panel variant="glass">BentoItem controls span inside the parent grid.</Panel>
      </BentoItem>
      <BentoItem>
        <Panel variant="bordered">Sibling card</Panel>
      </BentoItem>
    </BentoGrid>
  )}

  {["FontAssets", "JsonLd", "SkipLink", "SeoMeta", "ServiceWorker", "AgentDiscoveryHint"].includes(entry.name) && (
    <Panel variant="bordered">
      <p class="text-sm text-[var(--snurble-text-muted)]">
        {entry.name} works at the document or page shell layer. Its primary effect is part of the
        current route wiring rather than a visible in-body widget.
      </p>
    </Panel>
  )}

  {entry.name === "ProfileHero" && (
    <ProfileHero
      name="Matt Riley"
      subtitle="Senior Software Engineer in Leeds, West Yorkshire"
      avatarSrc="https://github.com/matt-riley.png"
      avatarAlt="Matt Riley"
    />
  )}

  {entry.name === "SocialLinks" && <SocialLinks links={socialLinks} />}

  {entry.name === "DecoratedHeading" && <DecoratedHeading text="Snurble" />}

  {entry.name === "ProjectCard" && (
    <ProjectCard
      name="Snurble"
      description="Shared Astro design tokens and UI primitives."
      url="https://github.com/matt-riley/snurble"
      stars={54}
      languages={[{ name: "TypeScript", color: "#3178c6" }]}
      topics={["astro", "design-system"]}
    />
  )}

  {entry.name === "ProjectGrid" && (
    <ProjectGrid>
      <li>
        <ProjectCard
          name="Snurble"
          description="Shared Astro design tokens and UI primitives."
          url="https://github.com/matt-riley/snurble"
          topics={["astro"]}
        />
      </li>
      <li>
        <ProjectCard
          name="workv2"
          description="Reference implementation that shaped the shared system."
          url="https://github.com/matt-riley/workv2"
          topics={["reference"]}
        />
      </li>
    </ProjectGrid>
  )}

  {entry.name === "ExperienceCard" && (
    <ExperienceCard
      logo="https://github.com/matt-riley.png"
      title="Senior Engineer"
      company="Example Corp"
      description="<p>Built shared UI systems and delivery tooling.</p>"
      start="2023-01"
      end="2024-12"
    >
      <SkillIcon slot="skills" name="typescript" label="TypeScript" />
      <SkillIcon slot="skills" name="astro" label="Astro" />
    </ExperienceCard>
  )}

  {entry.name === "ExperienceList" && (
    <ExperienceList>
      <li>
        <ExperienceCard
          logo="https://github.com/matt-riley.png"
          title="Senior Engineer"
          company="Example Corp"
          description="<p>Built shared UI systems and delivery tooling.</p>"
          start="2023-01"
          end="2024-12"
        />
      </li>
    </ExperienceList>
  )}

  {entry.name === "SkillIcon" && (
    <SkillIcon name="typescript" label="TypeScript" />
  )}

  {entry.name === "SkillIconList" && (
    <SkillIconList title="Core skills">
      <SkillIcon name="typescript" label="TypeScript" />
      <SkillIcon name="astro" label="Astro" />
    </SkillIconList>
  )}

  {entry.name === "Button" && <Button>Ship it</Button>}
  {entry.name === "IconButton" && <IconButton ariaLabel="Open menu"><span aria-hidden="true">☰</span></IconButton>}
  {entry.name === "LinkButton" && <LinkButton href="/components/button">Button docs</LinkButton>}
  {entry.name === "Badge" && (
    <div class="flex flex-wrap gap-3">
      {badgeVariants.map(({ label, variant }) => (
        <Badge variant={variant}>{label}</Badge>
      ))}
    </div>
  )}
  {entry.name === "Alert" && (
    <Stack space={3}>
      {alertVariants.map(({ description, title, variant }) => (
        <Alert title={title} description={description} variant={variant} />
      ))}
    </Stack>
  )}
  {entry.name === "Callout" && <Callout title="Consumer-owned">Route metadata stays local.</Callout>}
  {entry.name === "EmptyState" && (
    <EmptyState title="No releases yet" description="Publish a prerelease to get started.">
      <Button>Publish next</Button>
    </EmptyState>
  )}
  {entry.name === "Skeleton" && <Skeleton width="100%" height="2.5rem" />}
  {entry.name === "Breadcrumbs" && <Breadcrumbs items={breadcrumbItems} />}
  {entry.name === "Tabs" && (
    <Tabs tabs={tabs} defaultTab="overview">
      <Fragment slot="overview">
        <Panel variant="bordered">Overview content lives in named slots.</Panel>
      </Fragment>
      <Fragment slot="usage">
        <Panel variant="bordered">Usage content can be switched client-light.</Panel>
      </Fragment>
      <Fragment slot="notes">
        <Panel variant="bordered">Keep tab labels concise and stable.</Panel>
      </Fragment>
    </Tabs>
  )}
  {entry.name === "Accordion" && (
    <Accordion items={accordionItems}>
      <Fragment slot="contract">
        <p>Accordion reveals supporting sections progressively.</p>
      </Fragment>
      <Fragment slot="ownership">
        <p>Pages still own the section order and content.</p>
      </Fragment>
    </Accordion>
  )}
  {entry.name === "Pagination" && <Pagination currentPage={2} totalPages={8} />}
  {entry.name === "TableOfContents" && <TableOfContents headings={tocItems} />}

  {entry.name === "Field" && (
    <Field
      label="Email"
      htmlFor="field-demo-email"
      description="We only use this for release notes."
    >
      <Input id="field-demo-email" type="email" placeholder="matt@example.com" />
    </Field>
  )}
  {entry.name === "Input" && <Input id="input-demo" type="email" placeholder="matt@example.com" />}
  {entry.name === "Textarea" && <Textarea id="textarea-demo" placeholder="Tell us more..." rows={4} />}
  {entry.name === "Checkbox" && <Checkbox id="checkbox-demo" label="Email me release updates" checked />}
  {entry.name === "RadioGroup" && (
    <RadioGroup
      name="demo-surface"
      label="Primary docs surface"
      options={radioOptions}
      defaultValue="components"
    />
  )}
  {entry.name === "Select" && (
    <Select id="select-demo" options={selectOptions} defaultValue="forms" placeholder="Choose a category" />
  )}
  {entry.name === "Switch" && <Switch id="switch-demo" label="Enable announcements" checked />}
  {entry.name === "FormHint" && (
    <Field label="Email" htmlFor="hint-demo-email">
      <Input id="hint-demo-email" type="email" placeholder="matt@example.com" />
      <FormHint id="hint-demo-email-hint" text="We only use this for release updates." />
    </Field>
  )}
  {entry.name === "FormError" && (
    <Field label="Email" htmlFor="error-demo-email" error="Enter a valid email address.">
      <Input id="error-demo-email" type="email" value="invalid" />
      <FormError id="error-demo-email-error" text="Enter a valid email address." />
    </Field>
  )}

  {entry.name === "Dialog" && (
    <Dialog open title="Delete release">
      <Stack space={3}>
        <p>This cannot be undone.</p>
        <div class="flex gap-3">
          <Button variant="secondary">Cancel</Button>
          <Button variant="danger">Delete</Button>
        </div>
      </Stack>
    </Dialog>
  )}

  {entry.name === "Drawer" && (
    <Drawer open title="Filters">
      <Stack space={3}>
        <Checkbox id="drawer-checkbox" label="Only stable components" checked />
        <Checkbox id="drawer-checkbox-2" label="Show shell helpers" />
      </Stack>
    </Drawer>
  )}

  {entry.name === "Popover" && (
    <div
      class="popover-docs-demo rounded-lg border border-[var(--snurble-border)] bg-[var(--snurble-surface-card)] p-4"
      data-popover-docs-demo
    >
      <div class="popover-docs-controls">
        <label class="popover-docs-field">
          <span class="popover-docs-field-label">Position</span>
          <select
            class="popover-docs-select"
            data-popover-position
            aria-label="Popover position"
          >
            {popoverPositions.map((option) => (
              <option value={option.value}>{option.label}</option>
            ))}
          </select>
        </label>

        <label class="popover-docs-checkbox">
          <input type="checkbox" data-popover-title checked />
          <span>Show title</span>
        </label>

        <label class="popover-docs-checkbox">
          <input type="checkbox" data-popover-outside checked />
          <span>Close on outside click</span>
        </label>
      </div>

      <div
        class="popover-docs-stage rounded-lg border border-dashed border-[var(--snurble-border)]"
      >
        <div class="popover-docs-anchor">
          <button
            type="button"
            class="popover-docs-open rounded-md border border-[var(--snurble-border)] px-3 py-2 text-sm font-medium text-[var(--snurble-text)]"
            data-popover-open
          >
            Open popover
          </button>
          <p class="text-center text-xs text-[var(--snurble-text-muted)]">
            Click empty stage to test outside click behavior.
          </p>
        </div>

        <div data-popover-wrapper="titled">
          <Popover
            open
            title="Popover details"
            class="popover-docs-surface popover-docs-surface-titled"
          >
            <Stack space={2}>
              <p>Popover content stays short and contextual.</p>
              <p class="text-xs text-[var(--snurble-text-muted)]">
                Titled variant includes built-in close button.
              </p>
            </Stack>
          </Popover>
        </div>

        <div data-popover-wrapper="untitled" hidden>
          <Popover open class="popover-docs-surface popover-docs-surface-untitled">
            <Stack space={2}>
              <p>Popover content stays short and contextual.</p>
              <p class="text-xs text-[var(--snurble-text-muted)]">
                Untitled variant keeps chrome lighter for brief supporting copy.
              </p>
            </Stack>
          </Popover>
        </div>
      </div>

      <p class="text-sm text-[var(--snurble-text-muted)]">
        Toggle title, placement, and outside-click dismissal, then reopen preview as needed.
      </p>
    </div>
  )}

  {entry.name === "DropdownMenu" && <DropdownMenu open items={menuItems} />}

  {entry.name === "Tooltip" && (
    <div class="relative min-h-24">
      <button aria-describedby="tooltip-demo" type="button" class="rounded border px-3 py-2">
        Copy
      </button>
      <Tooltip id="tooltip-demo" text="Copy install command" />
    </div>
  )}

  {entry.name === "StatCard" && (
    <StatCard
      label="Documented components"
      value={componentDocs.length}
      trend="up"
      trendValue="catalog-driven"
    />
  )}

  {entry.name === "DescriptionList" && (
    <DescriptionList
      items={[
        { term: "Registry", description: "GitHub Packages" },
        { term: "Validation", description: "pnpm run validate" },
      ]}
    />
  )}

  {entry.name === "FilterBar" && (
    <FilterBar>
      <Button variant="secondary" size="sm">Newest</Button>
      <Button variant="secondary" size="sm">Stable only</Button>
    </FilterBar>
  )}

  {entry.name === "SortIndicator" && <SortIndicator label="Updated" sortOrder="desc" />}

  {entry.name === "ThemeToggle" && (
    <div class="flex items-center gap-4">
      <ThemeToggle />
      <p class="text-sm text-[var(--snurble-text-muted)]">
        Toggle the switch to see the track and icon animations.
      </p>
    </div>
  )}

  {entry.name === "SegmentedControl" && (
    <SegmentedControl
      name="demo-view"
      options={[
        { label: "List", value: "list" },
        { label: "Grid", value: "grid" },
        { label: "Gallery", value: "gallery" },
      ]}
      defaultValue="grid"
    />
  )}

  {entry.name === "Sparkle" && (
    <div class="flex items-center gap-8 py-4">
      <Sparkle size="sm" />
      <Sparkle size="md" />
      <Sparkle size="lg" />
      <Sparkle size="md" color="var(--snurble-brand-primary)" />
      <p class="text-sm text-[var(--snurble-text-muted)]">
        Sparkles pop once upon rendering. Refresh to see them again!
      </p>
    </div>
  )}

  {entry.name === "Toast" && (
    <div class="flex flex-col gap-4">
      <div class="flex gap-3">
        <Button
          variant="secondary"
          size="sm"
          data-toast-trigger
          data-toast-message="Deployment successful!"
          data-toast-variant="success"
        >
          Success Toast
        </Button>
        <Button
          variant="secondary"
          size="sm"
          data-toast-trigger
          data-toast-message="Something went wrong."
          data-toast-variant="error"
        >
          Error Toast
        </Button>
      </div>
      <p class="text-sm text-[var(--snurble-text-muted)]">
        Click the buttons to trigger non-blocking notifications.
      </p>
      <Toast position="bottom-right" />
    </div>
  )}
</Stack>

<style>
  .popover-docs-demo {
    display: grid;
    gap: var(--snurble-space-4);
  }

  .popover-docs-controls {
    display: grid;
    gap: var(--snurble-space-3);
  }

  .popover-docs-field {
    display: grid;
    gap: var(--snurble-space-2);
  }

  .popover-docs-field-label {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .popover-docs-select {
    min-height: 2.5rem;
    border: 1px solid var(--snurble-border);
    border-radius: 0.5rem;
    background: var(--snurble-surface);
    color: var(--snurble-text);
    padding-inline: var(--snurble-space-3);
  }

  .popover-docs-checkbox {
    display: inline-flex;
    gap: var(--snurble-space-2);
    align-items: center;
    font-size: 0.875rem;
    color: var(--snurble-text);
  }

  .popover-docs-stage {
    position: relative;
    min-height: 19rem;
    padding: var(--snurble-space-5);
    background:
      radial-gradient(circle at center, rgba(89, 131, 254, 0.12), transparent 55%),
      var(--snurble-surface);
    overflow: hidden;
  }

  .popover-docs-anchor {
    position: absolute;
    inset: 50% auto auto 50%;
    display: grid;
    gap: var(--snurble-space-2);
    justify-items: center;
    transform: translate(-50%, -50%);
  }

  .popover-docs-open {
    background: var(--snurble-surface-card);
    transition:
      background-color 150ms ease-out,
      transform 150ms ease-out;
  }

  .popover-docs-open:hover {
    background: var(--snurble-surface-hover, rgba(255, 255, 255, 0.08));
  }

  .popover-docs-open:active {
    transform: scale(0.98);
  }

  .popover-docs-open:focus-visible,
  .popover-docs-select:focus-visible {
    outline: 2px solid var(--snurble-brand-primary);
    outline-offset: 2px;
  }

  .popover-docs-demo :global(.popover-docs-surface.snurble-popover) {
    position: absolute;
    inset: auto;
    max-width: min(20rem, calc(100% - 2rem));
    animation: none;
    opacity: 1;
    pointer-events: auto;
  }

  .popover-docs-demo :global(.popover-docs-surface.snurble-popover-top) {
    bottom: calc(50% + 3rem);
    left: 50%;
    transform: translateX(-50%);
  }

  .popover-docs-demo :global(.popover-docs-surface.snurble-popover-bottom) {
    top: calc(50% + 3rem);
    left: 50%;
    transform: translateX(-50%);
  }

  .popover-docs-demo :global(.popover-docs-surface.snurble-popover-left) {
    top: 50%;
    right: calc(50% + 4rem);
    transform: translateY(-50%);
  }

  .popover-docs-demo :global(.popover-docs-surface.snurble-popover-right) {
    top: 50%;
    left: calc(50% + 4rem);
    transform: translateY(-50%);
  }

  @media (min-width: 48rem) {
    .popover-docs-controls {
      grid-template-columns: minmax(0, 12rem) repeat(2, auto);
      align-items: end;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .popover-docs-open {
      transition: none;
    }
  }
</style>

<script>
  const popoverPositions = ["top", "bottom", "left", "right"];

  const syncPopoverDemo = (demo: HTMLElement) => {
    const positionControl = demo.querySelector("[data-popover-position]");
    const titleControl = demo.querySelector("[data-popover-title]");
    const outsideControl = demo.querySelector("[data-popover-outside]");
    const openButton = demo.querySelector("[data-popover-open]");
    const titledWrapper = demo.querySelector('[data-popover-wrapper="titled"]');
    const untitledWrapper = demo.querySelector('[data-popover-wrapper="untitled"]');
    const titledPopover =
      titledWrapper instanceof HTMLElement
        ? titledWrapper.querySelector(".snurble-popover")
        : null;
    const untitledPopover =
      untitledWrapper instanceof HTMLElement
        ? untitledWrapper.querySelector(".snurble-popover")
        : null;

    if (
      !(positionControl instanceof HTMLSelectElement) ||
      !(titleControl instanceof HTMLInputElement) ||
      !(outsideControl instanceof HTMLInputElement) ||
      !(openButton instanceof HTMLButtonElement) ||
      !(titledWrapper instanceof HTMLElement) ||
      !(untitledWrapper instanceof HTMLElement) ||
      !(titledPopover instanceof HTMLElement) ||
      !(untitledPopover instanceof HTMLElement)
    ) {
      return;
    }

    const popovers = {
      titled: { popover: titledPopover, wrapper: titledWrapper },
      untitled: { popover: untitledPopover, wrapper: untitledWrapper },
    };

    const setPositionClass = (popover: HTMLElement, position: string) => {
      for (const value of popoverPositions) {
        popover.classList.remove(`snurble-popover-${value}`);
      }

      popover.classList.add(`snurble-popover-${position}`);
      popover.dataset.position = position;
    };

    const apply = () => {
      const position = positionControl.value;
      const closeOnOutsideClick = String(outsideControl.checked);
      const activeKey = titleControl.checked ? "titled" : "untitled";

      for (const [key, entry] of Object.entries(popovers)) {
        const isActive = key === activeKey;

        entry.wrapper.hidden = !isActive;
        entry.popover.dataset.closeOnOutside = closeOnOutsideClick;
        entry.popover.dataset.open = isActive ? "true" : "false";
        setPositionClass(entry.popover, position);
      }
    };

    openButton.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();

      const activePopover = titleControl.checked
        ? popovers.titled.popover
        : popovers.untitled.popover;

      activePopover.dataset.open = "true";
    });

    positionControl.addEventListener("change", apply);
    titleControl.addEventListener("change", apply);
    outsideControl.addEventListener("change", apply);

    apply();
  };

  for (const demo of document.querySelectorAll("[data-popover-docs-demo]")) {
    if (demo instanceof HTMLElement) {
      syncPopoverDemo(demo);
    }
  }

  // Toast triggers
  for (const button of document.querySelectorAll("[data-toast-trigger]")) {
    if (button instanceof HTMLButtonElement) {
      button.addEventListener("click", () => {
        const message = button.dataset.toastMessage || "Hello!";
        const variant = (button.dataset.toastVariant as
          | "info"
          | "success"
          | "warning"
          | "error") || "info";

        const snurbleWindow = window as unknown as {
          snurbleToast?: {
            show: (options: { message: string; variant?: string }) => void;
          };
        };

        if (snurbleWindow.snurbleToast) {
          snurbleWindow.snurbleToast.show({ message, variant });
        }
      });
    }
  }
</script>