---
import { Hero, PageShell, Panel, Section, Stack } from "@matt-riley/ui-astro";

import BaseLayout from "../layouts/BaseLayout.astro";
import { foundationLlmPage } from "../llm/pages/foundation";

const foundationCoverage = [
  {
    area: "Foundations",
    docsHref: "/",
    note: "Shared layout, grouping, data presentation, and snippet primitives for the package front door.",
    primitives: "Layout, PageShell, Hero, Section, Panel, Stack, DataTable, MetaList, CodeSnippet",
    status: "Shipped",
  },
  {
    area: "Shell primitives",
    docsHref: "/shell-primitives",
    note: "Accessibility, SEO, and font-loading helpers extracted from the reference shell.",
    primitives: "FontAssets, JsonLd, SkipLink",
    status: "Shipped",
  },
  {
    area: "Profile/social primitives",
    docsHref: "/profile-social-primitives",
    note: "Shared profile header, social link, and decorative heading patterns derived from workv2.",
    primitives: "ProfileHero, SocialLinks, DecoratedHeading",
    status: "Shipped",
  },
  {
    area: "Project primitives",
    docsHref: "/project-primitives",
    note: "Reusable project and repository display primitives with consumer-owned data shaping.",
    primitives: "ProjectCard, ProjectGrid",
    status: "Shipped",
  },
  {
    area: "Experience primitives",
    docsHref: "/experience-primitives",
    note: "Shared timeline and skill presentation primitives for experience-heavy pages.",
    primitives: "ExperienceCard, ExperienceList, SkillIcon, SkillIconList",
    status: "Shipped",
  },
  {
    area: "Adoption/migration",
    docsHref: "/mattriley-tools-migration",
    note: "Migration guidance explains how shared primitives replace local presentation without absorbing consumer-owned logic.",
    primitives: "Consumer handoff guidance",
    status: "Documented",
  },
  {
    area: "Release/publishing",
    docsHref: "/release-readiness",
    note: "Publishing guidance covers manual prerelease flow, registry installs, and release workflow expectations.",
    primitives: "Prerelease and publishing contract",
    status: "Documented",
  },
];

const extractionNotes = [
  {
    body: "workv2 remains the foundation reference: visual language, shell composition, and profile-oriented page patterns start there before they are generalized into shared packages.",
    id: "reference-source",
    title: "Reference source stays in workv2",
  },
  {
    body: "Snurble owns reusable presentation contracts and design tokens. It does not automatically absorb route data fetching, ranking, README rendering, or app-specific metadata policy.",
    id: "shared-packages",
    title: "Shared packages stay narrow",
  },
  {
    body: "mattriley.tools is the proving adopter today. Future adopters should follow the same package entrypoints and keep consumer-owned behavior local until a primitive explicitly moves into Snurble.",
    id: "adoption-proof",
    title: "Adoption proves the contract",
  },
];

const extractionStatusSummary = [
  {
    area: "Token/foundation layer",
    status: "Aligned",
    summary: "Design tokens, layout/grouping primitives, and core documentation foundations ship from Snurble today.",
  },
  {
    area: "Foundation families",
    status: "Shipped",
    summary: "Shell, profile/social, project, and experience primitive families all have dedicated shared-package coverage and docs pages.",
  },
  {
    area: "Remaining boundaries",
    status: "Relevant",
    summary: "Consumer-owned data fetching, ranking, README rendering, and app-specific metadata policy still stay outside the shared package surface.",
  },
];
---

<BaseLayout
  llm={foundationLlmPage}
  title="Snurble foundations"
  description="Repo roles, foundation coverage, and extraction status for the Snurble design system."
>
  <meta slot="head" name="theme-color" content="#11111b" />

  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <section>
        <Stack space={2}>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[var(--snurble-accent)]">
            Foundations
          </p>
          <Hero
            title="How the Snurble foundation is organized"
            variant="display"
            lede="Snurble extracts durable design-system contracts from workv2 into shared packages, then validates those contracts in mattriley.tools and future adopters. This page explains which repository owns which role, what foundation coverage already ships, and where adoption guidance lives."
          />
        </Stack>
      </section>

      <Section title="Repository roles" headingId="repo-roles-heading" variant="title">
        <div class="grid gap-6 lg:grid-cols-3">
          <article aria-labelledby="workv2-role-heading">
            <Panel variant="bordered" class="h-full">
              <Stack space={4}>
                <h3 id="workv2-role-heading" class="text-xl font-semibold">workv2/webclient</h3>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--snurble-accent)]">
                  Foundation reference
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  The original visual and structural source for the design system. Shell composition, profile presentation, project listings, experience layouts, and the Catppuccin Mocha aesthetic all originate here.
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  New shared primitives should still be checked against workv2 so the packages stay aligned with the reference foundation instead of drifting toward a single consumer&apos;s page structure.
                </p>
              </Stack>
            </Panel>
          </article>

          <article aria-labelledby="snurble-role-heading">
            <Panel variant="bordered" class="h-full">
              <Stack space={4}>
                <h3 id="snurble-role-heading" class="text-xl font-semibold">Snurble</h3>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--snurble-accent)]">
                  Shared system
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  The workspace that publishes <code>@matt-riley/design-tokens</code> and <code>@matt-riley/ui-astro</code>. Snurble turns durable patterns into reusable packages with narrow, explicit contracts.
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  Snurble owns the shared foundation, shell primitives, profile/social primitives, project primitives, experience primitives, and the docs that describe adoption and publishing expectations.
                </p>
              </Stack>
            </Panel>
          </article>

          <article aria-labelledby="mattriley-tools-role-heading">
            <Panel variant="bordered" class="h-full">
              <Stack space={4}>
                <h3 id="mattriley-tools-role-heading" class="text-xl font-semibold">mattriley.tools</h3>
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--snurble-accent)]">
                  Proving adopter
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  The first external consumer of the shared packages. It proves that the extracted primitives work outside the design-system workspace while keeping consumer-owned data and shell logic intact.
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  Adoption work here should validate the package contracts, not redefine the foundation reference. If a consumer needs new shared behavior, the reference check still starts with workv2.
                </p>
              </Stack>
            </Panel>
          </article>
        </div>
      </Section>

      <Section title="Foundation coverage" headingId="foundation-coverage-heading" variant="title">
        <Stack space={6}>
          <p class="max-w-3xl text-sm text-[var(--snurble-text-muted)]">
            The current documentation is organized around durable families instead of temporary delivery milestones. Use the coverage map below to see what already ships in shared packages and which docs explain adoption or publishing work around that surface.
          </p>

          <div class="overflow-x-auto rounded-lg border border-[var(--snurble-border)] shadow-sm">
            <table class="w-full border-collapse text-left text-sm">
              <thead class="bg-[var(--snurble-surface-card)]">
                <tr style="border-bottom: 1px solid var(--snurble-border);">
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Area</th>
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Status</th>
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Shared surface</th>
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Docs</th>
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Notes</th>
                </tr>
              </thead>
              <tbody>
                {
                  foundationCoverage.map((item, index) => (
                    <tr
                      class:list={[index < foundationCoverage.length - 1 && "border-b"]}
                      style="border-color: var(--snurble-border);"
                    >
                      <td class="px-4 py-3 font-medium">{item.area}</td>
                      <td class="px-4 py-3">
                        <span
                          class:list={[
                            "inline-flex rounded-full px-3 py-1 text-xs font-semibold",
                            item.status === "Shipped" && "bg-green-500/10 text-green-400",
                            item.status === "Documented" && "bg-blue-500/10 text-blue-300",
                          ]}
                        >
                          {item.status}
                        </span>
                      </td>
                      <td class="px-4 py-3 text-[var(--snurble-text-muted)]">
                        <code class="text-xs">{item.primitives}</code>
                      </td>
                      <td class="px-4 py-3">
                        <a class="font-medium text-[var(--snurble-accent)]" href={item.docsHref}>
                          Open docs →
                        </a>
                      </td>
                      <td class="px-4 py-3 text-[var(--snurble-text-muted)]">{item.note}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </Stack>
      </Section>

      <Section title="Extraction status" headingId="extraction-status-heading" variant="title">
        <Stack space={6}>
          <p class="max-w-3xl text-sm text-[var(--snurble-text-muted)]">
            This section is the compact source of truth for the current extraction state: the shared foundation is live, the major primitive families are shipped, and the remaining boundaries are mostly about what Snurble intentionally does not own yet.
          </p>

          <div class="overflow-x-auto rounded-lg border border-[var(--snurble-border)] shadow-sm">
            <table class="w-full border-collapse text-left text-sm">
              <thead class="bg-[var(--snurble-surface-card)]">
                <tr style="border-bottom: 1px solid var(--snurble-border);">
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Focus</th>
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Status</th>
                  <th class="px-4 py-3 font-semibold uppercase tracking-wider text-xs text-[var(--snurble-text-muted)]">Summary</th>
                </tr>
              </thead>
              <tbody>
                {
                  extractionStatusSummary.map((item, index) => (
                    <tr
                      class:list={[index < extractionStatusSummary.length - 1 && "border-b"]}
                      style="border-color: var(--snurble-border);"
                    >
                      <td class="px-4 py-3 font-medium">{item.area}</td>
                      <td class="px-4 py-3">
                        <span
                          class:list={[
                            "inline-flex rounded-full px-3 py-1 text-xs font-semibold",
                            item.status === "Aligned" && "bg-green-500/10 text-green-400",
                            item.status === "Shipped" && "bg-green-500/10 text-green-400",
                            item.status === "Relevant" && "bg-yellow-500/10 text-yellow-300",
                          ]}
                        >
                          {item.status}
                        </span>
                      </td>
                      <td class="px-4 py-3 text-[var(--snurble-text-muted)]">{item.summary}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <div class="grid gap-6 lg:grid-cols-3">
            {
              extractionNotes.map((note) => (
                <article aria-labelledby={`${note.id}-heading`}>
                  <Panel variant="bordered" class="h-full">
                    <Stack space={4}>
                      <h3 id={`${note.id}-heading`} class="text-xl font-semibold">{note.title}</h3>
                      <p class="text-sm text-[var(--snurble-text-muted)]">{note.body}</p>
                    </Stack>
                  </Panel>
                </article>
              ))
            }
          </div>
        </Stack>
      </Section>

      <Section title="Recommended reading order" headingId="reading-order-heading" variant="title">
        <Panel variant="elevated">
          <Stack space={6}>
            <h3 class="text-xl font-semibold">Move from foundations to delivery</h3>
            <ol class="grid gap-4 text-sm text-[var(--snurble-text-muted)]">
              <li>
                <Panel variant="bordered" padding={3}>
                  <Stack space={2}>
                    <span class="font-medium text-[var(--snurble-text)]">1. Foundations</span>
                    <p>Start here to understand repo roles, package scope, and the current family map.</p>
                  </Stack>
                </Panel>
              </li>
              <li>
                <Panel variant="bordered" padding={3}>
                  <Stack space={2}>
                    <span class="font-medium text-[var(--snurble-text)]">2. Primitive families</span>
                    <p>Read shell primitives, profile/social primitives, project primitives, and experience primitives to understand each shared contract in detail.</p>
                  </Stack>
                </Panel>
              </li>
              <li>
                <Panel variant="bordered" padding={3}>
                  <Stack space={2}>
                    <span class="font-medium text-[var(--snurble-text)]">3. Adoption/migration</span>
                    <p>Use the migration guide when a consumer is ready to replace local presentation code with shared packages.</p>
                  </Stack>
                </Panel>
              </li>
              <li>
                <Panel variant="bordered" padding={3}>
                  <Stack space={2}>
                    <span class="font-medium text-[var(--snurble-text)]">4. Release/publishing</span>
                    <p>Use the publishing guide for prerelease versions, registry installs, and shared release workflow expectations.</p>
                  </Stack>
                </Panel>
              </li>
            </ol>
          </Stack>
        </Panel>
      </Section>
    </PageShell>
  </main>
</BaseLayout>
