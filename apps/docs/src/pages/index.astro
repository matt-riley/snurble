---
import "../styles/global.css";
import { DataTable, Hero, Layout, PageShell, Panel, Section } from "@matt-riley/ui-astro";
import spacing from "@matt-riley/design-tokens/spacing.json";
import typography from "@matt-riley/design-tokens/typography.json";

const shortTableRows = [
  {
    surface: "Docs page",
    role: "Shows the public DataTable import and a minimal table shape.",
  },
  {
    surface: "Future consumer",
    role: "Keeps row mapping and headings app-owned while Surble owns the shared table treatment.",
  },
];

const pluginCatalogRows = [
  {
    name: "Space Sync",
    kind: "Plugin",
    install: "pnpm add @matt-riley/space-sync",
    note: "Keeps local Copilot indexes fresh after repository updates.",
  },
  {
    name: "Queue Peek",
    kind: "Tool",
    install: "pnpm add @matt-riley/queue-peek",
    note: "Summarises durable work queues without exposing repo-specific logic.",
  },
  {
    name: "Review Pulse",
    kind: "Plugin",
    install: "pnpm add @matt-riley/review-pulse",
    note: "Tracks open review work and makes handoffs visible in one place.",
  },
];

const semanticSurfaces = [
  {
    name: "Background",
    token: "--surble-background",
    note: "Application canvas and the darkest shell surfaces.",
  },
  {
    name: "Surface",
    token: "--surble-surface",
    note: "Default card and panel background for primary content.",
  },
  {
    name: "Surface strong",
    token: "--surble-surface-strong",
    note: "Raised containers and stronger visual grouping.",
  },
];

const typographyEntries = Object.entries(typography.styles);
const spacingEntries = Object.entries(spacing.scale);
---

<Layout title="Surble DataTable component" description="Stage 08 datatable showcase for the Surble design system.">
  <meta slot="head" name="theme-color" content="#11111b" />
  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <section class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[var(--surble-accent)]">
          Surble Stage 08
        </p>
        <Hero
          title="DataTable component is live."
          lede="Shared catalog tables now move overflow handling, semantic table markup, and consistent cell styling into a dedicated primitive while surrounding headings and surfaces stay consumer-owned."
        />
      </section>

      <div class="space-y-4">
        <h2 id="datatable-guidance-heading" class="text-2xl font-semibold">
          DataTable guidance
        </h2>
        <Section labelledBy="datatable-guidance-heading">
          <div class="grid gap-4 lg:grid-cols-[1.3fr,1fr]">
            <article aria-labelledby="datatable-contract-heading">
              <Panel>
                <div class="space-y-4">
                  <h3 id="datatable-contract-heading" class="text-xl font-semibold">DataTable contract</h3>
                  <p class="text-sm text-[var(--surble-text-muted)]">
                    `DataTable` stays intentionally narrow: it owns the overflow wrapper, semantic table, and shared cell
                    treatment while consumers still own headings, rows, links, and data mapping.
                  </p>
                  <ul class="grid gap-3 text-sm text-[var(--surble-text-muted)] sm:grid-cols-2">
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                      <code class="font-medium text-[var(--surble-text)]">head slot</code>
                      <p class="mt-2">The named head slot accepts the header row so column order stays app-owned.</p>
                    </li>
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                      <code class="font-medium text-[var(--surble-text)]">default slot</code>
                      <p class="mt-2">
                        Body rows stay consumer-owned, which keeps row rendering flexible without row-model props.
                      </p>
                    </li>
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                      <code class="font-medium text-[var(--surble-text)]">Accessible name</code>
                      <p class="mt-2">
                        Tables require exactly one of <code>labelledBy</code> or <code>ariaLabel</code>.
                      </p>
                    </li>
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                      <code class="font-medium text-[var(--surble-text)]">Compose with Panel</code>
                      <p class="mt-2">
                        Panel keeps surface chrome external so table semantics and surface styling do not overlap.
                      </p>
                    </li>
                  </ul>
                </div>
              </Panel>
            </article>

            <article aria-labelledby="datatable-accessibility-heading">
              <Panel>
                <div class="space-y-4">
                  <h3 id="datatable-accessibility-heading" class="text-xl font-semibold">Accessibility</h3>
                  <p class="text-sm text-[var(--surble-text-muted)]">
                    Stage 08 keeps the naming contract explicit. Use <code>labelledBy</code> when a visible heading
                    already exists nearby, or <code>ariaLabel</code> when the table needs a standalone accessible name.
                  </p>
                  <p class="text-sm text-[var(--surble-text-muted)]">
                    Header cells and row content still stay consumer-owned so apps can keep real table semantics like
                    <code>scope="col"</code>, links, install commands, and inline badges where they belong.
                  </p>
                </div>
              </Panel>
            </article>
          </div>
        </Section>
      </div>

      <Section title="Examples" headingId="datatable-examples-heading">
        <div class="grid gap-4 xl:grid-cols-2">
          <article aria-labelledby="datatable-short-heading">
            <Panel>
              <div class="space-y-4">
                <h3 id="datatable-short-heading" class="text-xl font-semibold">Short table example</h3>
                <p class="text-sm text-[var(--surble-text-muted)]">
                  This smaller example shows the narrowest supported shape: one header row plus a handful of body rows
                  mapped directly by the consumer.
                </p>
                <DataTable labelledBy="datatable-short-heading">
                  <tr slot="head">
                    <th scope="col">Surface</th>
                    <th scope="col">Why it exists</th>
                  </tr>
                  {
                    shortTableRows.map((row) => (
                      <tr>
                        <td>{row.surface}</td>
                        <td>{row.role}</td>
                      </tr>
                    ))
                  }
                </DataTable>
              </div>
            </Panel>
          </article>

          <article aria-labelledby="datatable-catalog-heading">
            <Panel>
              <div class="space-y-4">
                <h3 id="datatable-catalog-heading" class="text-xl font-semibold">Catalog-style example</h3>
                <p class="text-sm text-[var(--surble-text-muted)]">
                  The wider catalog variant keeps long install commands and multiple columns readable without baking
                  app-specific data contracts into Surble.
                </p>
                <DataTable labelledBy="datatable-catalog-heading">
                  <tr slot="head">
                    <th scope="col">Name</th>
                    <th scope="col">Kind</th>
                    <th scope="col">Install</th>
                    <th scope="col">Notes</th>
                  </tr>
                  {
                    pluginCatalogRows.map((entry) => (
                      <tr>
                        <td>{entry.name}</td>
                        <td>{entry.kind}</td>
                        <td><code>{entry.install}</code></td>
                        <td>{entry.note}</td>
                      </tr>
                    ))
                  }
                </DataTable>
                <p class="text-sm text-[var(--surble-text-muted)]">
                  Long install commands like <code>pnpm add</code> stay legible because the component owns horizontal
                  overflow instead of forcing each consumer to restyle wrappers by hand.
                </p>
              </div>
            </Panel>
          </article>
        </div>
      </Section>

      <Section title="Composition boundaries" headingId="composition-boundaries-heading">
        <div class="grid gap-4 lg:grid-cols-4">
          <article class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
            <p class="font-medium">Layout</p>
            <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
              Owns the document shell and shared token import.
            </p>
          </article>
          <article class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
            <p class="font-medium">Section</p>
            <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
              Owns section headings and higher-level grouping semantics.
            </p>
          </article>
          <article class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
            <p class="font-medium">Panel</p>
            <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
              Owns surface chrome and padding around the table examples.
            </p>
          </article>
          <article class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
            <p class="font-medium">DataTable</p>
            <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
              Owns overflow, semantic table markup, and shared row/cell treatment only.
            </p>
          </article>
        </div>
      </Section>

      <Section title="Semantic surfaces" headingId="semantic-surfaces-heading">
        <div class="grid gap-4 lg:grid-cols-3">
          {
            semanticSurfaces.map((surface) => (
              <article
                class="rounded-3xl border p-5"
                style={`background: var(${surface.token}); border-color: var(--surble-border);`}
              >
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--surble-text-muted)]">
                  {surface.name}
                </p>
                <p class="mt-3 text-sm text-[var(--surble-text-muted)]">{surface.note}</p>
                <code class="mt-4 inline-flex rounded-full bg-black/25 px-3 py-1 text-xs text-[var(--surble-text)]">
                  {surface.token}
                </code>
              </article>
            ))
          }
        </div>
      </Section>

      <Section title="Design scales" headingId="design-scales-heading">
        <div class="grid gap-4 lg:grid-cols-2">
          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(30 30 46 / 0.84); border-color: var(--surble-border);"
          >
            <h3 class="text-xl font-semibold">Typography scale</h3>
            <div class="grid gap-4">
              {
                typographyEntries.map(([name, style]) => (
                  <div class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--surble-text-muted)]">
                        {name}
                      </span>
                      <code class="text-xs text-[var(--surble-text-muted)]">{style.size}</code>
                    </div>
                    <p
                      class="mt-3"
                      style={`font-family: ${style.fontFamily}; font-size: ${style.size}; line-height: ${style.lineHeight}; font-weight: ${style.weight};`}
                    >
                      Surble carries bold night-sky contrast without losing readability.
                    </p>
                  </div>
                ))
              }
            </div>
          </article>

          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(24 24 37 / 0.92); border-color: var(--surble-border);"
          >
            <h3 class="text-xl font-semibold">Spacing scale</h3>
            <div class="grid gap-3">
              {
                spacingEntries.map(([step, value]) => (
                  <div class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                    <div class="flex items-center gap-4">
                      <code class="min-w-14 text-xs text-[var(--surble-text-muted)]">{step}</code>
                      <div
                        class="h-3 rounded-full bg-[var(--surble-accent)]"
                        style={`width: ${value}; min-width: ${value};`}
                      ></div>
                      <span class="text-sm text-[var(--surble-text-muted)]">{value}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </article>
        </div>
      </Section>
    </PageShell>
  </main>
</Layout>
