---
import "../styles/global.css";
import { Hero, Layout, PageShell, Section } from "@matt-riley/ui-astro";
import spacing from "@matt-riley/design-tokens/spacing.json";
import typography from "@matt-riley/design-tokens/typography.json";

const heroExampleSyncedAt = "2026-04-09T09:59:32.322Z";
const detailHeroExample = `<p class="eyebrow">Back to all tools</p>
<Hero
  title="Detail-style hero"
  lede="Detail pages can add supporting metadata after the lede without turning timestamps or labels into dedicated props."
>
  <p>Last synced: <time datetime="${heroExampleSyncedAt}">2026-04-09 09:59 UTC</time></p>
</Hero>`;
const semanticSurfaces = [
  {
    name: "Background",
    token: "--surble-background",
    note: "Application canvas and the darkest shell surfaces.",
  },
  {
    name: "Surface",
    token: "--surble-surface",
    note: "Default card and panel background for primary content.",
  },
  {
    name: "Surface strong",
    token: "--surble-surface-strong",
    note: "Raised containers and stronger visual grouping.",
  },
];

const typographyEntries = Object.entries(typography.styles);
const spacingEntries = Object.entries(spacing.scale);
---

<Layout title="Surble Section component" description="Stage 06 section showcase for the Surble design system.">
  <meta slot="head" name="theme-color" content="#11111b" />
  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <section class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[var(--surble-accent)]">
          Surble Stage 06
        </p>
        <Hero
          title="Section component is live."
          lede="Shared content regions now get a narrow Section primitive: either a built-in h2 or explicit external heading association, with Surble spacing but no panel-style chrome."
        />
      </section>

      <div class="space-y-4">
        <h2 id="hero-guidance-heading" class="text-2xl font-semibold">
          Hero guidance
        </h2>
        <Section labelledBy="hero-guidance-heading">
          <div class="grid gap-4 lg:grid-cols-[1.3fr,1fr]">
            <article
              class="space-y-4 rounded-3xl border p-6 shadow-2xl shadow-black/20"
              style="background: rgb(17 17 27 / 0.72); border-color: var(--surble-border);"
            >
              <h3 class="text-xl font-semibold">Section contract</h3>
              <p class="text-sm text-[var(--surble-text-muted)]">
                `Section` stays intentionally narrow: a named content region with shared outer spacing and either an
                internal heading or explicit external heading association.
              </p>
              <ul class="grid gap-3 text-sm text-[var(--surble-text-muted)] sm:grid-cols-2">
                <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                  <code class="font-medium text-[var(--surble-text)]">title</code>
                  <p class="mt-2">Renders the shared <code>h2</code> inside the component.</p>
                </li>
                <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                  <code class="font-medium text-[var(--surble-text)]">labelledBy</code>
                  <p class="mt-2">Associates the region with a consumer-owned heading without duplicating it.</p>
                </li>
                <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                  <code class="font-medium text-[var(--surble-text)]">Spacing only</code>
                  <p class="mt-2">The component coordinates structure and rhythm, not panel chrome or card padding.</p>
                </li>
                <li class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                  <code class="font-medium text-[var(--surble-text)]">Real regions</code>
                  <p class="mt-2">Docs use Section for actual grouped content instead of standalone demo wrappers.</p>
                </li>
              </ul>
            </article>

            <article
              class="space-y-4 rounded-3xl border p-6"
              style="background: rgb(30 30 46 / 0.88); border-color: var(--surble-border);"
            >
              <h3 class="text-xl font-semibold">Composition boundaries</h3>
              <div class="grid gap-3">
                <div class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
                  <p class="font-medium">Layout</p>
                  <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
                    Owns the HTML document shell, shared head defaults, and the baseline token import.
                  </p>
                </div>
                <div class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
                  <p class="font-medium">main.docs-shell + PageShell</p>
                  <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
                    Keep the docs backdrop, page semantics, and outer width/padding contract outside the shared section
                    API.
                  </p>
                </div>
                <div class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
                  <p class="font-medium">Section</p>
                  <p class="mt-2 text-sm text-[var(--surble-text-muted)]">
                    Owns named-region structure and spacing only, leaving surface treatment to later components.
                  </p>
                </div>
              </div>
            </article>
          </div>
        </Section>
      </div>

      <Section title="Detail-style hero usage" headingId="detail-hero-usage-heading">
        <div class="grid gap-4 lg:grid-cols-[1.15fr,0.85fr]">
          <article
            class="space-y-4 rounded-3xl border p-6 shadow-2xl shadow-black/20"
            style="background: rgb(17 17 27 / 0.72); border-color: var(--surble-border);"
          >
            <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[var(--surble-accent)]">
              Eyebrow stays outside Hero
            </p>
            <h3 class="text-xl font-semibold">Detail-style usage</h3>
            <p class="text-sm text-[var(--surble-text-muted)]">
              Detail pages keep the eyebrow or back link outside Hero, then pass supporting content through the default
              slot instead of relying on metadata-specific props.
            </p>
            <pre
              class="overflow-x-auto rounded-2xl border bg-black/25 p-4 text-sm text-[var(--surble-text)]"
              style="border-color: var(--surble-border);"
            ><code>{detailHeroExample}</code></pre>
          </article>

          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(30 30 46 / 0.88); border-color: var(--surble-border);"
          >
            <h3 class="text-xl font-semibold">Why the slot stays generic</h3>
            <p class="text-sm text-[var(--surble-text-muted)]">
              The shared slot covers supporting content already proven by the references, but it avoids baking
              timestamps, badges, or metadata rows into the public API before a second real variation appears.
            </p>
          </article>
        </div>
      </Section>

      <Section title="Semantic surfaces" headingId="semantic-surfaces-heading">
        <div class="grid gap-4 lg:grid-cols-3">
          {
            semanticSurfaces.map((surface) => (
              <article
                class="rounded-3xl border p-5"
                style={`background: var(${surface.token}); border-color: var(--surble-border);`}
              >
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--surble-text-muted)]">
                  {surface.name}
                </p>
                <p class="mt-3 text-sm text-[var(--surble-text-muted)]">{surface.note}</p>
                <code class="mt-4 inline-flex rounded-full bg-black/25 px-3 py-1 text-xs text-[var(--surble-text)]">
                  {surface.token}
                </code>
              </article>
            ))
          }
        </div>
      </Section>

      <Section title="Design scales" headingId="design-scales-heading">
        <div class="grid gap-4 lg:grid-cols-2">
          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(30 30 46 / 0.84); border-color: var(--surble-border);"
          >
            <h3 class="text-xl font-semibold">Typography scale</h3>
            <div class="grid gap-4">
              {
                typographyEntries.map(([name, style]) => (
                  <div class="rounded-2xl border p-4" style="border-color: var(--surble-border);">
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--surble-text-muted)]">
                        {name}
                      </span>
                      <code class="text-xs text-[var(--surble-text-muted)]">{style.size}</code>
                    </div>
                    <p
                      class="mt-3"
                      style={`font-family: ${style.fontFamily}; font-size: ${style.size}; line-height: ${style.lineHeight}; font-weight: ${style.weight};`}
                    >
                      Surble carries bold night-sky contrast without losing readability.
                    </p>
                  </div>
                ))
              }
            </div>
          </article>

          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(24 24 37 / 0.92); border-color: var(--surble-border);"
          >
            <h3 class="text-xl font-semibold">Spacing scale</h3>
            <div class="grid gap-3">
              {
                spacingEntries.map(([step, value]) => (
                  <div class="rounded-2xl border px-4 py-3" style="border-color: var(--surble-border);">
                    <div class="flex items-center gap-4">
                      <code class="min-w-14 text-xs text-[var(--surble-text-muted)]">{step}</code>
                      <div
                        class="h-3 rounded-full bg-[var(--surble-accent)]"
                        style={`width: ${value}; min-width: ${value};`}
                      ></div>
                      <span class="text-sm text-[var(--surble-text-muted)]">{value}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </article>
        </div>
      </Section>

      <Section title="Focus treatment" headingId="focus-treatment-heading">
        <p class="max-w-2xl text-sm text-[var(--surble-text-muted)]">
          The shared token entrypoint exports a generic focus-visible rule so interactive elements stay legible without
          bringing docs-only helper classes along for the ride.
        </p>
        <div class="flex flex-wrap gap-4">
          <button
            type="button"
            class="rounded-full border px-5 py-3 font-medium"
            style="border-color: var(--surble-border-strong); background: var(--surble-surface-strong);"
          >
            Tab to focus me
          </button>
          <a
            href="#focus-note"
            class="inline-flex items-center rounded-full border px-5 py-3 font-medium"
            style="border-color: var(--surble-border-strong); background: var(--surble-surface);"
          >
            Then focus this link
          </a>
        </div>
        <p id="focus-note" class="text-sm text-[var(--surble-text-muted)]">
          The green ring comes from <code class="text-[var(--surble-text)]">--surble-focus-ring</code>.
        </p>
      </Section>
    </PageShell>
  </main>
</Layout>
