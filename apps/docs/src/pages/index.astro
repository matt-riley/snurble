---
import { Hero, PageShell, Panel, Section, Stack, StatCard } from "@matt-riley/ui-astro";

import { componentDocs } from "../component-docs/registry";
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeLlmPage } from "../llm/pages/home";
---

<BaseLayout
  llm={homeLlmPage}
  title="Snurble design system"
  description="Component-first reference docs for the Snurble design system."
>
  <meta slot="head" name="theme-color" content="#11111b" />

  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <Stack space={3}>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[var(--snurble-accent)]">
          Snurble design system
        </p>
        <Hero
          title="A component-first reference for @matt-riley/ui-astro"
          lede="Browse every shared Astro primitive on its own page, plus the LLM helper API and the release guides that support package adoption."
        />
      </Stack>

      <div class="grid gap-4 lg:grid-cols-3">
        <StatCard label="Documented components" value={componentDocs.length} />
        <StatCard label="Docs mode" value="Dynamic" trend="neutral" trendValue="catalog-driven" />
        <StatCard label="LLM surface" value="Enabled" trend="up" trendValue="markdown twins" />
      </div>

      <Section title="Start here" headingId="start-here-heading">
        <div class="grid gap-4 lg:grid-cols-3">
          <Panel variant="elevated">
            <Stack space={3}>
              <h3 class="text-xl font-semibold">Components</h3>
              <p class="text-sm text-[var(--snurble-text-muted)]">
                Visit the component index for dedicated docs pages covering every shared Astro primitive.
              </p>
              <a class="font-medium text-[var(--snurble-accent)]" href="/components">Open component index →</a>
            </Stack>
          </Panel>

          <Panel variant="elevated">
            <Stack space={3}>
              <h3 class="text-xl font-semibold">LLM helper API</h3>
              <p class="text-sm text-[var(--snurble-text-muted)]">
                Reference the markdown alternate helper used by the docs site and other machine-readable surfaces.
              </p>
              <a class="font-medium text-[var(--snurble-accent)]" href="/llm-helper">Open helper docs →</a>
            </Stack>
          </Panel>

          <Panel variant="elevated">
            <Stack space={3}>
              <h3 class="text-xl font-semibold">Release guidance</h3>
              <p class="text-sm text-[var(--snurble-text-muted)]">
                Keep publishing and consumer adoption aligned with the current package contract.
              </p>
              <a class="font-medium text-[var(--snurble-accent)]" href="/release-readiness">Open release guide →</a>
            </Stack>
          </Panel>
        </div>
      </Section>
    </PageShell>
  </main>
</BaseLayout>
