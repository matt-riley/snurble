---
import "../styles/global.css";
import { CodeSnippet, Hero, Layout, PageShell, Panel, Section } from "@matt-riley/ui-astro";
import spacing from "@matt-riley/design-tokens/spacing.json";
import typography from "@matt-riley/design-tokens/typography.json";

const semanticSurfaces = [
  {
    name: "Background",
    token: "--snurble-background",
    note: "Application canvas and the darkest shell surfaces.",
  },
  {
    name: "Surface",
    token: "--snurble-surface",
    note: "Default card and panel background for primary content.",
  },
  {
    name: "Surface strong",
    token: "--snurble-surface-strong",
    note: "Raised containers and stronger visual grouping.",
  },
];

const typographyEntries = Object.entries(typography.styles);
const spacingEntries = Object.entries(spacing.scale);
---

<Layout
  title="Snurble CodeSnippet component"
  description="Stage 10 code snippet showcase for the Snurble design system."
>
  <meta slot="head" name="theme-color" content="#11111b" />
  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <section class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[var(--snurble-accent)]">
          Snurble Stage 10
        </p>
        <Hero
          title="CodeSnippet component is live."
          lede="Shared install commands and longer code snippets now land in one narrow Astro primitive with explicit inline and block variants."
        />
      </section>

      <div class="space-y-4">
        <h2 id="codesnippet-guidance-heading" class="text-2xl font-semibold">
          CodeSnippet guidance
        </h2>
        <Section labelledBy="codesnippet-guidance-heading">
          <div class="grid gap-4 lg:grid-cols-[1.3fr,1fr]">
            <article aria-labelledby="codesnippet-contract-heading">
              <Panel>
                <div class="space-y-4">
                  <h3 id="codesnippet-contract-heading" class="text-xl font-semibold">CodeSnippet contract</h3>
                  <p class="text-sm text-[var(--snurble-text-muted)]">
                    <code>CodeSnippet</code> keeps Stage 10 intentionally narrow: a required <code>variant</code> plus
                    a required <code>code</code> string, with no slot API or styling escape hatches in v1.
                  </p>
                  <ul class="grid gap-3 text-sm text-[var(--snurble-text-muted)] sm:grid-cols-2">
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--snurble-border);">
                      <code class="font-medium text-[var(--snurble-text)]">explicit variant</code>
                      <p class="mt-2">Consumers choose inline or block rendering directly instead of relying on inference.</p>
                    </li>
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--snurble-border);">
                      <code class="font-medium text-[var(--snurble-text)]">string content</code>
                      <p class="mt-2">Validation checks for a non-empty string without rewriting the authored snippet.</p>
                    </li>
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--snurble-border);">
                      <code class="font-medium text-[var(--snurble-text)]">owned styling</code>
                      <p class="mt-2">The component provides the pill and block chrome instead of delegating styling to the page.</p>
                    </li>
                    <li class="rounded-2xl border px-4 py-3" style="border-color: var(--snurble-border);">
                      <code class="font-medium text-[var(--snurble-text)]">v1 scope</code>
                      <p class="mt-2">Stage 10 ships without syntax highlighting, copy controls, or language badges.</p>
                    </li>
                  </ul>
                </div>
              </Panel>
            </article>

            <article aria-labelledby="codesnippet-semantics-heading">
              <Panel>
                <div class="space-y-4">
                  <h3 id="codesnippet-semantics-heading" class="text-xl font-semibold">
                    Rendering semantics
                  </h3>
                  <p class="text-sm text-[var(--snurble-text-muted)]">
                    Inline snippets stay in sentence flow as a styled <code>code</code> element, while block snippets
                    render as <code>pre</code> + <code>code</code> for preserved multiline content and horizontal overflow.
                  </p>
                  <p class="text-sm text-[var(--snurble-text-muted)]">
                    Whitespace is preserved for authored block snippets, so install commands and configuration examples
                    keep their intended indentation without widening the API.
                  </p>
                </div>
              </Panel>
            </article>
          </div>
        </Section>
      </div>

      <Section title="Examples" headingId="codesnippet-examples-heading">
        <div class="grid gap-4 xl:grid-cols-2">
          <article aria-labelledby="codesnippet-inline-heading">
            <Panel>
              <div class="space-y-4">
                <h3 id="codesnippet-inline-heading" class="text-xl font-semibold">Inline code example</h3>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  The inline variant is tuned for install commands and short snippets that need stronger visual emphasis
                  without breaking sentence flow.
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  Install the package with <CodeSnippet variant="inline" code="pnpm add @matt-riley/ui-astro" /> and
                  keep the surrounding prose readable.
                </p>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  Inline snippets keep the authored string intact while the component owns the shared pill treatment.
                </p>
              </div>
            </Panel>
          </article>

          <article aria-labelledby="codesnippet-block-heading">
            <Panel>
              <div class="space-y-4">
                <h3 id="codesnippet-block-heading" class="text-xl font-semibold">Block code example</h3>
                <p class="text-sm text-[var(--snurble-text-muted)]">
                  The block variant handles longer snippets and preserves multiline formatting, indentation, and overflow
                  within the component boundary.
                </p>
                <CodeSnippet variant="block" code={`pnpm add @matt-riley/ui-astro --filter ./apps/docs --workspace-root --save-exact --reporter append-only
pnpm dlx astro sync --root ./apps/docs --config ./apps/docs/astro.config.mjs

import { CodeSnippet } from "@matt-riley/ui-astro"`}
                />
              </div>
            </Panel>
          </article>
        </div>
      </Section>

      <Section title="Composition boundaries" headingId="composition-boundaries-heading">
        <div class="grid gap-4 lg:grid-cols-4">
          <article class="rounded-2xl border p-4" style="border-color: var(--snurble-border);">
            <p class="font-medium">Layout</p>
            <p class="mt-2 text-sm text-[var(--snurble-text-muted)]">
              Owns the document shell and shared token import.
            </p>
          </article>
          <article class="rounded-2xl border p-4" style="border-color: var(--snurble-border);">
            <p class="font-medium">Section</p>
            <p class="mt-2 text-sm text-[var(--snurble-text-muted)]">
              Owns section headings and higher-level grouping semantics.
            </p>
          </article>
          <article class="rounded-2xl border p-4" style="border-color: var(--snurble-border);">
            <p class="font-medium">Panel</p>
            <p class="mt-2 text-sm text-[var(--snurble-text-muted)]">
              Owns surface chrome and padding around the showcase examples.
            </p>
          </article>
          <article class="rounded-2xl border p-4" style="border-color: var(--snurble-border);">
            <p class="font-medium">CodeSnippet</p>
            <p class="mt-2 text-sm text-[var(--snurble-text-muted)]">
              Owns the inline and block snippet markup, validation, and shared code styling contract.
            </p>
          </article>
        </div>
      </Section>

      <Section title="Semantic surfaces" headingId="semantic-surfaces-heading">
        <div class="grid gap-4 lg:grid-cols-3">
          {
            semanticSurfaces.map((surface) => (
              <article
                class="rounded-3xl border p-5"
                style={`background: var(${surface.token}); border-color: var(--snurble-border);`}
              >
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--snurble-text-muted)]">
                  {surface.name}
                </p>
                <p class="mt-3 text-sm text-[var(--snurble-text-muted)]">{surface.note}</p>
                <code class="mt-4 inline-flex rounded-full bg-black/25 px-3 py-1 text-xs text-[var(--snurble-text)]">
                  {surface.token}
                </code>
              </article>
            ))
          }
        </div>
      </Section>

      <Section title="Design scales" headingId="design-scales-heading">
        <div class="grid gap-4 lg:grid-cols-2">
          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(30 30 46 / 0.84); border-color: var(--snurble-border);"
          >
            <h3 class="text-xl font-semibold">Typography scale</h3>
            <div class="grid gap-4">
              {
                typographyEntries.map(([name, style]) => (
                  <div class="rounded-2xl border p-4" style="border-color: var(--snurble-border);">
                    <div class="flex items-center justify-between gap-3">
                      <span class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--snurble-text-muted)]">
                        {name}
                      </span>
                      <code class="text-xs text-[var(--snurble-text-muted)]">{style.size}</code>
                    </div>
                    <p
                      class="mt-3"
                      style={`font-family: ${style.fontFamily}; font-size: ${style.size}; line-height: ${style.lineHeight}; font-weight: ${style.weight};`}
                    >
                      Snurble carries bold night-sky contrast without losing readability.
                    </p>
                  </div>
                ))
              }
            </div>
          </article>

          <article
            class="space-y-4 rounded-3xl border p-6"
            style="background: rgb(24 24 37 / 0.92); border-color: var(--snurble-border);"
          >
            <h3 class="text-xl font-semibold">Spacing scale</h3>
            <div class="grid gap-3">
              {
                spacingEntries.map(([step, value]) => (
                  <div class="rounded-2xl border px-4 py-3" style="border-color: var(--snurble-border);">
                    <div class="flex items-center gap-4">
                      <code class="min-w-14 text-xs text-[var(--snurble-text-muted)]">{step}</code>
                      <div
                        class="h-3 rounded-full bg-[var(--snurble-accent)]"
                        style={`width: ${value}; min-width: ${value};`}
                      ></div>
                      <span class="text-sm text-[var(--snurble-text-muted)]">{value}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </article>
        </div>
      </Section>
    </PageShell>
  </main>
</Layout>
