---
import "../styles/global.css";
import {
  CodeSnippet,
  DecoratedHeading,
  Hero,
  Layout,
  PageShell,
  Panel,
  ProfileHero,
  Section,
  SocialLinks,
  Stack,
} from "@matt-riley/ui-astro";

const profileLinks = [
  { href: "https://github.com/matt-riley", icon: "GitHub", label: "GitHub profile" },
  { href: "https://linkedin.com/in/matthewjriley", icon: "LinkedIn", label: "LinkedIn profile" },
  { href: "https://bsky.app/profile/mattriley.dev", icon: "Bluesky", label: "Bluesky profile" },
];
---

<Layout
  title="Profile & Social Primitives - Snurble"
  description="ProfileHero, SocialLinks, and DecoratedHeading primitives for profile headers, social navigation, and decorative headings"
>
  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <Hero
        title="Profile & Social Primitives"
        lede="Profile-building primitives for avatar headers, social link groups, and decorative section headings"
      />

      <Section title="Overview" headingId="overview-heading">
        <Stack>
          <Panel>
            <p>
              These primitives cover the most common profile-page building blocks: a centered hero,
              a social link cluster, and a decorative heading treatment. They stay focused on
              rendering while leaving content strategy, icon sourcing, and section structure to the
              consumer.
            </p>
          </Panel>
        </Stack>
      </Section>

      <Section title="ProfileHero" headingId="profile-hero-heading">
        <Stack>
          <p>
            <code>ProfileHero</code> renders a centered avatar, name, and subtitle for a person or
            creator profile page.
          </p>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Contract</h3>
              <CodeSnippet
                variant="block"
                code={`interface Props {
  name: string;
  subtitle: string;
  avatarSrc: string;
  avatarAlt: string;
}`}
              />
            </Stack>
          </Panel>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Example usage</h3>
              <CodeSnippet
                variant="block"
                code={`<ProfileHero
  name="Matt Riley"
  subtitle="Senior Software Engineer in Leeds, West Yorkshire"
  avatarSrc="https://github.com/matt-riley.png"
  avatarAlt="Matt Riley's GitHub avatar"
/>`}
              />
            </Stack>
          </Panel>

          <Panel>
            <h3 class="text-xl font-semibold">Live example</h3>
            <ProfileHero
              name="Matt Riley"
              subtitle="Senior Software Engineer in Leeds, West Yorkshire"
              avatarSrc="https://github.com/matt-riley.png"
              avatarAlt="Matt Riley's GitHub avatar"
            />
          </Panel>
        </Stack>
      </Section>

      <Section title="SocialLinks" headingId="social-links-heading">
        <Stack>
          <p>
            <code>SocialLinks</code> renders a navigation landmark containing external profile links
            with hover and focus affordances.
          </p>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Contract</h3>
              <CodeSnippet
                variant="block"
                code={`interface Props {
  links: Array<{
    href: string;
    icon: string;
    label: string;
  }>;
}`}
              />
            </Stack>
          </Panel>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Example usage</h3>
              <CodeSnippet
                variant="block"
                code={`const links = [
  { href: "https://github.com/matt-riley", icon: "GitHub", label: "GitHub profile" },
  { href: "https://linkedin.com/in/matthewjriley", icon: "LinkedIn", label: "LinkedIn profile" },
  { href: "https://bsky.app/profile/mattriley.dev", icon: "Bluesky", label: "Bluesky profile" },
];

<SocialLinks links={links} />`}
              />
            </Stack>
          </Panel>

          <Panel>
            <h3 class="text-xl font-semibold">Live example</h3>
            <SocialLinks links={profileLinks} />
          </Panel>
        </Stack>
      </Section>

      <Section title="DecoratedHeading" headingId="decorated-heading-heading">
        <Stack>
          <p>
            <code>DecoratedHeading</code> renders stylized SVG text for section labels and other
            decorative headings.
          </p>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Contract</h3>
              <CodeSnippet
                variant="block"
                code={`interface Props {
  text: string;
}`}
              />
            </Stack>
          </Panel>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Example usage</h3>
              <CodeSnippet
                variant="block"
                code={`<DecoratedHeading text="Projects" />
<DecoratedHeading text="Experience" />`}
              />
            </Stack>
          </Panel>

          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Live examples</h3>
              <div class="flex flex-col gap-4">
                <DecoratedHeading text="Projects" />
                <DecoratedHeading text="Experience" />
                <DecoratedHeading text="About Me" />
              </div>
            </Stack>
          </Panel>
        </Stack>
      </Section>

      <Section title="Composition Example" headingId="composition-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="text-xl font-semibold">Putting the primitives together</h3>
              <CodeSnippet
                variant="block"
                code={`<ProfileHero
  name="Matt Riley"
  subtitle="Senior Software Engineer in Leeds, West Yorkshire"
  avatarSrc="https://github.com/matt-riley.png"
  avatarAlt="Matt Riley's GitHub avatar"
/>

<SocialLinks links={profileLinks} />

<h2 id="projects-heading" class="sr-only">Projects</h2>
<Section labelledBy="projects-heading">
  <DecoratedHeading text="Projects" />
  <!-- Project content here -->
</Section>`}
              />
            </Stack>
          </Panel>
        </Stack>
      </Section>

      <Section title="Consumer Responsibilities" headingId="consumer-heading">
        <Stack>
          <Panel>
            <h3 class="text-xl font-semibold mb-3">Accessibility</h3>
            <ul class="list-disc list-inside space-y-2">
              <li>Provide meaningful <code>avatarAlt</code> text for the profile image.</li>
              <li>Set each social <code>label</code> so the navigation remains understandable without the visual icon text.</li>
              <li>Pair <code>DecoratedHeading</code> with a semantic heading when the text labels a section.</li>
            </ul>
          </Panel>

          <Panel>
            <h3 class="text-xl font-semibold mb-3">Rendering boundaries</h3>
            <p class="mb-3">
              <code>SocialLinks</code> passes each <code>href</code> straight through to the rendered
              <code>&lt;a href&gt;</code> with no package-level URL validation. Supply vetted external
              URLs, ideally <code>https://</code>, or wrap the primitive with your own validation
              before rendering.
            </p>
            <p>
              The primitive also renders the <code>icon</code> string as visible text inside an
              <code>aria-hidden</code> wrapper. The accessible name comes from <code>label</code>, not
              the icon value. If you need SVG or component-based icons, compose a wrapper around the
              same link data contract rather than treating this primitive as a raw HTML injection
              point.
            </p>
          </Panel>
        </Stack>
      </Section>
    </PageShell>
  </main>
</Layout>
