---
import "../styles/global.css";
import {
  CodeSnippet,
  Hero,
  Layout,
  PageShell,
  Panel,
  ProjectCard,
  ProjectGrid,
  Section,
  Stack,
} from "@matt-riley/ui-astro";

const sampleProjects = [
  {
    description: "Shared Astro design system primitives and design tokens for portfolio-style sites.",
    languages: [
      { color: "#3178c6", name: "TypeScript" },
      { color: "#ff5d01", name: "Astro" },
    ],
    name: "snurble",
    stars: 12,
    topics: ["design-system", "astro", "catppuccin"],
    url: "https://github.com/matt-riley/snurble",
  },
  {
    description: "Personal site source that consumes shared cards to present projects and writing.",
    languages: [
      { color: "#3178c6", name: "TypeScript" },
      { color: "#f7df1e", name: "JavaScript" },
    ],
    name: "portfolio-site",
    stars: 8,
    topics: ["portfolio", "astro", "homepage"],
    url: "https://github.com/example/portfolio-site",
  },
  {
    description: "CLI automation workspace with optional metadata omitted when it is not available.",
    languages: [{ color: "#3178c6", name: "TypeScript" }],
    name: "copilot-cli-tools",
    topics: ["copilot", "cli", "automation"],
    url: "https://github.com/example/copilot-cli-tools",
  },
  {
    description: "A minimal example showing the required ProjectCard props only.",
    name: "example-project",
    url: "https://github.com/example/project",
  },
];
---

<Layout
  title="Project Primitives - Snurble"
  description="ProjectCard and ProjectGrid primitives for project and repository summaries"
>
  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <Hero
        title="Project Primitives"
        lede="Presentation primitives for repository summaries, project metadata, and responsive project grids"
      />

      <Section title="Overview" headingId="overview-heading">
        <Stack>
          <Panel>
            <p>
              <code>ProjectCard</code> and <code>ProjectGrid</code> render project summaries without
              taking over your data pipeline. Use them when you already know which projects to show
              and need a stable display contract for cards, badges, and grid layout.
            </p>
          </Panel>
          <Panel>
            <ul class="list-disc list-inside space-y-2">
              <li><code>ProjectCard</code> renders the card, link, optional stars, languages, and topics.</li>
              <li><code>ProjectGrid</code> provides the semantic list and responsive grid wrapper.</li>
              <li>Fetching, ranking, filtering, and limiting metadata remain consumer responsibilities.</li>
            </ul>
          </Panel>
        </Stack>
      </Section>

      <Section title="Contracts" headingId="contracts-heading">
        <Stack>
          <Panel>
            <h3 class="text-xl font-semibold mb-3">ProjectCard props</h3>
            <ul class="list-disc list-inside space-y-1">
              <li><code>name: string</code> — rendered as the card heading and linked title</li>
              <li><code>description: string</code> — rendered as plain text and line-clamped to two lines</li>
              <li><code>url: string</code> — validated before use in <code>href</code></li>
              <li><code>stars?: number</code> — shown only when greater than zero</li>
              <li><code>languages?</code> — optional badge entries with a language name and optional color</li>
              <li><code>topics?: string[]</code> — optional tags rendered with a <code>#</code> prefix</li>
            </ul>
          </Panel>

          <Panel>
            <h3 class="text-xl font-semibold mb-3">ProjectGrid contract</h3>
            <p class="mb-3">
              <code>ProjectGrid</code> takes no props. It renders a semantic unordered list and
              expects list items in the default slot.
            </p>
            <p>
              The layout starts as a single column and switches to two columns at wider breakpoints.
            </p>
          </Panel>
        </Stack>
      </Section>

      <Section title="Example Usage" headingId="examples-heading">
        <Stack>
          <Panel>
            <h3 class="text-xl font-semibold mb-4">Mapping project data into the grid</h3>
            <CodeSnippet
              variant="block"
              code={`<ProjectGrid>
  {projects.map((project) => (
    <li class="w-full">
      <ProjectCard
        name={project.name}
        description={project.description}
        url={project.url}
        stars={project.stars}
        languages={project.languages}
        topics={project.topics}
      />
    </li>
  ))}
</ProjectGrid>`}
            />
          </Panel>

          <article aria-labelledby="grid-example-heading">
            <h3 id="grid-example-heading" class="text-xl font-semibold mb-4">Live grid example</h3>
            <Panel>
              <ProjectGrid>
                {sampleProjects.map((project) => (
                  <li class="w-full">
                    <ProjectCard
                      name={project.name}
                      description={project.description}
                      url={project.url}
                      stars={project.stars}
                      languages={project.languages}
                      topics={project.topics}
                    />
                  </li>
                ))}
              </ProjectGrid>
            </Panel>
          </article>
        </Stack>
      </Section>

      <Section title="Consumer Responsibilities" headingId="consumer-heading">
        <Stack>
          <Panel>
            <h3 class="text-xl font-semibold mb-3">Data and state</h3>
            <ul class="list-disc list-inside space-y-2">
              <li>Fetch project data from your API, content collection, or Git provider.</li>
              <li>Decide ranking, filtering, grouping, and fallback behavior outside the primitives.</li>
              <li>Limit topics and languages before rendering if your product needs a tighter display budget.</li>
              <li>Handle loading, empty, and error states around the grid.</li>
            </ul>
          </Panel>

          <Panel>
            <h3 class="text-xl font-semibold mb-3">Link behavior and accessibility</h3>
            <p class="mb-3">
              The card title opens in a new tab with <code>rel="noopener noreferrer"</code>. Use a
              descriptive <code>name</code> so the heading and link text remain meaningful in screen
              readers, browser tabs, and copied link lists.
            </p>
            <p>
              Keep <code>ProjectGrid</code> children wrapped in <code>&lt;li&gt;</code> elements so
              the list structure stays semantic.
            </p>
          </Panel>
        </Stack>
      </Section>

      <Section title="Security" headingId="security-heading">
        <Stack>
          <Panel>
            <h3 class="text-xl font-semibold mb-3">URL validation</h3>
            <p class="mb-3">
              <code>ProjectCard</code> validates project URLs before rendering them into
              <code>href</code>. Safe values include:
            </p>
            <ul class="list-disc list-inside space-y-1 mb-3">
              <li>HTTP and HTTPS URLs such as <code>https://example.com</code></li>
              <li>Explicit relative URLs such as <code>/projects/snurble</code>, <code>./page</code>, and <code>../page</code></li>
            </ul>
            <p class="mb-3">
              Dangerous or malformed URLs, including <code>javascript:</code>, <code>data:</code>,
              <code>vbscript:</code>, protocol-relative URLs, and obfuscated schemes with leading
              whitespace or control characters, are replaced with <code>#</code>.
            </p>
            <p>
              Consumers should still validate upstream data and prefer fully qualified external URLs.
            </p>
          </Panel>

          <Panel>
            <h3 class="text-xl font-semibold mb-3">Color validation</h3>
            <p class="mb-3">
              Language colors are validated before they are written into inline styles. Accepted
              formats include:
            </p>
            <ul class="list-disc list-inside space-y-1 mb-3">
              <li>Hex colors: <code>#RGB</code>, <code>#RRGGBB</code>, <code>#RRGGBBAA</code></li>
              <li>RGB and RGBA functions</li>
              <li>HSL and HSLA functions</li>
              <li>A limited set of common named colors</li>
            </ul>
            <p>
              Invalid or suspicious strings are ignored so the badge still renders without unsafe
              styling. Choose colors upstream when they add meaning; omit them when they do not.
            </p>
          </Panel>
        </Stack>
      </Section>
    </PageShell>
  </main>
</Layout>

<style>
  .docs-shell {
    min-height: 100vh;
  }
</style>
