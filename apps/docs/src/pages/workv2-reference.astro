---
import "../styles/global.css";
import {
  CodeSnippet,
  DecoratedHeading,
  ExperienceCard,
  Hero,
  Layout,
  PageShell,
  Panel,
  ProfileHero,
  ProjectCard,
  Section,
  SocialLinks,
  Stack,
} from "@matt-riley/ui-astro";

const profileLinks = [
  { href: "https://github.com/matt-riley", icon: "GitHub", label: "GitHub profile" },
  { href: "https://linkedin.com/in/matthewjriley", icon: "LinkedIn", label: "LinkedIn profile" },
];
---

<Layout
  title="WorkV2 Reference — Snurble"
  description="Visual regression baseline for WorkV2 alignment. Each component is shown alongside its WorkV2 source criteria."
>
  <main class="docs-shell min-h-screen">
    <PageShell class="flex flex-col gap-10">
      <Hero
        title="WorkV2 Reference"
        lede="Visual baseline for WorkV2 alignment. Each component is rendered live with the acceptance criteria derived from the WorkV2 webclient source of truth."
      />

      <Section title="About this page" headingId="about-heading">
        <Stack>
          <Panel>
            <Stack>
              <p>
                Snurble's design system derives its color system, typography, and component
                patterns from the <strong>WorkV2 webclient</strong> (<code
                  >mattriley.work</code
                >). This page renders every aligned component at a glance alongside
                its WorkV2 acceptance criteria. Use it to spot regressions after token
                or component changes.
              </p>
              <p>
                WorkV2 uses <strong>Catppuccin Mocha</strong> as its palette, routed
                through Tailwind utilities. Snurble re-exposes that palette via
                <code>--snurble-palette-*</code> tokens and maps them to semantic roles
                in <code>packages/tokens/src/semantic.css</code>.
              </p>
            </Stack>
          </Panel>
        </Stack>
      </Section>

      <Section title="Color token alignment" headingId="color-tokens-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">Acceptance criteria</h3>
              <ul class="ref-list">
                <li>
                  <strong>Peach (#fab387)</strong> — brand names and <code>h1</code> text
                  (<code>--snurble-brand-primary</code>)
                </li>
                <li>
                  <strong>Mauve (#cba6f7)</strong> — card titles and section headings
                  (<code>--snurble-brand-heading</code>)
                </li>
                <li>
                  <strong>Green (#a6e3a1)</strong> — avatar ring, focus outlines, success
                  (<code>--snurble-accent-success</code>)
                </li>
                <li>
                  <strong>Red (#f38ba8)</strong> — SVG decorative fill, danger
                  (<code>--snurble-accent-danger</code>)
                </li>
                <li>
                  <strong>Surface1 (#45475a)</strong> — card backgrounds
                  (<code>--snurble-surface-card</code>)
                </li>
                <li>
                  <strong>Surface2 (#585b70)</strong> — badge backgrounds, card borders
                  (<code>--snurble-surface-badge</code>, <code>--snurble-border-card</code
                  >)
                </li>
                <li>
                  <strong>Subtext0 (#a6adc8)</strong> — secondary / muted text
                  (<code>--snurble-text-muted</code>)
                </li>
                <li>
                  <strong>Overlay1 (#7f849c)</strong> — tertiary text
                  (<code>--snurble-text-tertiary</code>)
                </li>
              </ul>
            </Stack>
          </Panel>

          <Panel>
            <Stack>
              <h3 class="ref-heading">Live swatches</h3>
              <div class="swatch-grid">
                <div class="swatch" style="background: var(--snurble-brand-primary);">
                  <span>brand-primary</span>
                </div>
                <div class="swatch" style="background: var(--snurble-brand-heading);">
                  <span>brand-heading</span>
                </div>
                <div
                  class="swatch"
                  style="background: var(--snurble-accent-success);"
                >
                  <span>accent-success</span>
                </div>
                <div
                  class="swatch"
                  style="background: var(--snurble-accent-danger);"
                >
                  <span>accent-danger</span>
                </div>
                <div
                  class="swatch"
                  style="background: var(--snurble-surface-card); border: 1px solid var(--snurble-border-card);"
                >
                  <span>surface-card</span>
                </div>
                <div
                  class="swatch"
                  style="background: var(--snurble-surface-badge);"
                >
                  <span>surface-badge</span>
                </div>
                <div
                  class="swatch"
                  style="background: var(--snurble-text-muted); color: var(--snurble-base);"
                >
                  <span>text-muted</span>
                </div>
                <div
                  class="swatch"
                  style="background: var(--snurble-text-tertiary); color: var(--snurble-base);"
                >
                  <span>text-tertiary</span>
                </div>
              </div>
            </Stack>
          </Panel>
        </Stack>
      </Section>

      <Section title="ProfileHero" headingId="profile-hero-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">WorkV2 acceptance criteria</h3>
              <ul class="ref-list">
                <li>Avatar has a <strong>green ring</strong> (<code>--snurble-accent-success</code>)</li>
                <li>
                  Name renders in <strong>peach</strong> with Montserrat Black weight
                  (<code>--snurble-brand-primary</code>, <code
                    >--snurble-font-weight-display: 900</code
                  >)
                </li>
                <li>Subtitle renders in muted text (<code>--snurble-text-muted</code>)</li>
              </ul>
            </Stack>
          </Panel>
          <Panel>
            <ProfileHero
              name="Matt Riley"
              subtitle="Senior Software Engineer in Leeds, West Yorkshire"
              avatarSrc="https://github.com/matt-riley.png"
              avatarAlt="Matt Riley's GitHub avatar"
            />
          </Panel>
        </Stack>
      </Section>

      <Section title="SocialLinks" headingId="social-links-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">WorkV2 acceptance criteria</h3>
              <ul class="ref-list">
                <li>Focus outline uses <strong>green</strong> (<code>--snurble-accent</code>)</li>
                <li>Hover scale is <strong>1.3×</strong></li>
                <li>
                  Per-platform hover color: GitHub → subtext0 (grey), LinkedIn → blue, Email →
                  peach
                </li>
                <li>Links rendered inside a <code>&lt;nav&gt;</code> landmark</li>
              </ul>
            </Stack>
          </Panel>
          <Panel>
            <SocialLinks links={profileLinks} />
          </Panel>
        </Stack>
      </Section>

      <Section
        title="DecoratedHeading"
        headingId="decorated-heading-heading"
        decorated={false}
      >
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">WorkV2 acceptance criteria</h3>
              <ul class="ref-list">
                <li>
                  SVG text fill is <strong>red/danger</strong> (<code
                    >--snurble-accent-danger</code
                  >)
                </li>
                <li>
                  SVG outline/flood is <strong>green/success</strong> (<code
                    >--snurble-accent-success</code
                  >)
                </li>
                <li>
                  Colors routed via component-local vars
                  (<code>--snurble-decorated-heading-fill</code> /
                  <code>--snurble-decorated-heading-outline</code>) so consumers can
                  override per instance
                </li>
                <li>
                  <strong>WCAG note:</strong> All-caps SVG text fails SC 1.4.8 (visual
                  presentation) at WCAG 2.1 AAA. Snurble uses this as decorative /
                  presentational text only; the semantic heading must be provided by the
                  consumer (<code>Section decorated</code> prop or manual sr-only h2).
                </li>
              </ul>
            </Stack>
          </Panel>
          <Panel>
            <Stack>
              <DecoratedHeading text="Projects" />
              <DecoratedHeading text="Experience" />
            </Stack>
          </Panel>
        </Stack>
      </Section>

      <Section title="Section with decorated prop" headingId="section-decorated-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">WorkV2 acceptance criteria</h3>
              <ul class="ref-list">
                <li>
                  When <code>decorated=&#123;true&#125;</code>, the section renders
                  <code>DecoratedHeading</code> visually and a <code>sr-only</code> h2 for
                  screen readers
                </li>
                <li>
                  Aria landmark still points to the sr-only heading id so assistive
                  technology gets a meaningful label
                </li>
                <li>
                  When <code>decorated</code> is omitted or false, the normal visible h2 renders
                  as before (no regression)
                </li>
              </ul>
            </Stack>
          </Panel>
          <Panel>
            <Section title="About Me" headingId="demo-decorated-section" decorated={true}>
              <p>
                This section uses <code>decorated=&#123;true&#125;</code>. The visible heading is
                the SVG <code>DecoratedHeading</code>. Screen readers see a hidden h2 that reads
                "About Me".
              </p>
            </Section>
          </Panel>
          <Panel>
            <Stack>
              <h3 class="ref-heading">Usage</h3>
              <CodeSnippet
                variant="block"
                code={`<Section title="About Me" headingId="about-me" decorated={true}>
  <!-- content -->
</Section>`}
              />
            </Stack>
          </Panel>
        </Stack>
      </Section>

      <Section title="ExperienceCard" headingId="experience-card-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">WorkV2 acceptance criteria</h3>
              <ul class="ref-list">
                <li>Background uses surface-card (<code>--snurble-surface-card</code>)</li>
                <li>
                  Title renders in <strong>mauve</strong> (<code>--snurble-brand-heading</code>)
                </li>
                <li>
                  Company name uses muted text (<code>--snurble-text-muted</code>), no opacity
                  hack
                </li>
                <li>
                  Header border-bottom uses card border token (<code
                    >--snurble-border-card</code
                  >)
                </li>
              </ul>
            </Stack>
          </Panel>
          <Panel>
            <ExperienceCard
              title="Senior Software Engineer"
              company="Acme Corp"
              logo="https://github.com/matt-riley.png"
              start="Jan 2020"
              end="Present"
              description="Led platform-wide migration to TypeScript strict mode across 12 services."
            />
          </Panel>
        </Stack>
      </Section>

      <Section title="ProjectCard" headingId="project-card-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">WorkV2 acceptance criteria</h3>
              <ul class="ref-list">
                <li>Background uses surface-card (<code>--snurble-surface-card</code>)</li>
                <li>
                  Title renders in <strong>mauve</strong> (<code>--snurble-brand-heading</code>)
                </li>
                <li>
                  Topic pills use badge surface (<code>--snurble-surface-badge</code>) — Phase 0
                  bug fix
                </li>
              </ul>
            </Stack>
          </Panel>
          <Panel>
            <ProjectCard
              name="snurble"
              description="Design system and component library for matt-riley.tools and related sites."
              url="https://github.com/matt-riley/snurble"
              topics={["design-system", "astro", "typescript"]}
              stars={4}
            />
          </Panel>
        </Stack>
      </Section>

      <Section title="Acceptance checklist" headingId="checklist-heading">
        <Stack>
          <Panel>
            <Stack>
              <h3 class="ref-heading">All phases complete when:</h3>
              <ul class="ref-list">
                <li>✓ Phase 0 — <code>--snurble-surface-badge</code> token added; topic pills render on dark surface</li>
                <li>✓ Phase 1 — SkipLink present in Layout; SkillIcon is aria-hidden; SocialLinks focus uses green</li>
                <li>✓ Phase 2 — 24-token semantic layer maps all Catppuccin Mocha roles to Snurble names</li>
                <li>
                  ✓ Phase 3 — ProfileHero green ring + peach name; ExperienceCard mauve title +
                  surface-card bg; ProjectCard mauve title + surface-card bg; DecoratedHeading
                  red fill + green outline; Section decorated prop; SocialLinks platform colors
                </li>
              </ul>
            </Stack>
          </Panel>
        </Stack>
      </Section>
    </PageShell>
  </main>
</Layout>

<style>
  .ref-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--snurble-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .ref-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .ref-list li {
    color: var(--snurble-text);
    line-height: 1.5;
  }

  .swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .swatch {
    border-radius: 8px;
    padding: 0.75rem 0.5rem 0.5rem;
    display: flex;
    align-items: flex-end;
    min-height: 80px;
  }

  .swatch span {
    font-size: 0.7rem;
    color: var(--snurble-base);
    background: rgba(0, 0, 0, 0.35);
    border-radius: 4px;
    padding: 0.1rem 0.3rem;
    font-family: var(--snurble-font-mono, monospace);
  }
</style>
