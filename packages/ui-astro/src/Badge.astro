---
interface Props {
  variant?: "default" | "success" | "warning" | "danger" | "info";
  class?: string;
}

const { variant = "default", class: className } = Astro.props;
---

<span class:list={["snurble-badge", `snurble-badge--${variant}`, className]}>
  <slot />
</span>

<style>
  .snurble-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--snurble-space-2);
    padding: var(--snurble-space-1) var(--snurble-space-3);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .snurble-badge--default {
    background-color: var(--snurble-surface-badge);
    color: var(--snurble-text);
  }

  .snurble-badge--success {
    background-color: var(--snurble-accent-success);
    color: var(--snurble-on-accent);
  }

  .snurble-badge--warning {
    background-color: var(--snurble-accent-warning);
    color: var(--snurble-on-warning);
  }

  .snurble-badge--danger {
    background-color: var(--snurble-accent-danger);
    color: var(--snurble-on-accent);
  }

  .snurble-badge--info {
    background-color: var(--snurble-accent);
    color: var(--snurble-on-accent);
  }
</style>
