---
interface Props {
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  class?: string;
}

const { variant = "primary", size = "md", disabled = false, class: className } = Astro.props;
---

<button
  disabled={disabled}
  class:list={[
    "snurble-button",
    `snurble-button--${variant}`,
    `snurble-button--${size}`,
    disabled && "snurble-button--disabled",
    className,
  ]}
>
  <slot />
</button>

<style>
  .snurble-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--snurble-space-2);
    min-height: 2.75rem;
    padding: calc(var(--snurble-space-3) - 0.125rem) var(--snurble-space-5);
    border: 1px solid transparent;
    border-radius: 999px;
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    box-shadow: var(--snurble-action-shadow);
    transition:
      background 180ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out,
      box-shadow 150ms ease-out,
      opacity 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-button:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: var(--snurble-action-shadow-hover);
  }

  .snurble-button:active:not(:disabled) {
    transform: translateY(0) scale(0.98);
    box-shadow: var(--snurble-action-shadow);
  }

  .snurble-button:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
  }

  /* Variants */
  .snurble-button--primary {
    background: var(--snurble-action-primary);
    color: var(--snurble-action-primary-text);
    border-color: var(--snurble-action-primary-border);
  }

  .snurble-button--primary:hover:not(:disabled) {
    background: var(--snurble-action-primary-hover);
  }

  .snurble-button--secondary {
    background: var(--snurble-action-secondary);
    color: var(--snurble-action-secondary-text);
    border-color: var(--snurble-action-secondary-border);
  }

  .snurble-button--secondary:hover:not(:disabled) {
    background: var(--snurble-action-secondary-hover);
  }

  .snurble-button--danger {
    background: var(--snurble-action-danger);
    color: var(--snurble-action-danger-text);
    border-color: var(--snurble-action-danger-border);
  }

  .snurble-button--danger:hover:not(:disabled) {
    background: var(--snurble-action-danger-hover);
  }

  /* Sizes */
  .snurble-button--sm {
    min-height: 2.25rem;
    padding: var(--snurble-space-2) var(--snurble-space-4);
    font-size: 0.875rem;
  }

  .snurble-button--lg {
    min-height: 3.25rem;
    padding: var(--snurble-space-4) var(--snurble-space-6);
    font-size: 1.125rem;
  }

  /* Disabled */
  .snurble-button--disabled,
  .snurble-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
