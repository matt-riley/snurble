---
interface LabelledByProps {
  labelledBy: string;
  ariaLabel?: never;
}

interface AriaLabelProps {
  labelledBy?: never;
  ariaLabel: string;
}

type Props = LabelledByProps | AriaLabelProps;

const {props} = Astro;
const labelledBy =
  typeof props.labelledBy === "string" ? props.labelledBy.trim() || undefined : undefined;
const ariaLabel =
  typeof props.ariaLabel === "string" ? props.ariaLabel.trim() || undefined : undefined;

const hasLabelledBy = typeof labelledBy === "string" && labelledBy.length > 0;
const hasAriaLabel = typeof ariaLabel === "string" && ariaLabel.length > 0;

if (hasLabelledBy === hasAriaLabel) {
  throw new Error("DataTable requires exactly one of `labelledBy` or `ariaLabel`.");
}
---

<div class="snurble-data-table">
  <table aria-labelledby={labelledBy} aria-label={ariaLabel}>
    <thead class="snurble-data-table__head">
      <slot name="head" />
    </thead>
    <tbody class="snurble-data-table__body">
      <slot />
    </tbody>
  </table>
</div>

<style>
  .snurble-data-table {
    min-width: 0;
    overflow-x: auto;
    border: 1px solid var(--snurble-border);
    border-radius: 0.5rem;
    background: var(--snurble-surface);
  }

  .snurble-data-table table {
    width: 100%;
    min-width: 34rem;
    border-collapse: collapse;
    color: var(--snurble-text);
  }

  .snurble-data-table__head {
    background: var(--snurble-surface-card);
  }

  .snurble-data-table :global(th),
  .snurble-data-table :global(td) {
    padding: 0.75rem 1rem;
    text-align: left;
    vertical-align: top;
    border-block-end: 1px solid var(--snurble-border);
  }

  .snurble-data-table :global(th) {
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--snurble-text-muted);
  }

  .snurble-data-table :global(td) {
    min-width: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .snurble-data-table__body :global(tr:last-child td) {
    border-block-end: 0;
  }

  .snurble-data-table :global(code) {
    white-space: nowrap;
  }

  @media (max-width: 40rem) {
    .snurble-data-table {
      overflow-x: visible;
      border: 0;
      background: transparent;
    }

    .snurble-data-table table {
      min-width: 0;
    }

    .snurble-data-table__head {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .snurble-data-table__body {
      display: grid;
      gap: var(--snurble-space-3);
    }

    .snurble-data-table__body :global(tr) {
      display: block;
      border: 1px solid var(--snurble-border);
      border-radius: 0.5rem;
      background: var(--snurble-surface-card);
      overflow: hidden;
    }

    .snurble-data-table__body :global(td) {
      display: grid;
      grid-template: auto / minmax(0, 9rem) minmax(0, 1fr);
      gap: var(--snurble-space-2);
      align-items: start;
      padding: var(--snurble-space-3) var(--snurble-space-4);
      border-block-end: 1px solid var(--snurble-border);
    }

    .snurble-data-table__body :global(td::before) {
      content: attr(data-label);
      color: var(--snurble-text-muted);
      font-size: 0.75rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .snurble-data-table__body :global(tr td:last-child) {
      border-block-end: 0;
    }

    .snurble-data-table :global(code) {
      white-space: normal;
      overflow-wrap: anywhere;
    }
  }
</style>
