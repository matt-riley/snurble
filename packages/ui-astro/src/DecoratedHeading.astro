---
interface Props {
  text: string;
}

const { text } = Astro.props;
const filterId = `decorated-heading-${crypto.randomUUID()}`;
---

<div class="snurble-decorated-heading">
  <svg viewBox="0 0 400 60" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
    <defs>
      <filter id={filterId}>
        <feMorphology
          in="SourceAlpha"
          result="DILATED"
          operator="dilate"
          radius="3"
        />
        <feFlood flood-color="var(--snurble-decorated-heading-outline, var(--snurble-accent-success))" flood-opacity="1" result="OUTLINE_COLOR" />
        <feComposite in="OUTLINE_COLOR" in2="DILATED" operator="in" result="OUTLINE" />
        <feMerge>
          <feMergeNode in="OUTLINE" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <text
      x="200"
      y="45"
      text-anchor="middle"
      filter={`url(#${filterId})`}
      class="snurble-decorated-heading__text"
    >
      {text}
    </text>
  </svg>
</div>

<style>
  .snurble-decorated-heading {
    display: flex;
    justify-content: center;
    padding-block: var(--snurble-space-2);
    --snurble-decorated-heading-fill: var(--snurble-accent-danger);
    --snurble-decorated-heading-outline: var(--snurble-accent-success);
  }

  .snurble-decorated-heading svg {
    width: 100%;
    height: auto;
    max-width: 30rem;
  }

  .snurble-decorated-heading__text {
    font-family: var(--snurble-font-display);
    font-size: 50px;
    fill: var(--snurble-decorated-heading-fill);
  }
</style>
