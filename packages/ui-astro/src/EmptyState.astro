---
interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description, class: className } = Astro.props;
---

<div class:list={["snurble-empty-state", className]}>
  <div class="snurble-empty-state__icon">
    <slot name="icon" />
  </div>
  <div class="snurble-empty-state__content">
    <h2 class="snurble-empty-state__title">{title}</h2>
    {description && <p class="snurble-empty-state__description">{description}</p>}
    <div class="snurble-empty-state__action">
      <slot />
    </div>
  </div>
</div>

<style>
  .snurble-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--snurble-space-6);
    padding: var(--snurble-space-8) var(--snurble-space-4);
    text-align: center;
  }

  .snurble-empty-state__icon {
    font-size: 3rem;
    opacity: 0.5;
  }

  .snurble-empty-state__content {
    display: grid;
    gap: var(--snurble-space-3);
    max-width: 28rem;
  }

  .snurble-empty-state__title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--snurble-text);
  }

  .snurble-empty-state__description {
    margin: 0;
    font-size: 1rem;
    color: var(--snurble-text-muted);
    line-height: 1.6;
  }

  .snurble-empty-state__action {
    display: flex;
    justify-content: center;
    margin-top: var(--snurble-space-4);
  }
</style>
