---
interface Props {
  ariaLabel: string;
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  class?: string;
}

const { ariaLabel, variant = "primary", size = "md", disabled = false, class: className } = Astro.props;
---

<button
  aria-label={ariaLabel}
  disabled={disabled}
  class:list={[
    "snurble-icon-button",
    `snurble-icon-button--${variant}`,
    `snurble-icon-button--${size}`,
    disabled && "snurble-icon-button--disabled",
    className,
  ]}
>
  <slot />
</button>

<style>
  .snurble-icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--snurble-action-secondary);
    color: var(--snurble-action-secondary-text);
    cursor: pointer;
    box-shadow: var(--snurble-action-shadow);
    transition:
      background 180ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out,
      box-shadow 150ms ease-out,
      opacity 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-icon-button:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
  }

  .snurble-icon-button:hover:not(:disabled) {
    background: var(--snurble-action-secondary-hover);
    box-shadow: var(--snurble-action-shadow-hover);
    transform: translateY(-1px);
  }

  .snurble-icon-button:active:not(:disabled) {
    transform: translateY(0) scale(0.98);
    box-shadow: var(--snurble-action-shadow);
  }

  .snurble-icon-button--sm {
    width: 2.25rem;
    height: 2.25rem;
  }

  .snurble-icon-button--lg {
    width: 3.25rem;
    height: 3.25rem;
  }

  .snurble-icon-button--primary {
    background: var(--snurble-action-primary);
    color: var(--snurble-action-primary-text);
    border-color: var(--snurble-action-primary-border);
  }

  .snurble-icon-button--primary:hover:not(:disabled) {
    background: var(--snurble-action-primary-hover);
  }

  .snurble-icon-button--danger {
    background: var(--snurble-action-danger);
    color: var(--snurble-action-danger-text);
    border-color: var(--snurble-action-danger-border);
  }

  .snurble-icon-button--danger:hover:not(:disabled) {
    background: var(--snurble-action-danger-hover);
  }

  .snurble-icon-button--disabled,
  .snurble-icon-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
