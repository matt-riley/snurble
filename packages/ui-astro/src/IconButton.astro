---
interface Props {
  ariaLabel: string;
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  class?: string;
}

const { ariaLabel, variant = "primary", size = "md", disabled = false, class: className } = Astro.props;
---

<button
  aria-label={ariaLabel}
  disabled={disabled}
  class:list={[
    "snurble-icon-button",
    `snurble-icon-button--${variant}`,
    `snurble-icon-button--${size}`,
    disabled && "snurble-icon-button--disabled",
    className,
  ]}
>
  <slot />
</button>

<style>
  .snurble-icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    background-color: var(--snurble-surface-badge);
    cursor: pointer;
    transition:
      background-color 150ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out,
      box-shadow 150ms ease-out,
      opacity 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-icon-button:focus-visible {
    outline: 2px solid var(--snurble-accent-success);
  }

  .snurble-icon-button:hover:not(:disabled) {
    background-color: var(--snurble-surface-card);
    transform: scale(1.05);
  }

  .snurble-icon-button:active:not(:disabled) {
    transform: scale(0.96);
  }

  .snurble-icon-button--sm {
    width: 2rem;
    height: 2rem;
  }

  .snurble-icon-button--lg {
    width: 3rem;
    height: 3rem;
  }

  .snurble-icon-button--primary {
    background-color: var(--snurble-accent);
    color: var(--snurble-base);
  }

  .snurble-icon-button--primary:hover:not(:disabled) {
    background-color: var(--snurble-brand-primary);
  }

  .snurble-icon-button--danger {
    background-color: var(--snurble-accent-danger);
    color: var(--snurble-base);
  }

  .snurble-icon-button--disabled,
  .snurble-icon-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
