---
interface Props {
  id: string;
  type?: string;
  placeholder?: string;
  disabled?: boolean;
  required?: boolean;
  value?: string;
  class?: string;
}

const {
  id,
  type = "text",
  placeholder,
  disabled = false,
  required = false,
  value,
  class: className,
} = Astro.props;
---

<input
  id={id}
  type={type}
  placeholder={placeholder}
  disabled={disabled}
  required={required}
  value={value}
  aria-describedby={`${id}-description ${id}-error`}
  class:list={[
    "snurble-input",
    disabled && "snurble-input--disabled",
    className,
  ]}
/>

<style>
  .snurble-input {
    padding: var(--snurble-space-3) var(--snurble-space-3);
    border: 1px solid var(--snurble-border-card);
    border-radius: 0.375rem;
    background-color: var(--snurble-surface-card);
    color: var(--snurble-text);
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    line-height: 1.5;
    transition: all 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-input:focus {
    border-color: var(--snurble-brand-primary);
    outline: 2px solid var(--snurble-accent-success);
  }

  .snurble-input:invalid:not(:placeholder-shown) {
    border-color: var(--snurble-accent-danger);
  }

  .snurble-input::placeholder {
    color: var(--snurble-text-muted);
  }

  .snurble-input--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
