---
import "@matt-riley/design-tokens";
import SkipLink from "./SkipLink.astro";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  bodyClass?: string;
}

const { title, description, lang = "en", bodyClass } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class:list={[bodyClass]}>
    <SkipLink href="#main-content">Skip to main content</SkipLink>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
