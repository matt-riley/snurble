---
import "@matt-riley/design-tokens";

interface Props {
  title: string;
  description?: string;
  lang?: string;
  bodyClass?: string;
}

const { title, description, lang = "en", bodyClass } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class:list={[bodyClass]}>
    <slot />
  </body>
</html>
