---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  external?: boolean;
  class?: string;
}

const { href, variant = "primary", size = "md", external = false, class: className } = Astro.props;
---

<a
  href={href}
  rel={external ? "noopener noreferrer" : undefined}
  target={external ? "_blank" : undefined}
  class:list={[
    "snurble-link-button",
    `snurble-link-button--${variant}`,
    `snurble-link-button--${size}`,
    className,
  ]}
>
  <slot />
</a>

<style>
  .snurble-link-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--snurble-space-2);
    min-height: 2.75rem;
    padding: calc(var(--snurble-space-3) - 0.125rem) var(--snurble-space-5);
    border: 1px solid transparent;
    border-radius: 999px;
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    box-shadow: var(--snurble-action-shadow);
    transition:
      background 180ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out,
      box-shadow 150ms ease-out,
      opacity 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-link-button:hover {
    transform: translateY(-1px);
    box-shadow: var(--snurble-action-shadow-hover);
  }

  .snurble-link-button:active {
    transform: translateY(0) scale(0.98);
    box-shadow: var(--snurble-action-shadow);
  }

  .snurble-link-button:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
  }

  /* Variants match Button */
  .snurble-link-button--primary {
    background: var(--snurble-action-primary);
    color: var(--snurble-action-primary-text);
    border-color: var(--snurble-action-primary-border);
  }

  .snurble-link-button--primary:hover {
    background: var(--snurble-action-primary-hover);
  }

  .snurble-link-button--secondary {
    background: var(--snurble-action-secondary);
    color: var(--snurble-action-secondary-text);
    border-color: var(--snurble-action-secondary-border);
  }

  .snurble-link-button--secondary:hover {
    background: var(--snurble-action-secondary-hover);
  }

  .snurble-link-button--danger {
    background: var(--snurble-action-danger);
    color: var(--snurble-action-danger-text);
    border-color: var(--snurble-action-danger-border);
  }

  .snurble-link-button--danger:hover {
    background: var(--snurble-action-danger-hover);
  }

  /* Sizes */
  .snurble-link-button--sm {
    min-height: 2.25rem;
    padding: var(--snurble-space-2) var(--snurble-space-4);
    font-size: 0.875rem;
  }

  .snurble-link-button--lg {
    min-height: 3.25rem;
    padding: var(--snurble-space-4) var(--snurble-space-6);
    font-size: 1.125rem;
  }
</style>
