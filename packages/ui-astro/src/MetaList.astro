<dl class="surble-meta-list">
  <slot />
</dl>

<style>
  .surble-meta-list {
    display: grid;
    grid-template-columns: minmax(0, 10rem) minmax(0, 1fr);
    gap: var(--surble-space-2) var(--surble-space-4);
    margin: 0;
  }

  .surble-meta-list :global(dt) {
    margin: 0;
    color: var(--surble-text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .surble-meta-list :global(dd) {
    margin: 0;
    min-width: 0;
    color: var(--surble-text);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .surble-meta-list :global(dd p) {
    margin: 0;
  }

  .surble-meta-list :global(dd p + p) {
    margin-block-start: var(--surble-space-1);
  }

  .surble-meta-list :global(a) {
    color: var(--surble-accent);
  }

  .surble-meta-list :global(code) {
    white-space: nowrap;
  }

  @media (max-width: 40rem) {
    .surble-meta-list {
      grid-template-columns: 1fr;
      gap: var(--surble-space-1);
    }

    .surble-meta-list :global(dd) {
      margin-block-end: var(--surble-space-2);
    }
  }
</style>
