---
interface Props {
  name: string;
  description: string;
  url: string;
  stars?: number;
  languages?: { name: string; color?: string }[];
  topics?: string[];
  class?: string;
}

const { name, description, url, stars, languages = [], topics = [], class: className } = Astro.props;

/**
 * Validates that a URL is safe to use in href attributes.
 */
const isSafeUrl = (candidateUrl: string): boolean => {
  if (!candidateUrl || typeof candidateUrl !== "string") {
    return false;
  }
  const trimmed = candidateUrl.trim();
  if (trimmed.length === 0 || trimmed.startsWith("//")) {
    return false;
  }
  if (/^(\/(?!\/)|\.\/|\.\.\/)/.test(trimmed)) {
    return true;
  }
  try {
    const parsed = new URL(trimmed);
    return parsed.protocol === "http:" || parsed.protocol === "https:";
  } catch {
    return false;
  }
};

/**
 * Validates that a color string is safe to use in inline styles.
 */
const isSafeColor = (color: string): boolean => {
  if (!color || typeof color !== "string") {
    return false;
  }
  const trimmed = color.trim();
  const hexPattern = /^#([0-9a-f]{3}|[0-9a-f]{6}|[0-9a-f]{8})$/i;
  const rgbPattern = /^rgba?\(\s*\d+\s*,\s*\d+\s*,\s*\d+\s*(,\s*[\d.]+\s*)?\)$/i;
  return hexPattern.test(trimmed) || rgbPattern.test(trimmed);
};

const safeUrl = isSafeUrl(url) ? url : "#";
---

<article class:list={["snurble-project-card", className]}>
  <header class="snurble-project-card__header">
    <h3 class="snurble-project-card__title">
      <a
        href={safeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="snurble-project-card__link"
      >
        {name}
      </a>
    </h3>
    {
      stars !== undefined && stars > 0 && (
        <p class="snurble-project-card__stars">
          <span aria-hidden="true">★</span>
          <span class="sr-only">stars</span>
          <span>{stars}</span>
        </p>
      )
    }
  </header>

  <p class="snurble-project-card__description">{description}</p>

  {
    languages.length > 0 && (
      <ul class="snurble-project-card__languages">
        {languages.map((language) => {
          const safeColor =
            language.color && isSafeColor(language.color) ? language.color : undefined;
          return (
            <li
              class="snurble-project-card__language-item"
              style={safeColor ? `border-color: ${safeColor}; color: ${safeColor};` : undefined}
            >
              {language.name}
            </li>
          );
        })}
      </ul>
    )
  }

  {
    topics.length > 0 && (
      <ul class="snurble-project-card__topics">
        {topics.map((topic) => (
          <li class="snurble-project-card__topic-item">#{topic}</li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .snurble-project-card {
    display: flex;
    flex-direction: column;
    gap: var(--snurble-space-3);
    height: 100%;
    padding: var(--snurble-space-4);
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border);
    border-radius: 0.75rem;
    box-shadow: var(--snurble-shadow-sm);
    transition:
      transform var(--snurble-transition-base),
      box-shadow var(--snurble-transition-base),
      border-color var(--snurble-transition-base);
  }

  .snurble-project-card:hover {
    border-color: var(--snurble-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--snurble-shadow-md);
  }

  .snurble-project-card__header {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: var(--snurble-space-2);
  }

  .snurble-project-card__title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    font-family: var(--snurble-font-body);
    color: var(--snurble-brand-heading);
  }

  .snurble-project-card__link {
    color: inherit;
    text-decoration: none;
  }

  .snurble-project-card__link::after {
    content: "";
    position: absolute;
    inset: 0;
  }

  .snurble-project-card__link:hover {
    color: var(--snurble-accent);
  }

  .snurble-project-card__stars {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--snurble-brand-primary);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .snurble-project-card__description {
    margin: 0;
    font-size: 0.875rem;
    color: var(--snurble-text-muted);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    line-height: 1.5;
  }

  .snurble-project-card__languages {
    display: flex;
    flex-wrap: wrap;
    gap: var(--snurble-space-2);
    margin: 0;
    padding: 0;
    list-style: none;
    margin-top: auto;
  }

  .snurble-project-card__language-item {
    font-size: 0.75rem;
    border: 1px solid currentColor;
    border-radius: 9999px;
    padding-inline: var(--snurble-space-2);
    padding-block: 0.125rem;
  }

  .snurble-project-card__topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--snurble-space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .snurble-project-card__topic-item {
    font-size: 0.75rem;
    background: var(--snurble-surface-badge);
    border-radius: 9999px;
    padding-inline: var(--snurble-space-2);
    padding-block: 0.125rem;
    color: var(--snurble-text-muted);
  }
</style>
