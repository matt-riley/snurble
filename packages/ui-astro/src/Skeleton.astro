---
interface Props {
  width?: string;
  height?: string;
  shape?: "rect" | "circle" | "text";
  class?: string;
}

const { width = "100%", height = "1rem", shape = "rect", class: className } = Astro.props;

const shapeStyles = {
  circle: `width: ${width}; height: ${width}; border-radius: 9999px;`,
  rect: `width: ${width}; height: ${height};`,
  text: `width: ${width}; height: ${height}; border-radius: 0.25rem;`,
};
---

<div
  class:list={["snurble-skeleton", `snurble-skeleton--${shape}`, className]}
  style={shapeStyles[shape]}
  role="status"
  aria-label="Loading..."
/>

<style>
  @supports (animation: none) {
    @media (prefers-reduced-motion: no-preference) {
      .snurble-skeleton {
        background: linear-gradient(
          90deg,
          var(--snurble-surface-card) 25%,
          var(--snurble-surface-badge) 50%,
          var(--snurble-surface-card) 75%
        );
        background-size: 200% 100%;
        animation: snurble-skeleton-shimmer 2s infinite;
      }

      @keyframes snurble-skeleton-shimmer {
        0% {
          background-position: 200% 0;
        }
        100% {
          background-position: -200% 0;
        }
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-skeleton {
      background-color: var(--snurble-surface-badge);
    }
  }

  .snurble-skeleton {
    background-color: var(--snurble-surface-card);
    border-radius: 0.375rem;
  }

  .snurble-skeleton--circle {
    border-radius: 9999px;
  }

  .snurble-skeleton--text {
    border-radius: 0.25rem;
  }
</style>
