---
interface Props {
  label?: string;
}

const { label } = Astro.props;
---

<span
  class="snurble-skill-icon"
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={!label}
>
  <slot />
</span>

<style>
  .snurble-skill-icon {
    display: inline-flex;
    align-items: center;
    gap: var(--snurble-space-1);
  }
</style>
