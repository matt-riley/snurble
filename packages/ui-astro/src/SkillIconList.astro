---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="snurble-skill-icon-list">
  {title && <h3 class="snurble-skill-icon-list__title">{title}</h3>}
  <div class="snurble-skill-icon-list__items">
    <slot />
  </div>
</div>

<style>
  .snurble-skill-icon-list {
    display: flex;
    flex-direction: column;
    gap: var(--snurble-space-2);
  }

  .snurble-skill-icon-list__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .snurble-skill-icon-list__items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--snurble-space-2);
  }
</style>
