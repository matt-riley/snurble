---
import { resolveSocialIcon } from "./social-icons";

interface Props {
  links: { href: string; icon: string; label: string }[];
}

const { links } = Astro.props;
---

<nav aria-label="Social profiles" class="snurble-social-links">
  {links.map((link) => {
    const iconAsset = resolveSocialIcon(link.icon);

    return (
      <a
        href={link.href}
        aria-label={link.label}
        target="_blank"
        rel="noopener noreferrer"
        class="snurble-social-links__link"
        data-icon={link.icon}
      >
        <span class="snurble-social-links__icon" aria-hidden="true">
          {iconAsset ? (
            <svg viewBox="0 0 24 24" focusable="false">
              <path d={iconAsset.path}></path>
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="12" cy="12" r="9" opacity="0.3"></circle>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          )}
        </span>
      </a>
    );
  })}
</nav>

<style>
  .snurble-social-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--snurble-space-3);
    padding-block: var(--snurble-space-4);
    border-block: 2px solid var(--snurble-border);
  }

  .snurble-social-links__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--snurble-text);
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .snurble-social-links__link:hover,
  .snurble-social-links__link:focus-visible {
    transform: scale(1.3);
    transition: all 0.4s ease-in-out;
  }

  .snurble-social-links__link:focus-visible {
    outline: 2px solid var(--snurble-accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .snurble-social-links__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .snurble-social-links__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .snurble-social-links__link[data-icon*="bluesky"]:hover,
  .snurble-social-links__link:focus-visible[data-icon*="bluesky"] {
    color: var(--snurble-palette-blue);
  }

  .snurble-social-links__link[data-icon*="twitch"]:hover,
  .snurble-social-links__link:focus-visible[data-icon*="twitch"] {
    color: var(--snurble-palette-mauve);
  }

  .snurble-social-links__link[data-icon*="youtube"]:hover,
  .snurble-social-links__link[data-icon*="pdf"]:hover,
  .snurble-social-links__link:focus-visible[data-icon*="youtube"],
  .snurble-social-links__link:focus-visible[data-icon*="pdf"] {
    color: var(--snurble-palette-red);
  }

  .snurble-social-links__link[data-icon*="spotify"]:hover,
  .snurble-social-links__link:focus-visible[data-icon*="spotify"] {
    color: var(--snurble-palette-green);
  }

  .snurble-social-links__link[data-icon*="github"]:hover,
  .snurble-social-links__link[data-icon*="x"]:hover,
  .snurble-social-links__link[data-icon*="twitter"]:hover,
  .snurble-social-links__link:focus-visible[data-icon*="github"],
  .snurble-social-links__link:focus-visible[data-icon*="x"],
  .snurble-social-links__link:focus-visible[data-icon*="twitter"] {
    color: var(--snurble-palette-subtext0);
  }
</style>
