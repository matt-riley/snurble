---
interface Props {
  space?: 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8;
  class?: string;
}

const { space = 4, class: className } = Astro.props;
---

<div class:list={["snurble-stack", className]} style={`--snurble-stack-gap: var(--snurble-space-${space});`}>
  <slot />
</div>

<style>
  .snurble-stack {
    display: flex;
    flex-direction: column;
    gap: var(--snurble-stack-gap, var(--snurble-space-4));
  }
</style>
