---
interface Props {
  id: string;
  placeholder?: string;
  disabled?: boolean;
  required?: boolean;
  rows?: number;
  class?: string;
}

const {
  id,
  placeholder,
  disabled = false,
  required = false,
  rows = 4,
  class: className,
} = Astro.props;
---

<textarea
  id={id}
  placeholder={placeholder}
  disabled={disabled}
  required={required}
  rows={rows}
  aria-describedby={`${id}-description ${id}-error`}
  class:list={[
    "snurble-textarea",
    disabled && "snurble-textarea--disabled",
    className,
  ]}
/>

<style>
  .snurble-textarea {
    padding: var(--snurble-space-3);
    border: 1px solid var(--snurble-border-card);
    border-radius: 0.375rem;
    background-color: var(--snurble-surface-card);
    color: var(--snurble-text);
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    line-height: 1.5;
    resize: vertical;
    transition: all 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-textarea:focus {
    border-color: var(--snurble-brand-primary);
    outline: 2px solid var(--snurble-accent-success);
  }

  .snurble-textarea:invalid:not(:placeholder-shown) {
    border-color: var(--snurble-accent-danger);
  }

  .snurble-textarea::placeholder {
    color: var(--snurble-text-muted);
  }

  .snurble-textarea--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
