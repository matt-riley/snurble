---
interface Props {
  variant?: "default" | "success" | "warning" | "danger" | "info";
  pulse?: boolean;
  class?: string;
}

const { variant = "default", pulse = false, class: className } = Astro.props;
---

<span
  class:list={[
    "snurble-badge",
    `snurble-badge--${variant}`,
    pulse && "snurble-badge--pulse",
    className,
  ]}
>
  <slot />
</span>

<style>
  .snurble-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--snurble-space-2);
    padding: calc(var(--snurble-space-1) + 1px) var(--snurble-space-3);
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .snurble-badge--default {
    background-color: var(--snurble-surface-badge);
    color: var(--snurble-text);
  }

  .snurble-badge--success {
    background-color: var(--snurble-badge-fill-success);
    color: var(--snurble-badge-on-success);
  }

  .snurble-badge--warning {
    background-color: var(--snurble-badge-fill-warning);
    color: var(--snurble-badge-on-warning);
  }

  .snurble-badge--danger {
    background-color: var(--snurble-accent-danger);
    color: var(--snurble-badge-on-fill);
  }

  .snurble-badge--info {
    background-color: var(--snurble-accent);
    color: var(--snurble-badge-on-fill);
  }

  .snurble-badge--pulse {
    animation: snurble-pulse 3s ease-in-out infinite;
  }
</style>
