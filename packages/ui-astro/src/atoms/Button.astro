---
interface Props {
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  selected?: boolean;
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  disabled = false,
  selected = false,
  class: className,
} = Astro.props;
---

<button
  aria-pressed={selected ? "true" : undefined}
  disabled={disabled}
  class:list={[
    "snurble-button",
    `snurble-button--${variant}`,
    `snurble-button--${size}`,
    selected && "snurble-button--selected",
    disabled && "snurble-button--disabled",
    className,
  ]}
>
  <slot />
</button>

<style>
  .snurble-button {
    --snurble-button-background: var(--snurble-action-primary);
    --snurble-button-background-hover: var(--snurble-action-primary-hover);
    --snurble-button-background-active: var(--snurble-action-primary-active);
    --snurble-button-background-selected: var(--snurble-action-primary-selected);
    --snurble-button-color: var(--snurble-action-primary-text);
    --snurble-button-color-selected: var(--snurble-action-primary-text);
    --snurble-button-border: var(--snurble-action-primary-border);
    --snurble-button-border-hover: var(--snurble-action-primary-border-hover);
    --snurble-button-border-selected: var(--snurble-action-primary-border-selected);

    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--snurble-space-2);
    isolation: isolate;
    overflow: hidden;
    min-height: 2.75rem;
    padding: calc(var(--snurble-space-3) - 0.125rem) var(--snurble-space-5);
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--snurble-button-background);
    color: var(--snurble-button-color);
    border-color: var(--snurble-button-border);
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    box-shadow: var(--snurble-action-shadow);
    transition:
      background 180ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out,
      transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 400ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-button::before {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: rgb(255 255 255 / 0.16);
    content: "";
    opacity: 0;
    pointer-events: none;
    transition:
      width 220ms ease-out,
      opacity 180ms ease-out;
  }

  .snurble-button:hover:not(:disabled) {
    background: var(--snurble-button-background-hover);
    border-color: var(--snurble-button-border-hover);
    box-shadow: var(--snurble-action-shadow-hover);
    transform: translateY(-2px);
  }

  .snurble-button:hover:not(:disabled)::before {
    width: 100%;
    opacity: 1;
  }

  .snurble-button:active:not(:disabled) {
    background: var(--snurble-button-background-active);
    border-color: var(--snurble-button-border-hover);
    box-shadow: var(--snurble-action-shadow-active);
    transform: translateY(0px) scale(0.98);
  }

  .snurble-button--selected,
  .snurble-button[aria-pressed="true"] {
    background: var(--snurble-button-background-selected);
    color: var(--snurble-button-color-selected);
    border-color: var(--snurble-button-border-selected);
    box-shadow: var(--snurble-action-shadow-selected);
    transform: translateY(-1px);
  }

  .snurble-button:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
  }

  .snurble-button--primary {
    --snurble-button-background: var(--snurble-action-primary);
    --snurble-button-background-hover: var(--snurble-action-primary-hover);
    --snurble-button-background-active: var(--snurble-action-primary-active);
    --snurble-button-background-selected: var(--snurble-action-primary-selected);
    --snurble-button-color: var(--snurble-action-primary-text);
    --snurble-button-color-selected: var(--snurble-action-primary-text);
    --snurble-button-border: var(--snurble-action-primary-border);
    --snurble-button-border-hover: var(--snurble-action-primary-border-hover);
    --snurble-button-border-selected: var(--snurble-action-primary-border-selected);
  }

  .snurble-button--secondary {
    --snurble-button-background: var(--snurble-action-secondary);
    --snurble-button-background-hover: var(--snurble-action-secondary-hover);
    --snurble-button-background-active: var(--snurble-action-secondary-active);
    --snurble-button-background-selected: var(--snurble-action-secondary-selected);
    --snurble-button-color: var(--snurble-action-secondary-text);
    --snurble-button-color-selected: var(--snurble-action-secondary-selected-text);
    --snurble-button-border: var(--snurble-action-secondary-border);
    --snurble-button-border-hover: var(--snurble-action-secondary-border-hover);
    --snurble-button-border-selected: var(--snurble-action-secondary-border-selected);
  }

  .snurble-button--danger {
    --snurble-button-background: var(--snurble-action-danger);
    --snurble-button-background-hover: var(--snurble-action-danger-hover);
    --snurble-button-background-active: var(--snurble-action-danger-active);
    --snurble-button-background-selected: var(--snurble-action-danger-selected);
    --snurble-button-color: var(--snurble-action-danger-text);
    --snurble-button-color-selected: var(--snurble-action-danger-text);
    --snurble-button-border: var(--snurble-action-danger-border);
    --snurble-button-border-hover: var(--snurble-action-danger-border-hover);
    --snurble-button-border-selected: var(--snurble-action-danger-border-selected);
  }

  /* Sizes */
  .snurble-button--sm {
    min-height: 2.25rem;
    padding: var(--snurble-space-2) var(--snurble-space-4);
    font-size: 0.875rem;
  }

  .snurble-button--lg {
    min-height: 3.25rem;
    padding: var(--snurble-space-4) var(--snurble-space-6);
    font-size: 1.125rem;
  }

  /* Disabled */
  .snurble-button--disabled,
  .snurble-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-button,
    .snurble-button::before {
      transition: none;
    }

    .snurble-button:hover:not(:disabled),
    .snurble-button:active:not(:disabled),
    .snurble-button--selected,
    .snurble-button[aria-pressed="true"] {
      transform: none;
    }
  }
</style>
