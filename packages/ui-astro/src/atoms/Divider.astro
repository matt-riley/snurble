---
interface Props {
  orientation?: "horizontal" | "vertical";
  decorative?: boolean;
  label?: string;
  class?: string;
}

const {
  orientation = "horizontal",
  decorative = true,
  label,
  class: className,
} = Astro.props;
const hasLabel = typeof label === "string" && label.trim().length > 0;
---

{
  hasLabel ? (
    <div
      class:list={["snurble-divider", `snurble-divider--${orientation}`, "snurble-divider--labelled", className]}
      role="separator"
      aria-orientation={orientation}
    >
      <span class="snurble-divider__label">{label}</span>
    </div>
  ) : (
    <hr
      class:list={["snurble-divider", `snurble-divider--${orientation}`, className]}
      role={decorative ? "presentation" : "separator"}
      aria-orientation={decorative ? undefined : orientation}
    />
  )
}

<style>
  .snurble-divider {
    border: 0;
    background: var(--snurble-border);
  }

  .snurble-divider--horizontal {
    width: 100%;
    height: 1px;
    margin-block: var(--snurble-space-4);
  }

  .snurble-divider--vertical {
    align-self: stretch;
    width: 1px;
    min-height: 1.5rem;
    margin-inline: var(--snurble-space-3);
  }

  .snurble-divider--labelled {
    display: flex;
    align-items: center;
    gap: var(--snurble-space-3);
    height: auto;
    background: transparent;
    color: var(--snurble-text-muted);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .snurble-divider--labelled::before,
  .snurble-divider--labelled::after {
    flex: 1;
    height: 1px;
    background: var(--snurble-border);
    content: "";
  }

  .snurble-divider--vertical.snurble-divider--labelled {
    flex-direction: column;
    width: auto;
    min-height: 6rem;
    margin-block: 0;
  }

  .snurble-divider--vertical.snurble-divider--labelled::before,
  .snurble-divider--vertical.snurble-divider--labelled::after {
    width: 1px;
    height: auto;
  }

  .snurble-divider__label {
    flex: none;
  }
</style>
