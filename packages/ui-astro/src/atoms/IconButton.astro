---
interface Props {
  ariaLabel: string;
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  selected?: boolean;
  class?: string;
}

const {
  ariaLabel,
  variant = "primary",
  size = "md",
  disabled = false,
  selected = false,
  class: className,
} = Astro.props;
---

<button
  type="button"
  aria-label={ariaLabel}
  aria-pressed={selected ? "true" : undefined}
  disabled={disabled}
  class:list={[
    "snurble-icon-button",
    `snurble-icon-button--${variant}`,
    `snurble-icon-button--${size}`,
    selected && "snurble-icon-button--selected",
    disabled && "snurble-icon-button--disabled",
    className,
  ]}
>
  <slot />
</button>

<style>
  .snurble-icon-button {
    --snurble-icon-button-background: var(--snurble-action-secondary);
    --snurble-icon-button-background-hover: var(--snurble-action-secondary-hover);
    --snurble-icon-button-background-active: var(--snurble-action-secondary-active);
    --snurble-icon-button-background-selected: var(--snurble-action-secondary-selected);
    --snurble-icon-button-color: var(--snurble-action-secondary-text);
    --snurble-icon-button-color-selected: var(--snurble-action-secondary-selected-text);
    --snurble-icon-button-border: var(--snurble-action-secondary-border);
    --snurble-icon-button-border-hover: var(--snurble-action-secondary-border-hover);
    --snurble-icon-button-border-selected: var(--snurble-action-secondary-border-selected);

    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    overflow: hidden;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--snurble-icon-button-background);
    color: var(--snurble-icon-button-color);
    border-color: var(--snurble-icon-button-border);
    cursor: pointer;
    box-shadow: var(--snurble-action-shadow);
    transition:
      background var(--snurble-duration-fast) var(--snurble-ease-soft),
      border-color var(--snurble-duration-fast) var(--snurble-ease-soft),
      color var(--snurble-duration-fast) var(--snurble-ease-soft),
      transform var(--snurble-duration-slow) var(--snurble-ease-spring),
      box-shadow var(--snurble-duration-slow) var(--snurble-ease-spring),
      opacity var(--snurble-duration-fast) var(--snurble-ease-soft);
    outline-offset: 2px;
  }

  .snurble-icon-button::before {
    position: absolute;
    inset: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: radial-gradient(circle, var(--snurble-highlight-strong), transparent 70%);
    content: "";
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -50%);
    transition:
      width 200ms ease-out,
      height 200ms ease-out,
      opacity 180ms ease-out;
  }

  .snurble-icon-button:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
  }

  .snurble-icon-button:hover:not(:disabled) {
    background: var(--snurble-icon-button-background-hover);
    border-color: var(--snurble-icon-button-border-hover);
    box-shadow: var(--snurble-action-shadow-hover);
    transform: translateY(-2px);
  }

  .snurble-icon-button:hover:not(:disabled)::before {
    width: 90%;
    height: 90%;
    opacity: 1;
  }

  .snurble-icon-button:active:not(:disabled) {
    background: var(--snurble-icon-button-background-active);
    border-color: var(--snurble-icon-button-border-hover);
    box-shadow: var(--snurble-action-shadow-active);
    transform: translateY(0px) scale(0.97);
  }

  .snurble-icon-button--selected,
  .snurble-icon-button[aria-pressed="true"] {
    background: var(--snurble-icon-button-background-selected);
    color: var(--snurble-icon-button-color-selected);
    border-color: var(--snurble-icon-button-border-selected);
    box-shadow: var(--snurble-action-shadow-selected);
    transform: translateY(-1px);
  }

  .snurble-icon-button--sm {
    width: 2.25rem;
    height: 2.25rem;
  }

  .snurble-icon-button--lg {
    width: 3.25rem;
    height: 3.25rem;
  }

  .snurble-icon-button--primary {
    --snurble-icon-button-background: var(--snurble-action-primary);
    --snurble-icon-button-background-hover: var(--snurble-action-primary-hover);
    --snurble-icon-button-background-active: var(--snurble-action-primary-active);
    --snurble-icon-button-background-selected: var(--snurble-action-primary-selected);
    --snurble-icon-button-color: var(--snurble-action-primary-text);
    --snurble-icon-button-color-selected: var(--snurble-action-primary-text);
    --snurble-icon-button-border: var(--snurble-action-primary-border);
    --snurble-icon-button-border-hover: var(--snurble-action-primary-border-hover);
    --snurble-icon-button-border-selected: var(--snurble-action-primary-border-selected);
  }

  .snurble-icon-button--danger {
    --snurble-icon-button-background: var(--snurble-action-danger);
    --snurble-icon-button-background-hover: var(--snurble-action-danger-hover);
    --snurble-icon-button-background-active: var(--snurble-action-danger-active);
    --snurble-icon-button-background-selected: var(--snurble-action-danger-selected);
    --snurble-icon-button-color: var(--snurble-action-danger-text);
    --snurble-icon-button-color-selected: var(--snurble-action-danger-text);
    --snurble-icon-button-border: var(--snurble-action-danger-border);
    --snurble-icon-button-border-hover: var(--snurble-action-danger-border-hover);
    --snurble-icon-button-border-selected: var(--snurble-action-danger-border-selected);
  }

  .snurble-icon-button--disabled,
  .snurble-icon-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-icon-button,
    .snurble-icon-button::before {
      transition: none;
    }

    .snurble-icon-button:hover:not(:disabled),
    .snurble-icon-button:active:not(:disabled),
    .snurble-icon-button--selected,
    .snurble-icon-button[aria-pressed="true"] {
      transform: none;
    }
  }
</style>
