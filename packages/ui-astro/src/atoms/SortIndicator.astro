---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  sortOrder?: "asc" | "desc" | null;
  label: string;
}

const { sortOrder = null, label, class: className, ...rest } = Astro.props;
---

<button type="button" class={`sort-indicator ${className || ""}`} aria-sort={sortOrder ? `${sortOrder}ending` : "none"} {...rest}>
  <span class="sort-indicator-label">{label}</span>
  <span class="sort-indicator-icon" aria-hidden="true">
    {sortOrder === "asc" && "↑"}
    {sortOrder === "desc" && "↓"}
    {!sortOrder && "⇅"}
  </span>
</button>

<style>
  .sort-indicator {
    display: inline-flex;
    align-items: center;
    gap: var(--snurble-space-1);
    padding: var(--snurble-space-1) var(--snurble-space-2);
    background: transparent;
    border: none;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--snurble-text);
    cursor: pointer;
    border-radius: var(--snurble-radius-sm);
    transition:
      background-color 150ms ease-out,
      color 150ms ease-out,
      opacity 150ms ease-out;
  }

  .sort-indicator:hover {
    background: var(--snurble-surface-card);
    color: var(--snurble-accent);
  }

  .sort-indicator:focus-visible {
    outline: 2px solid var(--snurble-accent);
    outline-offset: 2px;
  }

  .sort-indicator-label {
    white-space: nowrap;
  }

  .sort-indicator-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    font-size: 0.75rem;
    opacity: 0.6;
    transition: opacity 150ms ease-out;
  }

  .sort-indicator:hover .sort-indicator-icon {
    opacity: 1;
  }

  @media (prefers-color-scheme: dark) {
    .sort-indicator:hover {
      background: var(--snurble-surface);
    }
  }
</style>
