---
import { getToggleControlProps } from '../internal/toggle-control';
import type { ToggleControlProps } from '../internal/toggle-control';

type Props = ToggleControlProps;

const { ariaDescribedBy, checked, className, disabled, id, label, required, rest } =
  getToggleControlProps(Astro.props);
---

<div class:list={["snurble-switch", className]}>
  <input
    id={id}
    type="checkbox"
    role="switch"
    disabled={disabled}
    checked={checked}
    required={required}
    aria-describedby={ariaDescribedBy}
    class="snurble-switch__input"
    {...rest}
  />
  <label for={id} class="snurble-switch__label">
    <span class="snurble-switch__toggle" aria-hidden="true" />
    {label}
  </label>
</div>

<style>
  .snurble-switch {
    display: flex;
    align-items: center;
  }

  .snurble-switch__input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .snurble-switch__label {
    display: inline-flex;
    align-items: center;
    gap: var(--snurble-space-2);
    font-size: 0.875rem;
    color: var(--snurble-text);
    cursor: pointer;
    user-select: none;
  }

  .snurble-switch__toggle {
    position: relative;
    display: inline-block;
    width: 2.5rem;
    height: 1.5rem;
    background-color: var(--snurble-border-card);
    border-radius: 9999px;
    transition: background-color 150ms ease-out;
  }

  .snurble-switch__toggle::before {
    content: "";
    position: absolute;
    top: 0.25rem;
    left: 0.25rem;
    width: 1rem;
    height: 1rem;
    background-color: var(--snurble-switch-thumb);
    border-radius: 50%;
    transition: transform 150ms ease-out;
    box-shadow: var(--snurble-shadow-sm);
  }

  .snurble-switch__input:checked + .snurble-switch__label .snurble-switch__toggle {
    background-color: var(--snurble-brand-primary);
  }

  .snurble-switch__input:checked + .snurble-switch__label .snurble-switch__toggle::before {
    transform: translateX(1rem);
  }

  .snurble-switch__input:focus-visible + .snurble-switch__label {
    outline: 2px solid var(--snurble-accent-success);
    outline-offset: 2px;
    border-radius: 0.25rem;
  }

  .snurble-switch__input:disabled + .snurble-switch__label {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-switch__toggle,
    .snurble-switch__toggle::before {
      transition: none;
    }
  }
</style>
