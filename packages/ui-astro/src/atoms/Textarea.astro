---
import type { HTMLAttributes } from "astro/types";

import { toSpaceSeparatedIds } from "../internal/a11y";

interface Props extends Omit<HTMLAttributes<"textarea">, "class" | "id" | "rows"> {
  id: string;
  placeholder?: string;
  disabled?: boolean;
  required?: boolean;
  rows?: number;
  describedBy?: string | readonly string[];
  class?: string;
}

const {
  id,
  placeholder,
  disabled = false,
  required = false,
  rows = 4,
  describedBy,
  class: className,
  ...rest
} = Astro.props;

const ariaDescribedBy = toSpaceSeparatedIds(describedBy);
---

<textarea
  id={id}
  placeholder={placeholder}
  disabled={disabled}
  required={required}
  rows={rows}
  aria-describedby={ariaDescribedBy}
  class:list={[
    "snurble-textarea",
    disabled && "snurble-textarea--disabled",
    className,
  ]}
  {...rest}
/>

<style>
  .snurble-textarea {
    padding: var(--snurble-space-3);
    border: 1px solid var(--snurble-border-card);
    border-radius: 0.375rem;
    background-color: var(--snurble-surface-card);
    color: var(--snurble-text);
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    line-height: 1.5;
    resize: vertical;
    transition:
      background-color 150ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-textarea:focus {
    border-color: var(--snurble-brand-primary);
    outline: 2px solid var(--snurble-accent-success);
  }

  .snurble-textarea:invalid:not(:placeholder-shown) {
    border-color: var(--snurble-accent-danger);
  }

  .snurble-textarea::placeholder {
    color: var(--snurble-text-muted);
  }

  .snurble-textarea--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
