---
interface Props {
  as?: "span" | "div";
  class?: string;
}

const { as: Element = "span", class: className } = Astro.props;
---

<Element class:list={["snurble-visually-hidden", className]}>
  <slot />
</Element>

<style>
  .snurble-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
