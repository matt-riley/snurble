---
interface Props {
  title: string;
  description?: string;
  variant?: "info" | "success" | "warning" | "danger";
  class?: string;
}

const { title, description, variant = "info", class: className } = Astro.props;
const colorMap = {
  danger: "--snurble-accent-danger",
  info: "--snurble-accent",
  success: "--snurble-accent-success",
  warning: "--snurble-accent-warning",
};
---

<div role="alert" class:list={["snurble-alert", `snurble-alert--${variant}`, className]}>
  <div class="snurble-alert__icon" style={`color: var(${colorMap[variant]})`}>
    <slot name="icon" />
  </div>
  <div class="snurble-alert__content">
    <h3 class="snurble-alert__title">{title}</h3>
    {description && <p class="snurble-alert__description">{description}</p>}
    <slot />
  </div>
</div>

<style>
  .snurble-alert {
    display: flex;
    gap: var(--snurble-space-3);
    padding: var(--snurble-space-4);
    border-radius: var(--snurble-radius-md);
    border-left: 4px solid;
  }

  .snurble-alert--info {
    background-color: color-mix(in srgb, var(--snurble-accent) 10%, transparent);
    border-color: var(--snurble-accent);
    color: var(--snurble-text);
  }

  .snurble-alert--success {
    background-color: color-mix(in srgb, var(--snurble-accent-success) 10%, transparent);
    border-color: var(--snurble-accent-success);
    color: var(--snurble-text);
  }

  .snurble-alert--warning {
    background-color: color-mix(in srgb, var(--snurble-accent-warning) 10%, transparent);
    border-color: var(--snurble-accent-warning);
    color: var(--snurble-text);
  }

  .snurble-alert--danger {
    background-color: color-mix(in srgb, var(--snurble-accent-danger) 10%, transparent);
    border-color: var(--snurble-accent-danger);
    color: var(--snurble-text);
  }

  .snurble-alert__icon {
    flex-shrink: 0;
    font-size: 1.25rem;
  }

  .snurble-alert__content {
    display: grid;
    gap: var(--snurble-space-2);
  }

  .snurble-alert__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
  }

  .snurble-alert__description {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--snurble-text-muted);
  }
</style>
