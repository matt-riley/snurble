---
import { toSpaceSeparatedIds } from "../internal/a11y";

interface ComboboxOption {
  label: string;
  value: string;
  disabled?: boolean;
}

interface Props {
  id: string;
  name?: string;
  label: string;
  options?: ComboboxOption[];
  value?: string;
  placeholder?: string;
  autocomplete?: "none" | "list";
  clearable?: boolean;
  disabled?: boolean;
  invalid?: boolean;
  required?: boolean;
  describedBy?: string | readonly string[];
  class?: string;
}

const {
  id,
  name = id,
  label,
  options = [],
  value,
  placeholder = "Select an option",
  autocomplete = "list",
  clearable = true,
  disabled = false,
  invalid = false,
  required = false,
  describedBy,
  class: className,
} = Astro.props;
const listboxId = `${id}-listbox`;
const selectedOption = options.find((option) => option.value === value);
const ariaDescribedBy = toSpaceSeparatedIds(describedBy);
---

<div
  class:list={[
    "snurble-combobox",
    invalid && "snurble-combobox--invalid",
    disabled && "snurble-combobox--disabled",
    className,
  ]}
  data-component="combobox"
  data-autocomplete={autocomplete}
>
  <label class="snurble-combobox__label" for={`${id}-input`}>{label}</label>
  <div class="snurble-combobox__control">
    <input type="hidden" name={name} value={value} data-combobox-hidden />
    <input
      id={`${id}-input`}
      class="snurble-combobox__input"
      type="text"
      value={selectedOption?.label ?? ""}
      placeholder={placeholder}
      disabled={disabled}
      required={required}
      role="combobox"
      aria-autocomplete={autocomplete === "none" ? "none" : "list"}
      aria-expanded="false"
      aria-controls={listboxId}
      aria-describedby={ariaDescribedBy}
      aria-invalid={invalid ? "true" : undefined}
      autocomplete="off"
      data-combobox-input
    />
    {clearable && (
      <button class="snurble-combobox__clear" type="button" aria-label="Clear selection" disabled={disabled} data-combobox-clear>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    )}
    <button class="snurble-combobox__toggle" type="button" aria-label="Toggle options" disabled={disabled} data-combobox-toggle>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </button>
  </div>
  <div
    id={listboxId}
    class="snurble-combobox__listbox"
    role="listbox"
    aria-label={label}
    data-combobox-listbox
    data-open="false"
    popover="manual"
  >
    {options.map((option, index) => (
      <button
        id={`${id}-option-${index}`}
        class="snurble-combobox__option"
        type="button"
        role="option"
        disabled={option.disabled}
        aria-disabled={option.disabled ? "true" : undefined}
        aria-selected={option.value === value ? "true" : "false"}
        data-combobox-option
        data-value={option.value}
        data-label={option.label}
      >
        {option.label}
      </button>
    ))}
    <p class="snurble-combobox__empty" data-combobox-empty hidden>No options found.</p>
  </div>
</div>

<style>
  .snurble-combobox {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--snurble-space-2);
    width: 100%;
    color: var(--snurble-text);
  }

  .snurble-combobox__label {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .snurble-combobox__control {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border-card);
    border-radius: var(--snurble-radius-md);
    transition:
      border-color 150ms ease-out,
      box-shadow 150ms ease-out,
      opacity 150ms ease-out;
  }

  .snurble-combobox__control:focus-within {
    border-color: var(--snurble-brand-primary);
    box-shadow: 0 0 0 2px var(--snurble-focus-ring);
  }

  .snurble-combobox--invalid .snurble-combobox__control {
    border-color: var(--snurble-accent-danger);
  }

  .snurble-combobox--disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .snurble-combobox__input {
    flex: 1 1 auto;
    min-width: 0;
    min-height: 2.75rem;
    padding: 0 var(--snurble-space-3);
    color: inherit;
    background: transparent;
    border: 0;
    font: inherit;
    outline: none;
  }

  .snurble-combobox__input::placeholder {
    color: var(--snurble-text-muted);
  }

  .snurble-combobox__clear,
  .snurble-combobox__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    color: var(--snurble-text-muted);
    background: transparent;
    border: 0;
    border-radius: var(--snurble-radius-md);
    cursor: pointer;
  }

  .snurble-combobox__clear[hidden] {
    opacity: 0;
    pointer-events: none;
  }

  .snurble-combobox__clear:hover:not(:disabled),
  .snurble-combobox__toggle:hover:not(:disabled) {
    color: var(--snurble-text);
    background: var(--snurble-surface-badge);
  }

  .snurble-combobox__clear:focus-visible,
  .snurble-combobox__toggle:focus-visible,
  .snurble-combobox__option:focus-visible {
    outline: 2px solid var(--snurble-focus-ring);
    outline-offset: 2px;
  }

  .snurble-combobox__clear svg,
  .snurble-combobox__toggle svg {
    width: 1rem;
    height: 1rem;
  }

  .snurble-combobox__listbox {
    position: fixed;
    inset-inline-start: 0;
    top: 0;
    z-index: var(--snurble-z-index-dropdown);
    max-height: 16rem;
    overflow-y: auto;
    padding: var(--snurble-space-1);
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border-card);
    border-radius: var(--snurble-radius-lg);
    box-shadow: var(--snurble-shadow-spatial-floating);
  }

  @supports (position-anchor: --snurble-anchor) {
    .snurble-combobox__listbox {
      position: absolute;
      position-anchor: --snurble-anchor;
      inset-inline-start: auto;
      top: auto;
      left: anchor(left);
      margin-top: var(--snurble-space-2);
      min-width: anchor-size(width);
    }
  }

  .snurble-combobox__option {
    display: block;
    width: 100%;
    padding: var(--snurble-space-2) var(--snurble-space-3);
    color: var(--snurble-text);
    background: transparent;
    border: 0;
    border-radius: var(--snurble-radius-md);
    font: inherit;
    text-align: start;
    cursor: pointer;
  }

  .snurble-combobox__option:hover,
  .snurble-combobox__option[aria-selected="true"] {
    background: var(--snurble-surface-badge);
  }

  .snurble-combobox__option:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .snurble-combobox__empty {
    margin: 0;
    padding: var(--snurble-space-3);
    color: var(--snurble-text-muted);
    font-size: 0.875rem;
    text-align: center;
  }
</style>

<script>
  import {
    applyAnchorPair,
    attachFloatingAutoUpdate,
    isOpen,
    noopCleanup,
    setOpen,
    supportsPopoverApi,
  } from "../internal/floating";

  const initCombobox = (el: Element) => {
    if (!(el instanceof HTMLElement) || el.dataset.snurbleComboboxBound === "true") {
      return;
    }

    el.dataset.snurbleComboboxBound = "true";
    const input = el.querySelector("[data-combobox-input]");
    const hidden = el.querySelector("[data-combobox-hidden]");
    const toggle = el.querySelector("[data-combobox-toggle]");
    const clear = el.querySelector("[data-combobox-clear]");
    const listbox = el.querySelector("[data-combobox-listbox]");
    const empty = el.querySelector("[data-combobox-empty]");
    const options = [...el.querySelectorAll("[data-combobox-option]")];
    let visibleOptions = options;
    let currentIndex = -1;
    let detachAutoUpdate = noopCleanup;

    if (!(input instanceof HTMLInputElement) || !(hidden instanceof HTMLInputElement) || !(listbox instanceof HTMLElement)) {
      return;
    }

    if (!supportsPopoverApi(listbox)) {
      listbox.hidden = true;
    }

    applyAnchorPair(input, listbox, listbox.id || input.id || "combobox");

    const syncClearButton = () => {
      if (clear instanceof HTMLButtonElement) {
        clear.hidden = input.value.length === 0;
      }
    };

    const setHighlighted = (index: number) => {
      currentIndex = index;
      for (const [optionIndex, option] of visibleOptions.entries()) {
        const isActive = optionIndex === currentIndex;
        option.setAttribute("aria-selected", isActive.toString());
        if (option instanceof HTMLElement && isActive) {
          input.setAttribute("aria-activedescendant", option.id);
          option.scrollIntoView({ block: "nearest" });
        }
      }

      if (currentIndex < 0) {
        input.removeAttribute("aria-activedescendant");
      }
    };

    const syncOpenState = (open: boolean) => {
      setOpen(listbox, open);
      input.setAttribute("aria-expanded", open.toString());
      detachAutoUpdate();
      if (open) {
        detachAutoUpdate = attachFloatingAutoUpdate(
          input,
          listbox,
          "bottom",
          8
        );
      }
    };

    const filterOptions = () => {
      const query = el.dataset.autocomplete === "none" ? "" : input.value.trim().toLowerCase();
      visibleOptions = [];

      for (const option of options) {
        const label = (option instanceof HTMLElement ? option.dataset.label : "") ?? "";
        const isMatch = label.toLowerCase().includes(query);
        if (option instanceof HTMLElement) {
          option.hidden = !isMatch;
        }
        if (isMatch && option.getAttribute("aria-disabled") !== "true") {
          visibleOptions.push(option);
        }
      }

      if (empty instanceof HTMLElement) {
        empty.hidden = visibleOptions.length > 0;
      }
      setHighlighted(visibleOptions.length > 0 ? 0 : -1);
    };

    const chooseOption = (option: Element) => {
      if (!(option instanceof HTMLElement) || option.getAttribute("aria-disabled") === "true") {
        return;
      }

      input.value = option.dataset.label ?? "";
      hidden.value = option.dataset.value ?? "";
      for (const item of options) {
        item.setAttribute("aria-selected", (item === option).toString());
      }
      syncOpenState(false);
      input.focus();
      syncClearButton();
      el.dispatchEvent(new CustomEvent("snurble-combobox-change", {
        bubbles: true,
        detail: { label: input.value, value: hidden.value },
      }));
    };

    input.addEventListener("focus", () => {
      filterOptions();
      syncOpenState(true);
    });
    input.addEventListener("input", () => {
      hidden.value = "";
      filterOptions();
      syncOpenState(true);
      syncClearButton();
    });
    input.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        syncOpenState(false);
      }
      if (event.key === "ArrowDown") {
        event.preventDefault();
        syncOpenState(true);
        const nextIndex = currentIndex + 1 >= visibleOptions.length ? 0 : currentIndex + 1;
        setHighlighted(nextIndex);
      }
      if (event.key === "ArrowUp") {
        event.preventDefault();
        syncOpenState(true);
        const nextIndex = currentIndex - 1 < 0 ? visibleOptions.length - 1 : currentIndex - 1;
        setHighlighted(nextIndex);
      }
      if (event.key === "Enter" && currentIndex >= 0) {
        event.preventDefault();
        chooseOption(visibleOptions[currentIndex]);
      }
    });

    if (toggle instanceof HTMLButtonElement) {
      toggle.addEventListener("click", () => {
        const shouldOpen = !isOpen(listbox);
        filterOptions();
        syncOpenState(shouldOpen);
        input.focus();
      });
    }

    if (clear instanceof HTMLButtonElement) {
      clear.addEventListener("click", () => {
        input.value = "";
        hidden.value = "";
        filterOptions();
        syncOpenState(true);
        input.focus();
        syncClearButton();
        el.dispatchEvent(new CustomEvent("snurble-combobox-clear", { bubbles: true }));
      });
    }

    for (const option of options) {
      option.addEventListener("click", () => chooseOption(option));
    }

    document.addEventListener("click", (event) => {
      if (event.target instanceof Node && !el.contains(event.target)) {
        syncOpenState(false);
      }
    });

    filterOptions();
    syncClearButton();
  };

  const initComboboxes = () => {
    for (const el of document.querySelectorAll('[data-component="combobox"]')) {
      initCombobox(el);
    }
  };

  initComboboxes();
  document.addEventListener("astro:page-load", initComboboxes);
</script>
