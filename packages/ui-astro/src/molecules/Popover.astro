---
/**
 * Popover - Positioned floating overlay attached to a trigger element
 * 
 * Renders a floating panel positioned relative to a trigger element
 * with backdrop, arrow, and keyboard dismiss support.
 * 
 * Usage:
 * <Popover
 *   id="my-popover"
 *   triggerSelector="#popover-trigger"
 *   position="bottom"
 *   title="Help"
 * >
 *   <p>Helpful content goes here</p>
 * </Popover>
 * <button id="popover-trigger">Open help</button>
 */

interface Props {
  /** Unique ID for the popover */
  id?: string;
  /** Whether popover is open by default */
  open?: boolean;
  /** Optional trigger element id used for click toggling and focus return */
  triggerId?: string;
  /** Position relative to trigger: top, bottom, left, right */
  position?: 'top' | 'bottom' | 'left' | 'right';
  /** Optional title */
  title?: string;
  /** Whether clicking outside closes the popover */
  closeOnOutsideClick?: boolean;
  /** Optional CSS class */
  class?: string;
}

const {
  id = `popover-${crypto.randomUUID()}`,
  open = false,
  triggerId,
  position = 'bottom',
  title,
  closeOnOutsideClick = true,
  class: className,
} = Astro.props;
---

<div
  id={id}
  class:list={[
    'snurble-popover',
    `snurble-popover-${position}`,
    !triggerId && 'snurble-popover--static',
    className,
  ]}
  data-component="popover"
  data-open={open}
  data-position={position}
  data-trigger-id={triggerId}
  data-close-on-outside={closeOnOutsideClick}
  role="dialog"
  aria-modal="false"
  aria-labelledby={title ? `${id}-title` : undefined}
  popover={triggerId ? "manual" : undefined}
>
  <div class="snurble-popover-arrow" aria-hidden="true" />

  <div class="snurble-popover-box">
    {title && (
      <div class="snurble-popover-header">
        <h3 id={`${id}-title`} class="snurble-popover-title">{title}</h3>
        <button
          class="snurble-popover-close"
          aria-label="Close popover"
          data-close-button
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    )}

    <div class="snurble-popover-content">
      <slot />
    </div>
  </div>
</div>

<style>
  .snurble-popover {
    position: fixed;
    top: 0;
    left: 0;
    z-index: var(--snurble-z-index-popover);
    opacity: 0;
    pointer-events: none;
    animation: snurble-popover-exit 150ms ease-out forwards;
  }

  .snurble-popover--static {
    position: relative;
    top: auto;
    left: auto;
  }

  @supports (position-anchor: --snurble-anchor) {
    .snurble-popover:not(.snurble-popover--static) {
      position: absolute;
      top: auto;
      left: auto;
      position-anchor: --snurble-anchor;
    }

    .snurble-popover-top:not(.snurble-popover--static) {
      bottom: calc(anchor(top) + 0.75rem);
      justify-self: anchor-center;
    }

    .snurble-popover-bottom:not(.snurble-popover--static) {
      top: calc(anchor(bottom) + 0.75rem);
      justify-self: anchor-center;
    }

    .snurble-popover-left:not(.snurble-popover--static) {
      right: calc(anchor(left) + 0.75rem);
      top: calc(anchor(center));
      translate: 0 -50%;
    }

    .snurble-popover-right:not(.snurble-popover--static) {
      left: calc(anchor(right) + 0.75rem);
      top: calc(anchor(center));
      translate: 0 -50%;
    }
  }

  .snurble-popover[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
    animation: snurble-popover-enter 150ms ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-popover {
      animation: none;
    }
  }

  .snurble-popover-arrow {
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .snurble-popover-top .snurble-popover-arrow {
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 6px 6px 0 6px;
    border-color: var(--snurble-surface-card) transparent transparent transparent;
  }

  .snurble-popover-bottom .snurble-popover-arrow {
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 0 6px 6px 6px;
    border-color: transparent transparent var(--snurble-surface-card) transparent;
  }

  .snurble-popover-left .snurble-popover-arrow {
    right: -6px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 6px 0 6px 6px;
    border-color: transparent transparent transparent var(--snurble-surface-card);
  }

  .snurble-popover-right .snurble-popover-arrow {
    left: -6px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 6px 6px 6px 0;
    border-color: transparent var(--snurble-surface-card) transparent transparent;
  }

  .snurble-popover-box {
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border-card);
    border-radius: var(--snurble-radius-lg);
    box-shadow: var(--snurble-shadow-spatial-floating);
    max-width: 320px;
  }

  .snurble-popover-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--snurble-space-3);
    border-bottom: 1px solid var(--snurble-border-card);
  }

  .snurble-popover-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--snurble-text);
  }

  .snurble-popover-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--snurble-text-muted);
    border-radius: 0.375rem;
    transition:
      background-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out;
  }

  .snurble-popover-close:hover {
    background: var(--snurble-surface-badge);
    color: var(--snurble-text);
  }

  .snurble-popover-close:active {
    transform: scale(0.96);
  }

  .snurble-popover-close:focus-visible {
    outline: 2px solid var(--snurble-focus-ring);
    outline-offset: 2px;
  }

  .snurble-popover-close svg {
    width: 1rem;
    height: 1rem;
  }

  .snurble-popover-content {
    padding: var(--snurble-space-3);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--snurble-text);
  }

  @keyframes snurble-popover-enter {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes snurble-popover-exit {
    from {
      opacity: 1;
      transform: scale(1);
    }
    to {
      opacity: 0;
      transform: scale(0.95);
    }
  }
</style>

<script>
  import {
    applyAnchorPair,
    attachFloatingAutoUpdate,
    isOpen,
    noopCleanup,
    setOpen,
    supportsPopoverApi,
  } from "../internal/floating";

  const initPopover = (el: Element) => {
    if (!(el instanceof HTMLElement) || el.dataset.snurblePopoverBound === 'true') {
      return;
    }

    el.dataset.snurblePopoverBound = 'true';
    const closeButton = el.querySelector('[data-close-button]');
    const trigger = el.dataset.triggerId ? document.querySelector(`#${CSS.escape(el.dataset.triggerId)}`) : null;
    const closeOnOutside = el.dataset.closeOnOutside === 'true';
    let detachAutoUpdate = noopCleanup;

    if (!supportsPopoverApi(el)) {
      el.hidden = el.dataset.open !== 'true';
    }

    if (trigger instanceof HTMLElement) {
      applyAnchorPair(trigger, el, el.id || trigger.id || 'popover');
    }

    const updatePosition = () => {
      detachAutoUpdate();
      if (trigger instanceof HTMLElement) {
        detachAutoUpdate = attachFloatingAutoUpdate(trigger, el, el.dataset.position ?? 'bottom', 12);
      }
    };

    const close = (focusTrigger = false) => {
      detachAutoUpdate();
      setOpen(el, false);
      trigger?.setAttribute('aria-expanded', 'false');
      if (focusTrigger && trigger instanceof HTMLElement) {
        trigger.focus();
      }
    };

    const open = () => {
      updatePosition();
      setOpen(el, true);
      trigger?.setAttribute('aria-expanded', 'true');
    };

    const toggle = () => {
      if (isOpen(el)) {
        close();
      } else {
        open();
      }
    };

    if (trigger instanceof HTMLElement) {
      trigger.setAttribute('aria-haspopup', 'dialog');
      trigger.setAttribute('aria-expanded', el.dataset.open === 'true' ? 'true' : 'false');
      trigger.setAttribute('aria-controls', el.id);
      trigger.addEventListener('click', toggle);
    }

    if (closeButton instanceof HTMLButtonElement) {
      closeButton.addEventListener('click', () => close(true));
    }

    const handleClickOutside = (e: MouseEvent) => {
      if (
        closeOnOutside &&
        isOpen(el) &&
        !el.contains(e.target as Node) &&
        !(trigger instanceof HTMLElement && trigger.contains(e.target as Node))
      ) {
        close();
      }
    };

    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && isOpen(el)) {
        close(true);
      }
    };

    document.addEventListener('click', handleClickOutside);
    document.addEventListener('keydown', handleEscape);

    if (el.dataset.open === 'true') {
      requestAnimationFrame(open);
    }

    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'data-open') {
          if (el.dataset.open === 'true') {
            open();
          } else {
            close();
          }
        }
      }
    });

    observer.observe(el, { attributes: true });
  };

  const initPopovers = () => {
    const popovers = document.querySelectorAll('[data-component="popover"]');
    for (const popover of popovers) {
      initPopover(popover);
    }
  };

  initPopovers();
  document.addEventListener('astro:page-load', initPopovers);
</script>
