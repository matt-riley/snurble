---
import type { HTMLAttributes } from "astro/types";

import { toSpaceSeparatedIds } from "../internal/a11y";

interface SelectOption {
  value: string;
  label: string;
  disabled?: boolean;
}

interface Props extends Omit<HTMLAttributes<"select">, "class" | "id"> {
  id: string;
  options: SelectOption[];
  disabled?: boolean;
  required?: boolean;
  defaultValue?: string;
  value?: string;
  placeholder?: string;
  describedBy?: string | readonly string[];
  class?: string;
}

const {
  id,
  options,
  disabled = false,
  required = false,
  defaultValue,
  value: controlledValue,
  placeholder,
  describedBy,
  class: className,
  ...rest
} = Astro.props;

const selectedValue = controlledValue ?? defaultValue;
const ariaDescribedBy = toSpaceSeparatedIds(describedBy);
---

<div class:list={["snurble-select-wrapper", className]}>
  <select
    id={id}
    disabled={disabled}
    required={required}
    aria-describedby={ariaDescribedBy}
    class:list={[
      "snurble-select",
      disabled && "snurble-select--disabled",
    ]}
    {...rest}
  >
    {
      placeholder && (
        <option value="" selected={selectedValue === undefined}>
          {placeholder}
        </option>
      )
    }
    {options.map((option) => (
      <option
        value={option.value}
        disabled={option.disabled}
        selected={option.value === selectedValue}
      >
        {option.label}
      </option>
    ))}
  </select>
  <div class="snurble-select-chevron" aria-hidden="true"></div>
</div>

<style>
  .snurble-select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .snurble-select {
    width: 100%;
    padding: var(--snurble-space-3) var(--snurble-space-3);
    padding-right: 2.5rem;
    border: 1px solid var(--snurble-border-card);
    border-radius: 0.375rem;
    background-color: var(--snurble-surface-card);
    color: var(--snurble-text);
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    line-height: 1.5;
    appearance: none;
    cursor: pointer;
    transition:
      background-color 150ms ease-out,
      border-color 150ms ease-out,
      color 150ms ease-out,
      opacity 150ms ease-out;
    outline-offset: 2px;
  }

  @supports (appearance: base-select) {
    .snurble-select {
      appearance: base-select;
    }
  }

  .snurble-select-chevron {
    position: absolute;
    right: 0.5rem;
    width: 1.25rem;
    height: 1.25rem;
    pointer-events: none;
    background-color: currentColor;
    color: var(--snurble-text);
    -webkit-mask-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>');
    mask-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>');
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
    transition: opacity 150ms ease-out;
  }

  .snurble-select:focus {
    border-color: var(--snurble-brand-primary);
    outline: 2px solid var(--snurble-accent-success);
  }

  .snurble-select:invalid:not(:placeholder-shown) {
    border-color: var(--snurble-accent-danger);
  }

  .snurble-select:invalid:not(:placeholder-shown) + .snurble-select-chevron {
    color: var(--snurble-accent-danger);
  }

  .snurble-select--disabled,
  .snurble-select:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .snurble-select:disabled + .snurble-select-chevron {
    opacity: 0.5;
  }

  .snurble-select option {
    background-color: var(--snurble-surface-card);
    color: var(--snurble-text);
  }
</style>
