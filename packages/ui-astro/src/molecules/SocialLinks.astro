---
import { resolveSocialIcon } from "../social-icons";

interface Props {
  links: { href: string; icon: string; label: string }[];
  effect?: "halo" | "slide";
}

const { links, effect = "halo" }: Props = Astro.props;
---

<nav aria-label="Social profiles" class="snurble-social-links">
  {links.map((link) => {
    const iconAsset = resolveSocialIcon(link.icon);

    return (
      <a
        href={link.href}
        aria-label={link.label}
        target="_blank"
        rel="noopener noreferrer"
        class="snurble-social-links__link"
        data-icon={link.icon}
        data-effect={effect}
      >
        <span class="snurble-social-links__icon-shell" aria-hidden="true">
          <span class="snurble-social-links__icon-clip">
            <span class="snurble-social-links__icon">
              {iconAsset ? (
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d={iconAsset.path}></path>
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" focusable="false">
                  <circle cx="12" cy="12" r="9" opacity="0.3"></circle>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              )}
            </span>
          </span>
        </span>
      </a>
    );
  })}
</nav>

<style>
  .snurble-social-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--snurble-space-3);
    padding-block: var(--snurble-space-4);
    border-block: 2px solid var(--snurble-border);
  }

  .snurble-social-links__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--snurble-text);
    text-decoration: none;
    transition:
      color 160ms ease-out,
      outline-color 160ms ease-out,
      transform 180ms ease-out;
  }

  .snurble-social-links__link[data-effect="halo"]:hover,
  .snurble-social-links__link[data-effect="halo"]:focus-visible {
    transform: translateY(-1px);
  }

  .snurble-social-links__link:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
    outline-offset: 2px;
  }

  .snurble-social-links__icon-shell {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
  }

  .snurble-social-links__icon-shell::before,
  .snurble-social-links__icon-shell::after {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    content: "";
    pointer-events: none;
    transition:
      opacity 180ms ease-out,
      transform 180ms ease-out;
  }

  .snurble-social-links__icon-shell::before {
    border: 1px solid color-mix(in srgb, currentColor 24%, transparent);
    opacity: 0.55;
  }

  .snurble-social-links__icon-shell::after {
    border: 2px solid currentColor;
    opacity: 0;
    transform: scale(0.88);
  }

  .snurble-social-links__icon-clip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: inherit;
  }

  .snurble-social-links__icon {
    display: flex;
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    transition:
      opacity 180ms ease-out,
      transform 180ms ease-out;
  }

  .snurble-social-links__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .snurble-social-links__link:hover .snurble-social-links__icon-shell::after,
  .snurble-social-links__link:focus-visible .snurble-social-links__icon-shell::after {
    opacity: 0.45;
    transform: scale(1);
  }

  .snurble-social-links__link[data-effect="halo"]:hover .snurble-social-links__icon-shell::after,
  .snurble-social-links__link[data-effect="halo"]:focus-visible .snurble-social-links__icon-shell::after {
    opacity: 0.7;
    transform: scale(1.06);
  }

  .snurble-social-links__link[data-effect="slide"]:hover .snurble-social-links__icon,
  .snurble-social-links__link[data-effect="slide"]:focus-visible .snurble-social-links__icon {
    transform: translateX(0.2rem);
  }

  .snurble-social-links__link[data-icon*="bluesky"]:hover,
  .snurble-social-links__link[data-icon*="bluesky"]:focus-visible {
    color: var(--snurble-palette-blue);
  }

  .snurble-social-links__link[data-icon*="twitch"]:hover,
  .snurble-social-links__link[data-icon*="twitch"]:focus-visible {
    color: var(--snurble-palette-mauve);
  }

  .snurble-social-links__link[data-icon*="youtube"]:hover,
  .snurble-social-links__link[data-icon*="youtube"]:focus-visible,
  .snurble-social-links__link[data-icon*="pdf"]:hover,
  .snurble-social-links__link[data-icon*="pdf"]:focus-visible {
    color: var(--snurble-palette-red);
  }

  .snurble-social-links__link[data-icon*="spotify"]:hover,
  .snurble-social-links__link[data-icon*="spotify"]:focus-visible {
    color: var(--snurble-palette-green);
  }

  .snurble-social-links__link[data-icon*="github"]:hover,
  .snurble-social-links__link[data-icon*="github"]:focus-visible,
  .snurble-social-links__link[data-icon*="x"]:hover,
  .snurble-social-links__link[data-icon*="x"]:focus-visible,
  .snurble-social-links__link[data-icon*="twitter"]:hover,
  .snurble-social-links__link[data-icon*="twitter"]:focus-visible {
    color: var(--snurble-palette-subtext0);
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-social-links__link,
    .snurble-social-links__icon-shell::before,
    .snurble-social-links__icon-shell::after,
    .snurble-social-links__icon {
      transition: none;
    }

    .snurble-social-links__link:hover,
    .snurble-social-links__link:focus-visible,
    .snurble-social-links__link:hover .snurble-social-links__icon,
    .snurble-social-links__link:focus-visible .snurble-social-links__icon,
    .snurble-social-links__link:hover .snurble-social-links__icon-shell::after,
    .snurble-social-links__link:focus-visible .snurble-social-links__icon-shell::after {
      transform: none;
    }
  }
</style>
