---
interface TabItem {
  id: string;
  label: string;
}

interface Props {
  tabs: TabItem[];
  defaultTab?: string;
  class?: string;
}

const { tabs, defaultTab = tabs[0]?.id, class: className } = Astro.props;
const tabPanelContent = new Map(
  await Promise.all(
    tabs.map(async (tab) => [tab.id, await Astro.slots.render(tab.id)] as const)
  )
);
---

<div class:list={["snurble-tabs", className]}>
  <div class="snurble-tabs__tablist" role="tablist">
    {tabs.map((tab) => (
      <button
        role="tab"
        aria-selected={tab.id === defaultTab}
        aria-controls={`snurble-tab-panel-${tab.id}`}
        id={`snurble-tab-${tab.id}`}
        class:list={[
          "snurble-tabs__tab",
          tab.id === defaultTab && "snurble-tabs__tab--active",
        ]}
      >
        {tab.label}
      </button>
    ))}
  </div>
  <div class="snurble-tabs__panels">
    {tabs.map((tab) => (
      <div
        role="tabpanel"
        id={`snurble-tab-panel-${tab.id}`}
        aria-labelledby={`snurble-tab-${tab.id}`}
        hidden={tab.id !== defaultTab}
        class="snurble-tabs__panel"
      >
        <Fragment set:html={tabPanelContent.get(tab.id) ?? ""} />
      </div>
    ))}
  </div>
</div>

<script>
  const initTabs = (root: HTMLElement) => {
    const tabList = root.querySelector('[role="tablist"]');
    const tabs = [...root.querySelectorAll('[role="tab"]')] as HTMLButtonElement[];
    const panels = [...root.querySelectorAll('[role="tabpanel"]')] as HTMLElement[];

    if (!tabList) {
      return;
    }

    const selectTab = (selectedTab: HTMLButtonElement) => {
      const selectedId = selectedTab.id.replace("snurble-tab-", "");

      for (const tab of tabs) {
        const isSelected = tab === selectedTab;
        tab.setAttribute("aria-selected", isSelected.toString());
        tab.classList.toggle("snurble-tabs__tab--active", isSelected);
        tab.tabIndex = isSelected ? 0 : -1;
      }

      for (const panel of panels) {
        const isSelected = panel.id === `snurble-tab-panel-${selectedId}`;
        panel.hidden = !isSelected;
      }
    };

    for (const [index, tab] of tabs.entries()) {
      tab.addEventListener("click", () => selectTab(tab));

      tab.addEventListener("keydown", (e) => {
        let targetIndex = -1;

        if (e.key === "ArrowRight") {
          targetIndex = (index + 1) % tabs.length;
        } else if (e.key === "ArrowLeft") {
          targetIndex = (index - 1 + tabs.length) % tabs.length;
        } else if (e.key === "Home") {
          targetIndex = 0;
        } else if (e.key === "End") {
          targetIndex = tabs.length - 1;
        }

        if (targetIndex !== -1) {
          e.preventDefault();
          tabs[targetIndex].focus();
          selectTab(tabs[targetIndex]);
        }
      });

      // Set initial tabIndex
      const isActive = tab.classList.contains("snurble-tabs__tab--active");
      tab.tabIndex = isActive ? 0 : -1;
    }
  };

  const tabsRoots = document.querySelectorAll(".snurble-tabs");
  for (const root of tabsRoots) {
    if (root instanceof HTMLElement) {
      initTabs(root);
    }
  }
</script>

<style>
  .snurble-tabs {
    display: flex;
    flex-direction: column;
  }

  .snurble-tabs__tablist {
    display: flex;
    gap: var(--snurble-space-1);
    border-bottom: 1px solid var(--snurble-border-card);
    overflow-x: auto;
  }

  .snurble-tabs__tab {
    flex-shrink: 0;
    padding: var(--snurble-space-2) var(--snurble-space-3);
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    color: var(--snurble-text-muted);
    font-family: var(--snurble-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      color 150ms ease-out,
      border-bottom-color 150ms ease-out;
    outline-offset: 2px;
  }

  .snurble-tabs__tab:hover {
    color: var(--snurble-text);
  }

  .snurble-tabs__tab:focus-visible {
    outline: 2px solid var(--snurble-accent-success);
  }

  .snurble-tabs__tab--active {
    color: var(--snurble-text);
    border-bottom-color: var(--snurble-brand-primary);
  }

  .snurble-tabs__panels {
    padding-top: var(--snurble-space-4);
  }

  .snurble-tabs__panel {
    display: contents;
  }

  .snurble-tabs__panel[hidden] {
    display: none;
  }
</style>
