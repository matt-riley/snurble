---
/**
 * Dialog - Modal overlay component
 * 
 * Renders a semantic modal dialog with backdrop, native focus trapping,
 * and keyboard escape support.
 * 
 * Usage:
 * <Dialog id="my-dialog" open={true} title="Confirm action">
 *   <p>Are you sure?</p>
 *   <Button variant="primary">Confirm</Button>
 * </Dialog>
 */

export interface Props {
  /** Optional ID to control the dialog via JS (e.g. document.getElementById('...').showModal()) */
  id?: string;
  /** Whether the dialog is open initially (triggers showModal() via script) */
  open?: boolean;
  /** Dialog title (used for accessibility) */
  title?: string;
  /** Whether clicking the backdrop dismisses the dialog */
  closeOnBackdropClick?: boolean;
  /** Optional CSS class for the dialog container */
  class?: string;
}

const { id, open = false, title, closeOnBackdropClick = true, class: className } = Astro.props;
const titleId = title
  ? `${id ?? `snurble-dialog-${Math.random().toString(36).slice(2)}`}-title`
  : undefined;
---

<dialog
  id={id}
  class:list={[
    'snurble-dialog',
    className,
  ]}
  aria-labelledby={titleId}
  data-component="dialog"
  data-initially-open={open.toString()}
  data-close-on-backdrop={closeOnBackdropClick.toString()}
>
  {/* Dialog box */}
  <div class="snurble-dialog-box">
    {/* Title bar if provided */}
    {title && (
      <div class="snurble-dialog-header">
        <h2 id={titleId} class="snurble-dialog-title">
          {title}
        </h2>
        <button
          class="snurble-dialog-close"
          aria-label="Close dialog"
          data-close-button
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    )}

    {/* Content slot */}
    <div class="snurble-dialog-content">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .snurble-dialog {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 90vw;
    max-height: 90vh;
    margin: auto;
    overflow: visible;
  }

  .snurble-dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    animation: snurble-fade-in 150ms ease-out forwards;
    backdrop-filter: blur(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-dialog::backdrop {
      animation: none;
    }
  }

  .snurble-dialog-box {
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border-card);
    border-radius: 0.5rem;
    box-shadow: var(--snurble-shadow-spatial-modal);
    width: 100%;
    min-width: 20rem;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    animation: snurble-scale-fade-in 150ms ease-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-dialog-box {
      animation: none;
    }
  }

  .snurble-dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--snurble-space-4);
    border-bottom: 1px solid var(--snurble-border-card);
  }

  .snurble-dialog-title {
    margin: 0;
    font-family: var(--snurble-font-title);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--snurble-text);
  }

  .snurble-dialog-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--snurble-text-muted);
    border-radius: 0.375rem;
    transition:
      background-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out;
  }

  .snurble-dialog-close:hover {
    background: var(--snurble-surface-badge);
    color: var(--snurble-text);
  }

  .snurble-dialog-close:active {
    transform: scale(0.96);
  }

  .snurble-dialog-close:focus-visible {
    outline: 2px solid var(--snurble-focus-ring);
    outline-offset: 2px;
  }

  .snurble-dialog-close svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .snurble-dialog-content {
    padding: var(--snurble-space-4);
    overflow-y: auto;
  }

  @keyframes snurble-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes snurble-scale-fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  const initDialog = (el: HTMLDialogElement) => {
    if (el.dataset.snurbleDialogBound === 'true') {
      return;
    }

    el.dataset.snurbleDialogBound = 'true';
    const closeButton = el.querySelector('[data-close-button]');

    if (closeButton) {
      closeButton.addEventListener('click', () => el.close());
    }

    if (el.dataset.closeOnBackdrop === 'true') {
      el.addEventListener('click', (e) => {
        // Since dialog takes up the full width/height including backdrop,
        // if the click target is the dialog itself (not its inner content),
        // it's a backdrop click.
        if (e.target === el) {
          el.close();
        }
      });
    }

    // Handle initial Astro state
    if (el.dataset.initiallyOpen === 'true') {
      // Defer to ensure it renders correctly on initial load
      requestAnimationFrame(() => el.showModal());
    }

    // Observer for programmatic attribute changes from frameworks
    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'data-initially-open') {
          if (el.dataset.initiallyOpen === 'true' && !el.open) {
            el.showModal();
          } else if (el.dataset.initiallyOpen === 'false' && el.open) {
            el.close();
          }
        }
      }
    });

    observer.observe(el, { attributes: true });
  };

  const initDialogs = () => {
    const dialogs = document.querySelectorAll('[data-component="dialog"]');
    for (const el of dialogs) {
      if (el instanceof HTMLDialogElement) {
        initDialog(el);
      }
    }
  };

  initDialogs();
  document.addEventListener('astro:page-load', initDialogs);
</script>
