---
/**
 * Drawer (Sheet) - Slide-in overlay from screen edge
 * 
 * Renders a slide-out panel from the side (default: right) using the
 * native HTML <dialog> element for robust focus trapping and accessibility.
 * 
 * Usage:
 * <Drawer id="my-drawer" open={true} title="Menu" position="left">
 *   <nav>...</nav>
 * </Drawer>
 */

interface Props {
  /** Optional ID to control the drawer via JS (e.g. document.getElementById('...').showModal()) */
  id?: string;
  /** Whether the drawer is open initially (triggers showModal() via script) */
  open?: boolean;
  /** Drawer title */
  title?: string;
  /** Which side to slide from */
  position?: 'left' | 'right';
  /** Whether clicking the backdrop dismisses the drawer */
  closeOnBackdropClick?: boolean;
  /** Optional CSS class */
  class?: string;
}

const {
  id,
  open = false,
  title,
  position = 'right',
  closeOnBackdropClick = true,
  class: className,
} = Astro.props;
const titleId = title
  ? `${id ?? `snurble-drawer-${Math.random().toString(36).slice(2)}`}-title`
  : undefined;
---

<dialog
  id={id}
  class:list={[
    'snurble-drawer',
    `snurble-drawer-${position}`,
    className,
  ]}
  data-component="drawer"
  data-initially-open={open.toString()}
  data-close-on-backdrop={closeOnBackdropClick.toString()}
  aria-labelledby={titleId}
>
  {/* Drawer panel */}
  <div class="snurble-drawer-panel">
    {/* Header if provided */}
    {title && (
      <div class="snurble-drawer-header">
        <h2 id={titleId} class="snurble-drawer-title">
          {title}
        </h2>
        <button
          class="snurble-drawer-close"
          aria-label="Close drawer"
          data-close-button
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    )}

    {/* Content */}
    <div class="snurble-drawer-content">
      <slot />
    </div>
  </div>
</dialog>

<style>
  .snurble-drawer {
    padding: 0;
    border: none;
    background: transparent;
    margin: 0;
    max-width: 100vw;
    max-height: 100vh;
    height: 100vh;
    width: fit-content;
    overflow: visible;
  }

  .snurble-drawer-left {
    margin-right: auto;
  }

  .snurble-drawer-right {
    margin-left: auto;
  }

  .snurble-drawer::backdrop {
    background: rgba(0, 0, 0, 0.6);
    animation: snurble-fade-in 150ms ease-out forwards;
    backdrop-filter: blur(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-drawer::backdrop {
      animation: none;
    }
  }

  .snurble-drawer-panel {
    background: var(--snurble-surface-card);
    width: min(100vw, 420px);
    height: 100vh;
    display: flex;
    flex-direction: column;
    box-shadow: var(--snurble-shadow-spatial-modal);
  }

  .snurble-drawer-left .snurble-drawer-panel {
    border-right: 1px solid var(--snurble-border-card);
    animation: snurble-slide-in-left 150ms ease-out;
  }

  .snurble-drawer-right .snurble-drawer-panel {
    border-left: 1px solid var(--snurble-border-card);
    animation: snurble-slide-in-right 150ms ease-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-drawer-panel {
      animation: none !important;
    }
  }

  .snurble-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--snurble-space-4);
    border-bottom: 1px solid var(--snurble-border-card);
    flex-shrink: 0;
  }

  .snurble-drawer-title {
    margin: 0;
    font-family: var(--snurble-font-title);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--snurble-text);
  }

  .snurble-drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--snurble-text-muted);
    border-radius: 0.375rem;
    transition:
      background-color 150ms ease-out,
      color 150ms ease-out,
      transform 150ms ease-out;
    flex-shrink: 0;
  }

  .snurble-drawer-close:hover {
    background: var(--snurble-surface-badge);
    color: var(--snurble-text);
  }

  .snurble-drawer-close:active {
    transform: scale(0.96);
  }

  .snurble-drawer-close:focus-visible {
    outline: 2px solid var(--snurble-focus-ring);
    outline-offset: 2px;
  }

  .snurble-drawer-close svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .snurble-drawer-content {
    padding: var(--snurble-space-4);
    overflow-y: auto;
    flex: 1;
  }

  @keyframes snurble-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes snurble-slide-in-left {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(0);
    }
  }

  @keyframes snurble-slide-in-right {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(0);
    }
  }
</style>

<script>
  const initDrawer = (el: HTMLDialogElement) => {
    if (el.dataset.snurbleDrawerBound === 'true') {
      return;
    }

    el.dataset.snurbleDrawerBound = 'true';
    const closeButton = el.querySelector('[data-close-button]');

    if (closeButton) {
      closeButton.addEventListener('click', () => el.close());
    }

    if (el.dataset.closeOnBackdrop === 'true') {
      el.addEventListener('click', (e) => {
        if (e.target === el) {
          el.close();
        }
      });
    }

    if (el.dataset.initiallyOpen === 'true') {
      requestAnimationFrame(() => el.showModal());
    }

    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'data-initially-open') {
          if (el.dataset.initiallyOpen === 'true' && !el.open) {
            el.showModal();
          } else if (el.dataset.initiallyOpen === 'false' && el.open) {
            el.close();
          }
        }
      }
    });

    observer.observe(el, { attributes: true });
  };

  const initDrawers = () => {
    const drawers = document.querySelectorAll('[data-component="drawer"]');
    for (const drawer of drawers) {
      if (drawer instanceof HTMLDialogElement) {
        initDrawer(drawer);
      }
    }
  };

  initDrawers();
  document.addEventListener('astro:page-load', initDrawers);
</script>
