---
/**
 * DropdownMenu - Floating menu with keyboard navigation
 * 
 * Renders a dropdown menu with arrow key navigation, selection, and focus management.
 * Use with MenuButton for complete dropdown experience.
 * 
 * Usage:
 * <DropdownMenu
 *   id="main-menu"
 *   open={true}
 *   items={[
 *     { label: 'Edit', icon: 'edit' },
 *     { label: 'Delete', icon: 'trash', variant: 'danger' }
 *   ]}
 *   onSelect={(item) => { ... }}
 * />
 */

interface MenuItem {
  label: string;
  value?: string;
  icon?: string;
  variant?: 'default' | 'danger';
  disabled?: boolean;
}

interface Props {
  id?: string;
  open?: boolean;
  triggerId?: string;
  items: MenuItem[];
  onSelect?: (item: MenuItem) => void;
  class?: string;
}

const {
  id = `menu-${crypto.randomUUID()}`,
  open = false,
  triggerId,
  items = [],
  class: className,
} = Astro.props;
---

<div
  id={id}
  class:list={[
    'snurble-dropdown-menu',
    !triggerId && 'snurble-dropdown-menu--static',
    className,
  ]}
  data-component="dropdown-menu"
  data-open={open}
  data-trigger-id={triggerId}
  role="menu"
  aria-orientation="vertical"
  popover="manual"
>
  <div class="snurble-dropdown-menu-box">
    {items.map((item, idx) => (
      <button
        class:list={[
          'snurble-dropdown-menu-item',
          `snurble-dropdown-menu-item-${item.variant || 'default'}`,
        ]}
        role="menuitem"
        aria-disabled={item.disabled}
        disabled={item.disabled}
        data-index={idx}
        data-value={item.value || item.label}
      >
        {item.label}
      </button>
    ))}
  </div>
</div>

<style>
  .snurble-dropdown-menu {
    position: absolute;
    top: 0;
    left: 0;
    min-width: 200px;
    opacity: 0;
    pointer-events: none;
    animation: snurble-menu-exit 150ms ease-out forwards;
    z-index: var(--snurble-z-index-dropdown);
  }

  .snurble-dropdown-menu--static {
    position: relative;
    top: auto;
    left: auto;
  }

  .snurble-dropdown-menu[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
    animation: snurble-menu-enter 150ms ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-dropdown-menu {
      animation: none;
    }
  }

  .snurble-dropdown-menu-box {
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border-card);
    border-radius: var(--snurble-radius-lg);
    box-shadow: var(--snurble-shadow-spatial-floating);
    overflow: hidden;
    padding: 4px 0;
  }

  .snurble-dropdown-menu-item {
    display: flex;
    align-items: center;
    width: 100%;
    padding: var(--snurble-space-2) var(--snurble-space-3);
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    font-size: 0.875rem;
    color: var(--snurble-text);
    transition:
      background-color 150ms ease-out,
      color 150ms ease-out,
      opacity 150ms ease-out;
    position: relative;
  }

  .snurble-dropdown-menu-item:hover {
    background: var(--snurble-surface-badge);
  }

  .snurble-dropdown-menu-item:focus-visible {
    outline: none;
    background: var(--snurble-brand-primary);
    color: white;
  }

  .snurble-dropdown-menu-item:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .snurble-dropdown-menu-item-danger {
    color: var(--snurble-accent-danger);
  }

  .snurble-dropdown-menu-item-danger:focus-visible {
    background: var(--snurble-accent-danger);
    color: white;
  }

  @keyframes snurble-menu-enter {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes snurble-menu-exit {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-4px);
    }
  }
</style>

<script>
  import {
    applyAnchorPair,
    attachFloatingAutoUpdate,
    isOpen,
    noopCleanup,
    setOpen,
    supportsPopoverApi,
  } from "../internal/floating";

  const initDropdownMenu = (el: Element) => {
    if (!(el instanceof HTMLElement) || el.dataset.snurbleDropdownBound === 'true') {
      return;
    }

    el.dataset.snurbleDropdownBound = 'true';
    const items = [...el.querySelectorAll('[role="menuitem"]')].filter(
      (item) => !(item instanceof HTMLButtonElement) || !item.disabled
    );
    const trigger = el.dataset.triggerId ? document.querySelector(`#${CSS.escape(el.dataset.triggerId)}`) : null;
    let currentIndex = -1;
    let detachAutoUpdate = noopCleanup;

    if (!supportsPopoverApi(el)) {
      el.hidden = el.dataset.open !== 'true';
    }

    if (trigger instanceof HTMLElement) {
      applyAnchorPair(trigger, el, el.id || trigger.id || 'dropdown');
    }

    const updatePosition = () => {
      detachAutoUpdate();
      if (trigger instanceof HTMLElement) {
        detachAutoUpdate = attachFloatingAutoUpdate(trigger, el, 'bottom', 8);
      }
    };

    const setMenuOpen = (open: boolean, focusTrigger = false) => {
      if (open) {
        updatePosition();
      } else {
        detachAutoUpdate();
      }
      setOpen(el, open);
      trigger?.setAttribute('aria-expanded', open.toString());
      if (focusTrigger && trigger instanceof HTMLElement) {
        trigger.focus();
      }
    };

    const selectItem = (item: HTMLElement) => {
      const { value } = item.dataset;
      el.dispatchEvent(new CustomEvent('snurble-dropdown-select', {
        bubbles: true,
        detail: { value },
      }));
      setMenuOpen(false, true);
    };

    const focusItem = (rawIndex: number) => {
      if (items.length === 0) {
        return;
      }

      let index = rawIndex;
      if (index < 0) {
        index = items.length - 1;
      }
      if (index >= items.length) {
        index = 0;
      }
      currentIndex = index;
      const item = items[index];
      if (item instanceof HTMLElement) {
        item.focus();
      }
    };

    const handleKeyDown = (e: KeyboardEvent) => {
      if (!isOpen(el)) {
        return;
      }

      switch (e.key) {
        case 'ArrowDown': {
          e.preventDefault();
          focusItem(currentIndex + 1);
          break;
        }
        case 'ArrowUp': {
          e.preventDefault();
          focusItem(currentIndex - 1);
          break;
        }
        case 'Home': {
          e.preventDefault();
          focusItem(0);
          break;
        }
        case 'End': {
          e.preventDefault();
          focusItem(items.length - 1);
          break;
        }
        case 'Enter':
        case ' ': {
          e.preventDefault();
          if (currentIndex >= 0) {
            const item = items[currentIndex];
            if (item instanceof HTMLElement) {
              selectItem(item);
            }
          }
          break;
        }
        case 'Escape': {
          e.preventDefault();
          setMenuOpen(false, true);
          break;
        }
        default:
      }
    };

    if (trigger instanceof HTMLElement) {
      trigger.setAttribute('aria-haspopup', 'menu');
      trigger.setAttribute('aria-controls', el.id);
      trigger.setAttribute('aria-expanded', el.dataset.open === 'true' ? 'true' : 'false');
      trigger.addEventListener('click', () => {
        const shouldOpen = !isOpen(el);
        setMenuOpen(shouldOpen);
        if (shouldOpen) {
          focusItem(0);
        }
      });
    }

    for (const item of items) {
      if (item instanceof HTMLElement) {
        item.addEventListener('click', () => selectItem(item));
      }
    }

    document.addEventListener('keydown', handleKeyDown);
    document.addEventListener('click', (event) => {
      if (
        isOpen(el) &&
        event.target instanceof Node &&
        !el.contains(event.target) &&
        !(trigger instanceof HTMLElement && trigger.contains(event.target))
      ) {
        setMenuOpen(false);
      }
    });

    if (el.dataset.open === 'true') {
      requestAnimationFrame(() => setMenuOpen(true));
    }

    const observer = new MutationObserver((mutations) => {
      for (const mutation of mutations) {
        if (mutation.type === 'attributes' && mutation.attributeName === 'data-open') {
          setMenuOpen(el.dataset.open === 'true');
        }
      }
    });

    observer.observe(el, { attributes: true });
  };

  const initDropdownMenus = () => {
    const menus = document.querySelectorAll('[data-component="dropdown-menu"]');
    for (const menu of menus) {
      initDropdownMenu(menu);
    }
  };

  initDropdownMenus();
  document.addEventListener('astro:page-load', initDropdownMenus);
</script>
