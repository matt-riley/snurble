---
import { toViewTransitionStyle } from "../internal/view-transitions";
import SkillIconList from "../molecules/SkillIconList.astro";

interface Props {
  logo: string;
  logoAlt?: string;
  title: string;
  company: string;
  description: string;
  start: string;
  end: string;
  surface?: "solid" | "glass";
  viewTransitionName?: string;
  class?: string;
}

const {
  logo,
  logoAlt,
  title,
  company,
  description,
  start,
  end,
  surface = "solid",
  viewTransitionName,
  class: className,
} = Astro.props;
const resolvedLogoAlt = logoAlt || `${company} logo`;
const hasSkills = await Astro.slots.has("skills");

const cardStyle = toViewTransitionStyle(viewTransitionName);
---

<article class:list={["snurble-experience-card", `snurble-experience-card--${surface}`, className]} style={cardStyle}>
  <div class="snurble-experience-card__logo">
    <img src={logo} alt={resolvedLogoAlt} />
  </div>
  <div class="snurble-experience-card__content">
    <header class="snurble-experience-card__header">
      <div class="snurble-experience-card__title-group">
        <h3 class="snurble-experience-card__title">{title}</h3>
        <p class="snurble-experience-card__company">{company}</p>
      </div>
      <p class="snurble-experience-card__dates">
        <time datetime={start}>{start}</time> - <time datetime={end}>{end}</time>
      </p>
    </header>
    <slot />
  </div>
  <!--
    Trusted HTML boundary:
    `description` is only safe when sourced from upstream sanitization
    or trusted rich text rendering. Consumers must ensure description
    comes from a trusted source before using set:html.
  -->
  <div class="snurble-experience-card__description" set:html={description} />
  {hasSkills && (
    <div class="snurble-experience-card__skills">
      <SkillIconList>
        <slot name="skills" />
      </SkillIconList>
    </div>
  )}
</article>

<style>
  .snurble-experience-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--snurble-space-4);
    padding: var(--snurble-space-4);
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border);
    border-radius: 0.5rem;
    box-shadow: var(--snurble-shadow-sm);
    transition:
      transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 400ms cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 200ms ease-out,
      background 200ms ease-out;
  }

  .snurble-experience-card--glass {
    background: var(--snurble-surface-glass-card, var(--snurble-surface-card));
    backdrop-filter: var(--snurble-backdrop-blur, blur(12px));
  }

  .snurble-experience-card:hover {
    border-color: var(--snurble-action-secondary-border-hover, var(--snurble-border-strong));
    transform: translateY(-2px) scale(1.005);
    box-shadow: var(--snurble-shadow-glow-accent, var(--snurble-shadow-md));
  }

  .snurble-experience-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .snurble-experience-card__logo img {
    max-width: 8rem;
    max-height: 8rem;
    object-fit: contain;
    border-radius: 0.375rem;
    outline: 1px solid rgba(0, 0, 0, 0.1);
    outline-offset: -1px;
  }

  .snurble-experience-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--snurble-space-3);
    min-width: 0;
  }

  .snurble-experience-card__header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--snurble-space-2);
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: var(--snurble-space-2);
    border-bottom: 2px solid var(--snurble-border-card);
  }

  .snurble-experience-card__title-group {
    flex: 1;
    min-width: 0;
  }

  .snurble-experience-card__title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--snurble-brand-heading);
    text-wrap: balance;
  }

  .snurble-experience-card__company {
    margin: 0;
    font-size: 0.875rem;
    color: var(--snurble-text-muted);
  }

  .snurble-experience-card__dates {
    margin: 0;
    font-size: 1rem;
    white-space: nowrap;
  }

  .snurble-experience-card__description {
    grid-column: 1 / -1;
    padding: var(--snurble-space-2);
    text-align: justify;
  }

  .snurble-experience-card__skills {
    grid-column: 1 / -1;
    padding: var(--snurble-space-2);
    padding-top: 0;
  }

  @media (max-width: 768px) {
    .snurble-experience-card {
      grid-template-columns: 1fr;
    }

    .snurble-experience-card__logo img {
      max-width: 6rem;
      max-height: 6rem;
    }
  }

  @media (prefers-color-scheme: dark) {
    .snurble-experience-card__logo img {
      outline-color: rgba(255, 255, 255, 0.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-experience-card {
      transition:
        box-shadow 200ms ease-out,
        border-color 200ms ease-out,
        background 200ms ease-out;
    }

    .snurble-experience-card:hover {
      transform: none;
    }
  }
</style>
