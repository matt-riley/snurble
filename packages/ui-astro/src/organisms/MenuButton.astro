---
interface MenuButtonItem {
  label: string;
  value?: string;
  href?: string;
  variant?: "default" | "danger";
  disabled?: boolean;
}

interface Props {
  id?: string;
  label: string;
  items?: MenuButtonItem[];
  variant?: "primary" | "secondary" | "danger";
  size?: "sm" | "md" | "lg";
  placement?: "bottom" | "top";
  align?: "start" | "end";
  class?: string;
}

const {
  id = `menu-button-${crypto.randomUUID()}`,
  label,
  items = [],
  variant = "secondary",
  size = "md",
  placement = "bottom",
  align = "start",
  class: className,
} = Astro.props;
const menuId = `${id}-menu`;
---

<div
  class:list={[
    "snurble-menu-button",
    `snurble-menu-button--${placement}`,
    `snurble-menu-button--align-${align}`,
    className,
  ]}
  data-component="menu-button"
>
  <button
    id={id}
    type="button"
    class:list={["snurble-menu-button__trigger", `snurble-menu-button__trigger--${variant}`, `snurble-menu-button__trigger--${size}`]}
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls={menuId}
    popovertarget={menuId}
    popovertargetaction="toggle"
    data-menu-trigger
  >
    <span>{label}</span>
    <svg class="snurble-menu-button__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </button>
  <div id={menuId} class="snurble-menu-button__menu" role="menu" aria-labelledby={id} data-menu popover="auto">
    {items.map((item) => (
      item.href ? (
        <a
          class:list={["snurble-menu-button__item", item.variant === "danger" && "snurble-menu-button__item--danger"]}
          role="menuitem"
          href={item.disabled ? undefined : item.href}
          aria-disabled={item.disabled ? "true" : undefined}
          data-menu-item
          data-value={item.value ?? item.label}
        >
          {item.label}
        </a>
      ) : (
        <button
          class:list={["snurble-menu-button__item", item.variant === "danger" && "snurble-menu-button__item--danger"]}
          type="button"
          role="menuitem"
          disabled={item.disabled}
          aria-disabled={item.disabled ? "true" : undefined}
          data-menu-item
          data-value={item.value ?? item.label}
        >
          {item.label}
        </button>
      )
    ))}
  </div>
</div>

<style>
  .snurble-menu-button {
    position: relative;
    display: inline-flex;
  }

  .snurble-menu-button__trigger {
    --snurble-menu-button-background: var(--snurble-action-secondary);
    --snurble-menu-button-background-hover: var(--snurble-action-secondary-hover);
    --snurble-menu-button-color: var(--snurble-action-secondary-text);
    --snurble-menu-button-border: var(--snurble-action-secondary-border);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--snurble-space-2);
    min-height: 2.75rem;
    padding: calc(var(--snurble-space-3) - 0.125rem) var(--snurble-space-5);
    color: var(--snurble-menu-button-color);
    background: var(--snurble-menu-button-background);
    border: 1px solid var(--snurble-menu-button-border);
    border-radius: var(--snurble-radius-full);
    box-shadow: var(--snurble-action-shadow);
    font-family: var(--snurble-font-body);
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      background var(--snurble-duration-fast) var(--snurble-ease-soft),
      box-shadow var(--snurble-duration-fast) var(--snurble-ease-soft),
      transform var(--snurble-duration-fast) var(--snurble-ease-soft);
  }

  .snurble-menu-button__trigger--primary {
    --snurble-menu-button-background: var(--snurble-action-primary);
    --snurble-menu-button-background-hover: var(--snurble-action-primary-hover);
    --snurble-menu-button-color: var(--snurble-action-primary-text);
    --snurble-menu-button-border: var(--snurble-action-primary-border);
  }

  .snurble-menu-button__trigger--danger {
    --snurble-menu-button-background: var(--snurble-action-danger);
    --snurble-menu-button-background-hover: var(--snurble-action-danger-hover);
    --snurble-menu-button-color: var(--snurble-action-danger-text);
    --snurble-menu-button-border: var(--snurble-action-danger-border);
  }

  .snurble-menu-button__trigger--sm {
    min-height: 2.25rem;
    padding: var(--snurble-space-2) var(--snurble-space-4);
    font-size: 0.875rem;
  }

  .snurble-menu-button__trigger--lg {
    min-height: 3.25rem;
    padding: var(--snurble-space-4) var(--snurble-space-6);
    font-size: 1.125rem;
  }

  .snurble-menu-button__trigger:hover {
    background: var(--snurble-menu-button-background-hover);
    box-shadow: var(--snurble-action-shadow-hover);
    transform: translateY(-1px);
  }

  .snurble-menu-button__trigger:focus-visible {
    outline: 3px solid var(--snurble-focus-ring);
    outline-offset: 2px;
  }

  .snurble-menu-button__chevron {
    width: 1rem;
    height: 1rem;
    transition: transform 150ms ease-out;
  }

  .snurble-menu-button[data-open="true"] .snurble-menu-button__chevron {
    transform: rotate(180deg);
  }

  .snurble-menu-button__menu {
    position: absolute;
    inset-inline-start: 0;
    top: calc(100% + var(--snurble-space-2));
    z-index: var(--snurble-z-index-dropdown);
    min-width: 12rem;
    padding: var(--snurble-space-1) 0;
    background: var(--snurble-surface-card);
    border: 1px solid var(--snurble-border-card);
    border-radius: var(--snurble-radius-lg);
    box-shadow: var(--snurble-shadow-spatial-floating);
  }

  @supports (position-anchor: --snurble-anchor) {
    .snurble-menu-button__menu {
      position: absolute;
      position-anchor: --snurble-anchor;
      inset-inline-start: auto;
      top: auto;
      left: anchor(left);
      margin-top: var(--snurble-space-2);
      min-width: max(12rem, anchor-size(width));
    }

    .snurble-menu-button--top .snurble-menu-button__menu {
      bottom: calc(anchor(top) + var(--snurble-space-2));
      margin-top: 0;
    }

    .snurble-menu-button--bottom .snurble-menu-button__menu {
      top: calc(anchor(bottom) + var(--snurble-space-2));
    }

    .snurble-menu-button--align-end .snurble-menu-button__menu {
      left: calc(anchor(right) - anchor-size(width));
    }
  }

  .snurble-menu-button--top .snurble-menu-button__menu {
    top: auto;
    bottom: calc(100% + var(--snurble-space-2));
  }

  .snurble-menu-button--align-end .snurble-menu-button__menu {
    inset-inline: auto 0;
  }

  .snurble-menu-button__item {
    display: flex;
    align-items: center;
    width: 100%;
    padding: var(--snurble-space-2) var(--snurble-space-3);
    color: var(--snurble-text);
    background: transparent;
    border: 0;
    font: inherit;
    font-size: 0.875rem;
    text-align: start;
    text-decoration: none;
    cursor: pointer;
  }

  .snurble-menu-button__item:hover,
  .snurble-menu-button__item:focus-visible {
    color: var(--snurble-text);
    background: var(--snurble-surface-badge);
    outline: none;
  }

  .snurble-menu-button__item--danger {
    color: var(--snurble-accent-danger);
  }

  .snurble-menu-button__item[aria-disabled="true"],
  .snurble-menu-button__item:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (prefers-reduced-motion: reduce) {
    .snurble-menu-button__trigger,
    .snurble-menu-button__chevron {
      transition: none;
    }

    .snurble-menu-button__trigger:hover {
      transform: none;
    }
  }
</style>

<script>
  import {
    applyAnchorPair,
    attachFloatingAutoUpdate,
    noopCleanup,
    setOpen,
    supportsPopoverApi,
  } from "../internal/floating";

  const initMenuButton = (el: Element) => {
    if (!(el instanceof HTMLElement) || el.dataset.snurbleMenuButtonBound === "true") {
      return;
    }

    el.dataset.snurbleMenuButtonBound = "true";
    const trigger = el.querySelector("[data-menu-trigger]");
    const menu = el.querySelector("[data-menu]");
    const items = [...el.querySelectorAll("[data-menu-item]")].filter(
      (item) => item.getAttribute("aria-disabled") !== "true" && !(item instanceof HTMLButtonElement && item.disabled)
    );
    let currentIndex = -1;
    let detachAutoUpdate = noopCleanup;

    if (!(trigger instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) {
      return;
    }

    applyAnchorPair(trigger, menu, menu.id || trigger.id || 'menu-button');

    const syncExpanded = (open: boolean) => {
      el.dataset.open = open ? "true" : "false";
      trigger.setAttribute("aria-expanded", open.toString());
      if (open) {
        detachAutoUpdate();
        detachAutoUpdate = attachFloatingAutoUpdate(
          trigger,
          menu,
          el.classList.contains('snurble-menu-button--top') ? 'top' : 'bottom',
          8
        );
      } else {
        detachAutoUpdate();
      }
    };

    const setMenuOpen = (open: boolean, focusTrigger = false) => {
      setOpen(menu, open);
      syncExpanded(open);
      if (focusTrigger) {
        trigger.focus();
      }
    };

    const focusItem = (index: number) => {
      if (items.length === 0) {
        return;
      }

      let nextIndex = index;
      if (nextIndex < 0) {
        nextIndex = items.length - 1;
      }
      if (nextIndex >= items.length) {
        nextIndex = 0;
      }
      currentIndex = nextIndex;
      const item = items[currentIndex];
      if (item instanceof HTMLElement) {
        item.focus();
      }
    };

    trigger.addEventListener("click", () => {
      const shouldOpen = el.dataset.open !== "true";
      if (!supportsPopoverApi(menu)) {
        setMenuOpen(shouldOpen);
      }
      if (shouldOpen) {
        focusItem(0);
      }
    });

    menu.addEventListener("toggle", () => {
      syncExpanded(menu.matches(':popover-open'));
      if (menu.matches(':popover-open')) {
        focusItem(0);
      }
    });

    el.addEventListener("keydown", (event) => {
      if (!(event instanceof KeyboardEvent)) {
        return;
      }

      if (event.key === "Escape" && el.dataset.open === "true") {
        event.preventDefault();
        setMenuOpen(false, true);
        return;
      }

      if (event.key === "ArrowDown") {
        event.preventDefault();
        setMenuOpen(true);
        focusItem(currentIndex + 1);
        return;
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        setMenuOpen(true);
        focusItem(currentIndex - 1);
        return;
      }

      if (event.key === "Home") {
        event.preventDefault();
        focusItem(0);
        return;
      }

      if (event.key === "End") {
        event.preventDefault();
        focusItem(items.length - 1);
      }
    });

    for (const item of items) {
      item.addEventListener("click", () => {
        el.dispatchEvent(new CustomEvent("snurble-menu-select", {
          bubbles: true,
          detail: { value: (item as HTMLElement).dataset.value },
        }));
        setMenuOpen(false, true);
      });
    }

    document.addEventListener("click", (event) => {
      if (event.target instanceof Node && !el.contains(event.target) && el.dataset.open === 'true') {
        setMenuOpen(false);
      }
    });
  };

  const initMenuButtons = () => {
    for (const el of document.querySelectorAll('[data-component="menu-button"]')) {
      initMenuButton(el);
    }
  };

  initMenuButtons();
  document.addEventListener("astro:page-load", initMenuButtons);
</script>
