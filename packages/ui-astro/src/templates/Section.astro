---
import DecoratedHeading from "../molecules/DecoratedHeading.astro";

interface TitledProps {
  title: string;
  headingId: string;
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  decorated?: boolean;
  variant?: "display" | "title";
  labelledBy?: never;
  class?: string;
  spacing?: 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8;
}

interface AssociatedProps {
  title?: never;
  headingId?: never;
  level?: never;
  decorated?: never;
  variant?: never;
  labelledBy: string;
  class?: string;
  spacing?: 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8;
}

type Props = TitledProps | AssociatedProps;

const {
  title,
  headingId,
  labelledBy,
  level = 2,
  decorated = false,
  variant = "title",
  class: className,
  spacing = 4,
} = Astro.props;

const normalizedTitle = typeof title === "string" ? title.trim() : "";
const normalizedHeadingId = typeof headingId === "string" ? headingId.trim() : "";
const normalizedLabelledBy = typeof labelledBy === "string" ? labelledBy.trim() : "";

const hasTitle = normalizedTitle.length > 0;
const hasHeadingId = normalizedHeadingId.length > 0;
const hasLabelledBy = normalizedLabelledBy.length > 0;

if (hasTitle === hasLabelledBy) {
  throw new Error("Section requires exactly one of `title` or `labelledBy`.");
}

if (hasTitle && !hasHeadingId) {
  throw new Error("Section title mode requires a non-empty `headingId`.");
}

const resolvedHeadingId = hasTitle ? normalizedHeadingId : normalizedLabelledBy;
const HeadingTag = `h${level}` as `h${1 | 2 | 3 | 4 | 5 | 6}`;
---

<section
  aria-labelledby={resolvedHeadingId}
  class:list={["snurble-section", className]}
  style={`--snurble-section-gap: var(--snurble-space-${spacing});`}
>
  {
    hasTitle && decorated && (
      <>
        <HeadingTag id={resolvedHeadingId} class="sr-only">
          {normalizedTitle}
        </HeadingTag>
        <DecoratedHeading text={normalizedTitle} />
      </>
    )
  }
  {
    hasTitle && !decorated && (
      <HeadingTag
        id={resolvedHeadingId}
        class:list={["snurble-section__title", `snurble-section__title--${variant}`]}
      >
        {normalizedTitle}
      </HeadingTag>
    )
  }
  <div class="snurble-section__content">
    <slot />
  </div>
</section>

<style>
  .snurble-section {
    display: grid;
    gap: var(--snurble-section-gap, var(--snurble-space-4));
    margin: 0;
  }

  .snurble-section__title {
    margin: 0;
    color: var(--snurble-brand-heading);
    line-height: 1.1;
    text-wrap: balance;
  }

  .snurble-section__title--display {
    font-family: var(--snurble-font-display);
    font-size: clamp(1.5rem, 2vw, 2rem);
    text-transform: uppercase;
  }

  .snurble-section__title--title {
    font-family: var(--snurble-font-title);
    font-size: clamp(1.25rem, 1.5vw, 1.75rem);
    font-weight: 700;
  }

  .snurble-section__content {
    min-width: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
